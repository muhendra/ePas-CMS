@{
    ViewData["Title"] = "Dashboard Performance Verifikator";
}

<script src="/js/apexcharts.js"></script>

@section Styles {
    <style>
        .verifier-dashboard {
            background: #f4f5f8;
            min-height: calc(100vh - 120px);
            padding: 28px 32px;
            color: #101820;
        }

        .dash-title {
            font-size: 28px;
            font-weight: 800;
            margin: 0;
        }

        .filter-bar {
            display: flex;
            gap: 16px;
            justify-content: flex-end;
            flex-wrap: wrap;
        }

        .filter-select {
            min-width: 145px;
            height: 48px;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            padding: 0 16px;
            background: #fff;
            font-weight: 500;
        }

        .card-modern {
            background: #fff;
            border-radius: 14px;
            border: 1px solid #e5e7eb;
            box-shadow: 0 6px 18px rgba(15,23,42,.08);
            height: 100%;
        }

        .chart-card {
            padding: 24px;
        }

        .card-titlex {
            font-size: 18px;
            font-weight: 800;
            margin-bottom: 2px;
        }

        .card-subtitlex {
            color: #6b7280;
            font-size: 14px;
        }

        .donut-wrap {
            display: grid;
            grid-template-columns: 1fr 170px;
            gap: 10px;
            align-items: center;
        }

        .status-item {
            margin-bottom: 18px;
        }

        .status-row {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #6b7280;
            font-size: 14px;
        }

        .status-dot {
            width: 15px;
            height: 15px;
            border-radius: 4px;
        }

        .status-value {
            font-size: 18px;
            font-weight: 800;
            color: #111827;
            margin-left: 23px;
            margin-top: 4px;
        }

        .section-title {
            font-size: 18px;
            font-weight: 900;
            margin: 24px 0 12px;
        }

        .table-card {
            background: #fff;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            overflow: hidden;
        }

        .table {
            margin: 0;
        }

            .table thead th {
                background: #eaeaea;
                color: #111827;
                font-size: 16px;
                font-weight: 900;
                padding: 16px 22px;
                border: none;
                white-space: nowrap;
            }

            .table tbody td {
                padding: 18px 22px;
                border: none;
                vertical-align: middle;
                font-size: 15px;
                color: #111827;
            }

            .table tbody tr {
                border-bottom: 1px solid #f1f5f9;
            }

        .total-row td {
            background: #f3ffb8;
            font-weight: 900;
        }

        .sortable {
            cursor: pointer;
            user-select: none;
        }

        .sort-icon {
            color: #21B6D7;
            font-size: 15px;
            margin-left: 6px;
        }

        .loading-box {
            background: #fff;
            border-radius: 14px;
            border: 1px solid #e5e7eb;
            padding: 18px;
            margin-bottom: 16px;
            font-weight: 700;
            color: #64748b;
        }

        /* Pagination seperti contoh gambar: < 1 2 3 4 5 > */
        .pagination-wrap {
            display: flex;
            justify-content: flex-start;
            align-items: center;
            margin: 12px 0 18px;
        }

        .pagination-soft {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: #94a3b8;
        }

        .page-btn {
            border: none;
            background: transparent;
            color: #111827;
            min-width: 24px;
            height: 24px;
            padding: 0 6px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 800;
            line-height: 24px;
            text-align: center;
            cursor: pointer;
        }

            .page-btn.active {
                background: #21B6D7;
                color: #fff;
            }

            .page-btn:disabled {
                color: #cbd5e1;
                cursor: not-allowed;
                opacity: .75;
            }

            .page-btn.page-arrow {
                color: #94a3b8;
                min-width: 18px;
                padding: 0 2px;
                font-size: 13px;
            }

                .page-btn.page-arrow:not(:disabled):hover,
                .page-btn:not(.active):not(:disabled):hover {
                    background: #eaf8fc;
                    color: #21B6D7;
                }

        @@media (max-width: 992px) {
            .donut-wrap {
                grid-template-columns: 1fr;
            }

            .filter-bar {
                justify-content: flex-start;
            }
        }
    </style>
}

<div class="verifier-dashboard">

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <h2 class="dash-title">Dashboard Performance Verifikator</h2>

        <div class="filter-bar">
            <select id="filterRegion" class="filter-select">
                <option value="">Semua Region</option>
                <option value="I">Region I</option>
                <option value="II">Region II</option>
                <option value="III">Region III</option>
                <option value="IV">Region IV</option>
                <option value="V">Region V</option>
                <option value="VI">Region VI</option>
                <option value="VII">Region VII</option>
                <option value="VIII">Region VIII</option>
            </select>

            <select id="filterMonth" class="filter-select">
                <option value="">Semua Bulan</option>
                <option value="1">Januari</option>
                <option value="2">Februari</option>
                <option value="3">Maret</option>
                <option value="4">April</option>
                <option value="5">Mei</option>
                <option value="6">Juni</option>
                <option value="7">Juli</option>
                <option value="8">Agustus</option>
                <option value="9">September</option>
                <option value="10">Oktober</option>
                <option value="11">November</option>
                <option value="12">Desember</option>
            </select>

            <select id="filterDay" class="filter-select">
                <option value="">Semua Hari</option>
                <option value="1">Senin</option>
                <option value="2">Selasa</option>
                <option value="3">Rabu</option>
                <option value="4">Kamis</option>
                <option value="5">Jumat</option>
                <option value="6">Sabtu</option>
                <option value="0">Minggu</option>
            </select>

            <select id="filterYear" class="filter-select">
                @{
                    var currentYear = DateTime.Now.Year;
                    for (int y = currentYear - 3; y <= currentYear + 1; y++)
                    {
                        <option value="@y" selected="@(y == currentYear)">@y</option>
                    }
                }
            </select>
        </div>
    </div>

    <div id="loadingBox" class="loading-box">
        Memuat data performance verifikator...
    </div>

    <div class="row g-4">
        <div class="col-xl-8">
            <div class="card-modern chart-card">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <div class="card-titlex">Pencapaian Total yang di Verifikasi</div>
                        <div class="card-subtitlex">dari total <span id="totalReportText">0</span> Report</div>
                    </div>
                </div>

                <div id="verifierBarChart" style="height:270px;"></div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card-modern chart-card">
                <div class="donut-wrap">
                    <div id="verifierDonutChart" style="height:250px;"></div>

                    <div>
                        <div class="status-item">
                            <div class="status-row">
                                <span class="status-dot" style="background:#a8c51d;"></span>
                                Audit Terverifikasi
                            </div>
                            <div class="status-value" id="verifiedVal">0</div>
                        </div>

                        <div class="status-item">
                            <div class="status-row">
                                <span class="status-dot" style="background:#26b6d5;"></span>
                                Dalam Review
                            </div>
                            <div class="status-value" id="reviewVal">0</div>
                        </div>

                        <div class="status-item mb-0">
                            <div class="status-row">
                                <span class="status-dot" style="background:#f32645;"></span>
                                Banding
                            </div>
                            <div class="status-value" id="appealVal">0</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h4 class="section-title">Peringkat Verifikator</h4>

    <div class="table-card">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th class="sortable" data-table="ranking" data-field="rank">
                            Peringkat Verifikator <i class="bi bi-arrow-down-up sort-icon"></i>
                        </th>
                        <th class="sortable" data-table="ranking" data-field="verifier">
                            Verifikator <i class="bi bi-arrow-down-up sort-icon"></i>
                        </th>
                        <th class="sortable" data-table="ranking" data-field="speedSeconds">
                            Kecepatan<br />Verifikasi Audit <i class="bi bi-arrow-down-up sort-icon"></i>
                        </th>
                        <th class="sortable" data-table="ranking" data-field="verifiedAudit">
                            Total Audit yang<br />Diverifikasi <i class="bi bi-arrow-down-up sort-icon"></i>
                        </th>
                        <th class="sortable" data-table="ranking" data-field="missedAudit">
                            Total Audit yang<br />Terlewat <i class="bi bi-arrow-down-up sort-icon"></i>
                        </th>
                        <th class="sortable" data-table="ranking" data-field="cancelledAudit">
                            Total Audit yang<br />Dibatalkan <i class="bi bi-arrow-down-up sort-icon"></i>
                        </th>
                        <th class="sortable" data-table="ranking" data-field="lastVerifiedDate">
                            Verifikasi<br />Audit Terakhir <i class="bi bi-arrow-down-up sort-icon"></i>
                        </th>
                    </tr>
                </thead>

                <tbody id="rankingBody">
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            Memuat data...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="pagination-wrap">
        <div id="rankingPagination" class="pagination-soft"></div>
    </div>

    <h4 class="section-title">Performa Verifikator</h4>

    <div class="table-card">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th class="sortable" data-table="performance" data-field="verifier">
                            Verifikator <i class="bi bi-arrow-down-up sort-icon"></i>
                        </th>
                        <th class="sortable" data-table="performance" data-field="totalAudited">
                            Total<br />Audited <i class="bi bi-arrow-down-up sort-icon"></i>
                        </th>
                        <th class="sortable" data-table="performance" data-field="underVerified">
                            Under Verified <i class="bi bi-arrow-down-up sort-icon"></i>
                        </th>
                        <th class="sortable" data-table="performance" data-field="doneVerified">
                            Done Verified <i class="bi bi-arrow-down-up sort-icon"></i>
                        </th>
                        <th class="sortable" data-table="performance" data-field="verifiedPercent">
                            % verified <i class="bi bi-arrow-down-up sort-icon"></i>
                        </th>
                        <th class="sortable" data-table="performance" data-field="perday">
                            PERDAY <i class="bi bi-arrow-down-up sort-icon"></i>
                        </th>
                        <th class="sortable" data-table="performance" data-field="totalSpbu">
                            Total SPBU <i class="bi bi-arrow-down-up sort-icon"></i>
                        </th>
                        <th class="sortable" data-table="performance" data-field="remainingSpbu">
                            Sisa SPBU <i class="bi bi-arrow-down-up sort-icon"></i>
                        </th>
                    </tr>
                </thead>

                <tbody id="performanceBody">
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            Memuat data...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="pagination-wrap">
        <div id="performancePagination" class="pagination-soft"></div>
    </div>
</div>

@section Scripts {
    <script>
        let verifierBarChart = null;
        let verifierDonutChart = null;

        let rankingData = [];
        let performanceData = [];

        // Jumlah row per halaman. Dibuat 7 agar pagination langsung tampil seperti contoh desain.
        const pageSize = 7;

        let rankingCurrentPage = 1;
        let performanceCurrentPage = 1;

        let rankingSort = {
            field: 'rank',
            direction: 'asc'
        };

        let performanceSort = {
            field: 'doneVerified',
            direction: 'desc'
        };

        function normalizeArray(arr) {
            if (!arr || !Array.isArray(arr)) return Array(12).fill(0);
            return arr.map(x => Number(x || 0));
        }

        function formatDateTime(value) {
            if (!value) return '-';

            const d = new Date(value);
            if (isNaN(d.getTime())) return '-';

            const date = d.toLocaleDateString('id-ID', {
                day: '2-digit',
                month: '2-digit',
                year: 'numeric'
            });

            const time = d.toLocaleTimeString('id-ID', {
                hour: '2-digit',
                minute: '2-digit'
            });

            return `${date}<br><small class="text-muted">${time} WIB</small>`;
        }

        function parseSpeedToSeconds(speed) {
            if (!speed || speed === '-') return null;

            let total = 0;

            const jam = speed.match(/(\d+)\s*Jam/i);
            const menit = speed.match(/(\d+)\s*Menit/i);
            const detik = speed.match(/(\d+)\s*Detik/i);

            if (jam) total += Number(jam[1]) * 3600;
            if (menit) total += Number(menit[1]) * 60;
            if (detik) total += Number(detik[1]);

            return total > 0 ? total : null;
        }

        function getSortValue(row, field) {
            if (field === 'speedSeconds') {
                const value = row.speedSeconds ?? parseSpeedToSeconds(row.speed);
                return value === null || value === undefined ? Number.MAX_SAFE_INTEGER : Number(value);
            }

            if (field === 'lastVerifiedDate') {
                if (!row.lastVerifiedDate) return 0;

                const date = new Date(row.lastVerifiedDate);
                return isNaN(date.getTime()) ? 0 : date.getTime();
            }

            const value = row[field];

            if (typeof value === 'number') return value;

            if (value === null || value === undefined) return '';

            const numericValue = Number(value);
            if (!isNaN(numericValue) && value !== '') return numericValue;

            return String(value).toLowerCase();
        }

        function sortItems(items, field, direction) {
            const sorted = [...items];

            sorted.sort((a, b) => {
                const av = getSortValue(a, field);
                const bv = getSortValue(b, field);

                if (typeof av === 'number' && typeof bv === 'number') {
                    return direction === 'asc' ? av - bv : bv - av;
                }

                return direction === 'asc'
                    ? String(av).localeCompare(String(bv))
                    : String(bv).localeCompare(String(av));
            });

            return sorted;
        }

        function paginateItems(items, currentPage) {
            const start = (currentPage - 1) * pageSize;
            return items.slice(start, start + pageSize);
        }

        function renderPagination(containerId, totalItems, currentPage, onPageClick) {
            const container = document.getElementById(containerId);

            if (!container) return;

            totalItems = Number(totalItems || 0);

            if (totalItems <= 0) {
                container.innerHTML = '';
                return;
            }

            const totalPages = Math.max(1, Math.ceil(totalItems / pageSize));
            const safeCurrentPage = Math.min(Math.max(Number(currentPage || 1), 1), totalPages);
            const pages = getCompactPaginationPages(safeCurrentPage, totalPages);

            let html = '';

            html += `
                <button type="button"
                        class="page-btn page-arrow"
                        ${safeCurrentPage === 1 ? 'disabled' : ''}
                        data-page="${safeCurrentPage - 1}"
                        aria-label="Previous page">
                    <i class="bi bi-chevron-left"></i>
                </button>
            `;

            pages.forEach(page => {
                html += `
                    <button type="button"
                            class="page-btn ${page === safeCurrentPage ? 'active' : ''}"
                            data-page="${page}">
                        ${page}
                    </button>
                `;
            });

            html += `
                <button type="button"
                        class="page-btn page-arrow"
                        ${safeCurrentPage === totalPages ? 'disabled' : ''}
                        data-page="${safeCurrentPage + 1}"
                        aria-label="Next page">
                    <i class="bi bi-chevron-right"></i>
                </button>
            `;

            container.innerHTML = html;

            container.querySelectorAll('.page-btn').forEach(btn => {
                btn.addEventListener('click', function () {
                    const page = Number(this.dataset.page);

                    if (!page || page < 1 || page > totalPages || page === safeCurrentPage) return;

                    onPageClick(page);
                });
            });
        }

        function getCompactPaginationPages(currentPage, totalPages) {
            const maxVisiblePages = 5;

            if (totalPages <= maxVisiblePages) {
                return Array.from({ length: totalPages }, (_, i) => i + 1);
            }

            let startPage = currentPage - Math.floor(maxVisiblePages / 2);
            let endPage = currentPage + Math.floor(maxVisiblePages / 2);

            if (startPage < 1) {
                startPage = 1;
                endPage = maxVisiblePages;
            }

            if (endPage > totalPages) {
                endPage = totalPages;
                startPage = totalPages - maxVisiblePages + 1;
            }

            return Array.from(
                { length: endPage - startPage + 1 },
                (_, i) => startPage + i
            );
        }

        function refreshSortIcons(tableName, field, direction) {
            document.querySelectorAll(`.sortable[data-table="${tableName}"] .sort-icon`).forEach(icon => {
                icon.className = 'bi bi-arrow-down-up sort-icon';
            });

            const activeIcon = document.querySelector(`.sortable[data-table="${tableName}"][data-field="${field}"] .sort-icon`);
            if (!activeIcon) return;

            activeIcon.className = direction === 'asc'
                ? 'bi bi-sort-up sort-icon'
                : 'bi bi-sort-down sort-icon';
        }

        function applyRankingSort() {
            const sorted = sortItems(rankingData, rankingSort.field, rankingSort.direction);


            const totalPages = Math.max(1, Math.ceil(sorted.length / pageSize));
            if (rankingCurrentPage > totalPages) {
                rankingCurrentPage = totalPages;
            }

            const pagedItems = paginateItems(sorted, rankingCurrentPage);

            renderRanking(pagedItems);
            renderPagination('rankingPagination', sorted.length, rankingCurrentPage, function (page) {
                rankingCurrentPage = page;
                applyRankingSort();
            });

            refreshSortIcons('ranking', rankingSort.field, rankingSort.direction);
        }

        function applyPerformanceSort() {
            const sorted = sortItems(performanceData, performanceSort.field, performanceSort.direction);

            const totalPages = Math.max(1, Math.ceil(sorted.length / pageSize));
            if (performanceCurrentPage > totalPages) {
                performanceCurrentPage = totalPages;
            }

            const pagedItems = paginateItems(sorted, performanceCurrentPage);

            renderPerformance(pagedItems, sorted);
            renderPagination('performancePagination', sorted.length, performanceCurrentPage, function (page) {
                performanceCurrentPage = page;
                applyPerformanceSort();
            });

            refreshSortIcons('performance', performanceSort.field, performanceSort.direction);
        }

        function bindSortEvents() {
            document.querySelectorAll('.sortable').forEach(th => {
                th.addEventListener('click', function () {
                    const table = this.dataset.table;
                    const field = this.dataset.field;

                    if (table === 'ranking') {
                        rankingCurrentPage = 1;

                        if (rankingSort.field === field) {
                            rankingSort.direction = rankingSort.direction === 'asc' ? 'desc' : 'asc';
                        } else {
                            rankingSort.field = field;
                            rankingSort.direction = (field === 'speedSeconds' || field === 'rank') ? 'asc' : 'desc';
                        }

                        applyRankingSort();
                    }

                    if (table === 'performance') {
                        performanceCurrentPage = 1;

                        if (performanceSort.field === field) {
                            performanceSort.direction = performanceSort.direction === 'asc' ? 'desc' : 'asc';
                        } else {
                            performanceSort.field = field;
                            performanceSort.direction = 'desc';
                        }

                        applyPerformanceSort();
                    }
                });
            });
        }

        async function loadVerifierPerformance() {
            const loadingBox = document.getElementById('loadingBox');

            try {
                loadingBox.style.display = 'block';

                const region = document.getElementById('filterRegion').value;
                const month = document.getElementById('filterMonth').value;
                const day = document.getElementById('filterDay').value;
                const year = document.getElementById('filterYear').value;

                const params = new URLSearchParams();

                if (region) params.append('region', region);
                if (month) params.append('month', month);
                if (day !== '') params.append('day', day);
                if (year) params.append('year', year);

                const res = await fetch(`/Dashboard/VerifierPerformanceSummary?${params.toString()}`);

                if (!res.ok) {
                    throw new Error(`HTTP ${res.status}`);
                }

                const data = await res.json();

                renderDashboard(data);
            } catch (e) {
                console.error(e);

                renderDashboard({
                    monthly: {
                        totalAudit: Array(12).fill(0),
                        verifiedAudit: Array(12).fill(0),
                        appealAudit: Array(12).fill(0)
                    },
                    status: {
                        verified: 0,
                        review: 0,
                        appeal: 0,
                        total: 0
                    },
                    ranking: [],
                    performance: []
                });
            } finally {
                loadingBox.style.display = 'none';
            }
        }

        function renderDashboard(data) {
            const totalAudit = normalizeArray(data.monthly?.totalAudit);
            const verifiedAudit = normalizeArray(data.monthly?.verifiedAudit);
            const appealAudit = normalizeArray(data.monthly?.appealAudit);

            const verified = Number(data.status?.verified || 0);
            const review = Number(data.status?.review || 0);
            const appeal = Number(data.status?.appeal || 0);
            const total = Number(data.status?.total || (verified + review + appeal));

            document.getElementById('totalReportText').innerText = total;
            document.getElementById('verifiedVal').innerText = verified;
            document.getElementById('reviewVal').innerText = review;
            document.getElementById('appealVal').innerText = appeal;

            rankingData = (data.ranking || []).map(x => ({
                ...x,
                speedSeconds: x.speedSeconds ?? parseSpeedToSeconds(x.speed)
            }));

            performanceData = data.performance || [];

            rankingCurrentPage = 1;
            performanceCurrentPage = 1;

            renderBar(totalAudit, verifiedAudit, appealAudit);
            renderDonut(verified, review, appeal, total);

            applyRankingSort();
            applyPerformanceSort();
        }

        function renderBar(totalAudit, verifiedAudit, appealAudit) {
            if (verifierBarChart) verifierBarChart.destroy();

            verifierBarChart = new ApexCharts(document.querySelector("#verifierBarChart"), {
                chart: {
                    type: 'bar',
                    height: 270,
                    toolbar: { show: false },
                    fontFamily: 'Inter, sans-serif'
                },
                series: [
                    { name: 'Total Audit', data: totalAudit },
                    { name: 'Audit Diverifikasi', data: verifiedAudit },
                    { name: 'Banding', data: appealAudit }
                ],
                colors: ['#a8c51d', '#26b6d5', '#f32645'],
                plotOptions: {
                    bar: {
                        columnWidth: '46%',
                        borderRadius: 2
                    }
                },
                dataLabels: { enabled: false },
                grid: {
                    borderColor: '#cfd4dc',
                    strokeDashArray: 3,
                    xaxis: { lines: { show: false } }
                },
                xaxis: {
                    categories: ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Aug', 'Sep', 'Okt', 'Nov', 'Des'],
                    labels: { style: { colors: '#6b7280' } },
                    axisBorder: { show: false },
                    axisTicks: { show: false }
                },
                yaxis: {
                    labels: { style: { colors: '#9ca3af' } }
                },
                legend: {
                    position: 'top',
                    horizontalAlign: 'right'
                },
                tooltip: { theme: 'light' }
            });

            verifierBarChart.render();
        }

        function renderDonut(verified, review, appeal, total) {
            if (verifierDonutChart) verifierDonutChart.destroy();

            verifierDonutChart = new ApexCharts(document.querySelector("#verifierDonutChart"), {
                chart: {
                    type: 'donut',
                    height: 250,
                    toolbar: { show: false },
                    fontFamily: 'Inter, sans-serif'
                },
                series: [verified, review, appeal],
                labels: ['Audit Terverifikasi', 'Dalam Review', 'Banding'],
                colors: ['#a8c51d', '#26b6d5', '#f32645'],
                dataLabels: {
                    enabled: true,
                    formatter: function (val) {
                        return Math.round(val) + '%';
                    },
                    style: {
                        fontSize: '16px',
                        fontWeight: 800
                    }
                },
                plotOptions: {
                    pie: {
                        donut: {
                            size: '62%',
                            labels: {
                                show: true,
                                name: { show: false },
                                value: {
                                    show: true,
                                    fontSize: '18px',
                                    fontWeight: 800,
                                    color: '#5b616b',
                                    formatter: function () {
                                        return total;
                                    }
                                },
                                total: {
                                    show: true,
                                    showAlways: true,
                                    label: '',
                                    formatter: function () {
                                        return total;
                                    }
                                }
                            }
                        }
                    }
                },
                legend: { show: false },
                stroke: { width: 0 }
            });

            verifierDonutChart.render();
        }

        function renderRanking(items) {
            const tbody = document.getElementById('rankingBody');

            if (!items || items.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            Data peringkat verifikator belum tersedia
                        </td>
                    </tr>`;
                return;
            }

            tbody.innerHTML = items.map(x => `
                <tr>
                    <td>${x.rank ?? '-'}</td>
                    <td>${x.verifier ?? '-'}</td>
                    <td>${x.speed ?? '-'}</td>
                    <td>${x.verifiedAudit ?? 0} Audit</td>
                    <td>${x.missedAudit ?? 0} Audit</td>
                    <td>${x.cancelledAudit ?? 0} Audit</td>
                    <td>${formatDateTime(x.lastVerifiedDate)}</td>
                </tr>
            `).join('');
        }

        function renderPerformance(items, allItems) {
            const tbody = document.getElementById('performanceBody');

            if (!items || items.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            Data performa verifikator belum tersedia
                        </td>
                    </tr>`;
                return;
            }

            let totalAudited = 0;
            let totalUnder = 0;
            let totalDone = 0;
            let totalPerday = 0;
            let totalSpbu = 0;
            let totalRemaining = 0;

            const sourceTotal = allItems || items;

            sourceTotal.forEach(x => {
                totalAudited += Number(x.totalAudited || 0);
                totalUnder += Number(x.underVerified || 0);
                totalDone += Number(x.doneVerified || 0);
                totalPerday += Number(x.perday || 0);
                totalSpbu += Number(x.totalSpbu || 0);
                totalRemaining += Number(x.remainingSpbu || 0);
            });

            const rows = items.map(x => `
                <tr>
                    <td>${x.verifier ?? '-'}</td>
                    <td>${x.totalAudited ?? 0}</td>
                    <td>${x.underVerified ?? 0}</td>
                    <td>${x.doneVerified ?? 0}</td>
                    <td>${x.verifiedPercent ?? 0}%</td>
                    <td>${x.perday ?? 0}</td>
                    <td>${x.totalSpbu ?? 0}</td>
                    <td>${x.remainingSpbu ?? 0}</td>
                </tr>
            `).join('');

            const percent = totalAudited === 0
                ? 0
                : Math.round((totalDone / totalAudited) * 100);

            tbody.innerHTML = rows + `
                <tr class="total-row">
                    <td>Grand Total</td>
                    <td>${totalAudited}</td>
                    <td>${totalUnder}</td>
                    <td>${totalDone}</td>
                    <td>${percent}%</td>
                    <td>${totalPerday}</td>
                    <td>${totalSpbu}</td>
                    <td>${totalRemaining}</td>
                </tr>
            `;
        }

        document.addEventListener("DOMContentLoaded", function () {
            bindSortEvents();
            loadVerifierPerformance();

            document.getElementById('filterRegion').addEventListener('change', loadVerifierPerformance);
            document.getElementById('filterMonth').addEventListener('change', loadVerifierPerformance);
            document.getElementById('filterYear').addEventListener('change', loadVerifierPerformance);
            document.getElementById('filterDay').addEventListener('change', loadVerifierPerformance);
        });
    </script>
}