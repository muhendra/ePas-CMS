@using e_Pas_CMS.ViewModels
@model RoleManagementIndexViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    int totalPages = Model.TotalPages;
    int currentPage = Model.CurrentPage <= 0 ? 1 : Model.CurrentPage;
    int pageSize = Model.PageSize <= 0 ? 10 : Model.PageSize;
    int windowSize = 10;

    int currentWindow = (int)Math.Ceiling((double)currentPage / windowSize);
    int startPage = (currentWindow - 1) * windowSize + 1;
    int endPage = Math.Min(startPage + windowSize - 1, totalPages);

    int rowNumber = ((currentPage - 1) * pageSize) + 1;
}

<style>
    body {
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f4f6f9;
        color: #1f2937;
    }

    .role-page {
        padding: 28px 32px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 22px;
    }

    .page-title {
        margin: 0;
        font-size: 1.35rem;
        font-weight: 800;
        color: #111827;
        letter-spacing: -0.02em;
    }

    .page-subtitle {
        margin-top: 5px;
        color: #6b7280;
        font-size: 0.88rem;
    }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
        margin-bottom: 18px;
    }

    .summary-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 16px;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.05);
    }

    .summary-label {
        color: #64748b;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .summary-value {
        margin-top: 8px;
        font-size: 1.35rem;
        font-weight: 800;
        color: #111827;
    }

    .card-panel {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
        overflow: hidden;
    }

    .filter-panel {
        padding: 18px;
        margin-bottom: 20px;
    }

    .form-control {
        border-radius: 12px;
        border: 1px solid #dbe1ea;
        padding: 10px 14px;
        font-size: 0.9rem;
        color: #111827;
        background: #ffffff;
    }

        .form-control::placeholder {
            color: #9ca3af;
        }

        .form-control:focus {
            border-color: #1e3a8a;
            box-shadow: 0 0 0 4px rgba(30, 58, 138, 0.08);
        }

    .btn {
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.86rem;
        padding: 9px 14px;
    }

    .btn-dark-blue {
        background: #111827;
        border-color: #111827;
        color: #ffffff;
    }

        .btn-dark-blue:hover {
            background: #1e3a8a;
            border-color: #1e3a8a;
            color: #ffffff;
        }

    .btn-soft {
        background: #f9fafb;
        border: 1px solid #dbe1ea;
        color: #374151;
    }

        .btn-soft:hover {
            background: #eef2f7;
            border-color: #cbd5e1;
            color: #111827;
        }

    .table-card {
        padding: 0;
    }

    .table {
        margin-bottom: 0;
        font-size: 0.9rem;
    }

        .table thead th {
            background: #f8fafc;
            color: #64748b;
            font-size: 0.73rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            border-bottom: 1px solid #e5e7eb;
            padding: 15px 16px;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 16px;
            border-bottom: 1px solid #edf0f4;
            color: #374151;
            vertical-align: middle;
        }

        .table tbody tr:last-child td {
            border-bottom: none;
        }

        .table tbody tr:hover td {
            background: #fafafa;
        }

    .td-number {
        color: #94a3b8;
        font-weight: 700;
        width: 70px;
    }

    .role-name {
        font-weight: 800;
        color: #111827;
    }

    .role-meta {
        color: #6b7280;
        font-size: 0.82rem;
        margin-top: 2px;
    }

    .app-pill {
        display: inline-flex;
        align-items: center;
        padding: 6px 11px;
        border-radius: 999px;
        background: #f1f5f9;
        color: #334155;
        font-weight: 700;
        font-size: 0.8rem;
        white-space: nowrap;
    }

    .permission-wrapper {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        max-width: 560px;
    }

    .permission-badge {
        display: inline-flex;
        align-items: center;
        padding: 5px 9px;
        border-radius: 999px;
        background: #eff6ff;
        color: #1d4ed8;
        font-size: 0.75rem;
        font-weight: 700;
        line-height: 1.2;
    }

    .permission-more {
        background: #f3f4f6;
        color: #4b5563;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 800;
        white-space: nowrap;
    }

    .status-active {
        background: #ecfdf3;
        color: #027a48;
    }

    .status-inactive {
        background: #f3f4f6;
        color: #667085;
    }

    .status-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: currentColor;
    }

    .btn-action {
        background: #ffffff;
        border: 1px solid #dbe1ea;
        color: #344054;
        padding: 7px 11px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.82rem;
        white-space: nowrap;
    }

        .btn-action:hover {
            background: #111827;
            border-color: #111827;
            color: #ffffff;
        }

    .empty-state {
        padding: 44px 20px;
        text-align: center;
        color: #6b7280;
    }

    .empty-icon {
        width: 48px;
        height: 48px;
        margin: 0 auto 12px;
        border-radius: 14px;
        background: #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #9ca3af;
        font-size: 1.4rem;
    }

    .pagination-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 18px;
        gap: 12px;
        flex-wrap: wrap;
    }

    .pagination-info {
        color: #6b7280;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .pagination {
        margin-bottom: 0;
        gap: 6px;
    }

        .pagination .page-link {
            border-radius: 10px;
            border: 1px solid #dbe1ea;
            color: #475467;
            font-weight: 700;
            font-size: 0.84rem;
            min-width: 38px;
            text-align: center;
        }

            .pagination .page-link:hover {
                background: #f1f5f9;
                color: #111827;
            }

        .pagination .page-item.active .page-link {
            background: #111827;
            border-color: #111827;
            color: #ffffff;
        }

    .alert {
        border-radius: 14px;
        border: 1px solid #bbf7d0;
        background: #f0fdf4;
        color: #166534;
        font-weight: 700;
    }

    @@media (max-width: 992px) {
        .summary-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .role-page {
            padding: 20px 16px;
        }

        .page-header {
            align-items: flex-start;
            flex-direction: column;
        }

        .filter-panel {
            padding: 14px;
        }

        .table thead {
            white-space: nowrap;
        }
    }
</style>

<div class="role-page">
    <div class="page-header">
        <div>
            <h3 class="page-title">Role Management</h3>
            <div class="page-subtitle">
                Kelola akses fitur CMS berdasarkan role: view, edit, assign, approve, dashboard, dan lainnya.
            </div>
        </div>
    </div>

    <div class="summary-grid">
        <div class="summary-card">
            <div class="summary-label">Total Role</div>
            <div class="summary-value">@Model.TotalRecords</div>
        </div>

        <div class="summary-card">
            <div class="summary-label">Current Page</div>
            <div class="summary-value">@currentPage</div>
        </div>

        <div class="summary-card">
            <div class="summary-label">Total Page</div>
            <div class="summary-value">@totalPages</div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-dismissible fade show mb-3" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card-panel filter-panel">
        <form method="get" class="row g-2 align-items-center mb-0">
            <div class="col-md-5">
                <input type="text"
                       name="searchTerm"
                       value="@Model.SearchTerm"
                       class="form-control"
                       placeholder="Cari nama role, app, status, atau permission..." />
            </div>

            <div class="col-auto">
                <button type="submit" class="btn btn-dark-blue">
                    <i class="bi bi-search me-1"></i> Cari
                </button>
            </div>

            <div class="col-auto">
                <a href="@Url.Action("Index", "RoleManagement")" class="btn btn-soft">
                    Reset
                </a>
            </div>
        </form>
    </div>

    <div class="card-panel table-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr class="align-middle">
                        <th class="text-center">No</th>
                        <th>Nama Role</th>
                        <th class="text-center">App</th>
                        <th>Permission</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            var visiblePermissions = item.MenuFunctionLabels.Take(8).ToList();
                            var remainingPermission = item.MenuFunctionLabels.Count - visiblePermissions.Count;

                            <tr>
                                <td class="text-center td-number">@rowNumber</td>

                                <td>
                                    <div class="role-name">@item.NamaRole</div>
                                    <div class="role-meta">@item.TotalPermission permission assigned</div>
                                </td>

                                <td class="text-center">
                                    <span class="app-pill">@item.App</span>
                                </td>

                                <td>
                                    @if (visiblePermissions.Any())
                                    {
                                        <div class="permission-wrapper">
                                            @foreach (var permission in visiblePermissions)
                                            {
                                                <span class="permission-badge">@permission</span>
                                            }

                                            @if (remainingPermission > 0)
                                            {
                                                <span class="permission-badge permission-more">
                                                    +@remainingPermission lainnya
                                                </span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Belum ada permission</span>
                                    }
                                </td>

                                <td class="text-center">
                                    <span class="status-badge @(item.IsActive ? "status-active" : "status-inactive")">
                                        <span class="status-dot"></span>
                                        @item.Status
                                    </span>
                                </td>

                                <td class="text-center">
                                    <a href="@Url.Action("Edit", "RoleManagement", new { id = item.Id })"
                                       class="btn btn-action">
                                        <i class="bi bi-pencil-square me-1"></i> Edit
                                    </a>
                                </td>
                            </tr>

                            rowNumber++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6">
                                <div class="empty-state">
                                    <div class="empty-icon">
                                        <i class="bi bi-folder-x"></i>
                                    </div>
                                    <div class="fw-bold text-dark mb-1">Data tidak ditemukan</div>
                                    <div>Silakan ubah kata kunci pencarian atau reset filter.</div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="pagination-wrapper">
            <div class="pagination-info">
                Page @currentPage of @totalPages
            </div>

            <nav>
                <ul class="pagination">
                    @if (startPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               href="@Url.Action("Index", new { pageNumber = startPage - 1, pageSize = pageSize, searchTerm = Model.SearchTerm })">
                                Prev
                            </a>
                        </li>
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link"
                               href="@Url.Action("Index", new { pageNumber = i, pageSize = pageSize, searchTerm = Model.SearchTerm })">
                                @i
                            </a>
                        </li>
                    }

                    @if (endPage < totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               href="@Url.Action("Index", new { pageNumber = endPage + 1, pageSize = pageSize, searchTerm = Model.SearchTerm })">
                                Next
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>

@section Scripts {
    <script>
        setTimeout(function () {
            var alert = document.querySelector('.alert');
            if (alert) {
                var bsAlert = bootstrap.Alert.getOrCreateInstance(alert);
                bsAlert.close();
            }
        }, 5000);
    </script>
}