@inject e_Pas_CMS.Data.EpasDbContext _context
@using System.Security.Claims
@using System
@using e_Pas_CMS.Helpers

@{
    var userIdString = Context.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

    var currentUser = _context.app_users.FirstOrDefault(u => u.id == userIdString);

    var username = currentUser?.username ?? "-";
    var fullname = currentUser?.name ?? "-";

    var userRoles = _context.app_user_roles
        .AsEnumerable()
        .Where(aur => aur.app_user_id.ToString() == userIdString)
        .ToList();

    var roleNames = userRoles
        .Join(_context.app_roles,
            aur => aur.app_role_id,
            ar => ar.id,
            (aur, ar) => ar.name)
        .Distinct()
        .ToList();

    string roleDisplay = roleNames.Any() ? string.Join(", ", roleNames) : "-";

    bool Can(params string[] permissions) => User.HasPermission(permissions);

    int bandingAssignedCount = 0;

    if (Can("FEEDBACK_BANDING_VIEW", "FBAN"))
    {
        bandingAssignedCount = _context.TrxFeedbacks
            .Count(tf =>
                tf.FeedbackType == "BANDING"
                && tf.Status == "UNDER_REVIEW"
            );
    }
}

@functions {
    public bool IsActive(string controller, string action = null)
    {
        var c = (string)ViewContext.RouteData.Values["controller"];
        var a = (string)ViewContext.RouteData.Values["action"];

        if (!string.IsNullOrEmpty(action))
        {
            return string.Equals(c, controller, StringComparison.OrdinalIgnoreCase)
                && string.Equals(a, action, StringComparison.OrdinalIgnoreCase);
        }

        return string.Equals(c, controller, StringComparison.OrdinalIgnoreCase);
    }
}

