                                    </li>
                                }

                                @if (Can("SCHEDULER_VIEW", "SSCH"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link @(IsActive("Scheduler", "Index_NotStarted") ? "active" : "")"
                                           asp-controller="Scheduler"
                                           asp-action="Index_NotStarted">
                                            <span class="dot"></span> Log Changed Status
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </li>
                }

                @* Access *@
                @if (Can("ROLE_VIEW", "USER_VIEW", "AROLE", "AUSER"))
                {
                    <li class="nav-item menu-group">
                        <a class="nav-link menu-trigger" data-target="#menu-access" role="button" aria-expanded="false" aria-controls="menu-access">
                            <span class="d-flex align-items-center gap-2">
                                <i class="bi bi-person-gear"></i>
                                <strong>Access</strong>
                            </span>
                            <i class="bi bi-caret-down-fill chev"></i>
                        </a>

                        <div class="collapse submenu-panel" id="menu-access">
                            <ul class="nav flex-column mt-1">
                                @if (Can("USER_VIEW", "AUSER"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link @(IsActive("Role", "Index") ? "active" : "")"
                                           asp-controller="Role"
                                           asp-action="Index">
                                            <span class="dot"></span> App User
                                        </a>
                                    </li>
                                }

                                @if (Can("ROLE_VIEW", "AROLE"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link @(IsActive("RoleManagement", "Index") ? "active" : "")"
                                           asp-controller="RoleManagement"
                                           asp-action="Index">
                                            <span class="dot"></span> App Role
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </li>
                }

            </ul>
        </div>
    </div>

    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <button class="toggle-sidebar" onclick="toggleSidebar()" id="sidebarToggleBtn">
        <i class="bi bi-list" id="toggleIcon"></i>
    </button>

    <div class="content-wrapper d-flex flex-column flex-grow-1">
        <header>
            <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container-fluid">
                    <div class="d-flex align-items-center gap-2">
                        <span style="font-size: 0.85rem; color: #6c757d;">Powered by</span>
                        <img src="~/Report/header_intertek.png"
                             alt="Powered by Citrabuana"
                             style="height: 48px;">
                    </div>

                    <div class="d-flex align-items-center ms-auto">
                        <div class="text-end me-3 text-user">
                            <div class="fw-semibold">@fullname</div>
                            <div class="d-flex justify-content-end align-items-center gap-1">
                                <span class="text-username">@username</span>
                                <span class="badge-role">@roleDisplay</span>
                            </div>
                        </div>

                        <div class="dropdown">
                            <button class="btn btn-light rounded-circle p-2 border-0 shadow-sm"
                                    type="button"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                    style="width:42px;height:42px;">
                                <i class="bi bi-person-fill"></i>
                            </button>

                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" style="border-radius:12px;">
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Profile"
                                       asp-action="Index">
                                        <i class="bi bi-person me-2"></i> Profile
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Profile"
                                       asp-action="ChangePassword">
                                        <i class="bi bi-key me-2"></i> Ganti Password
                                    </a>
                                </li>

                                <li><hr class="dropdown-divider"></li>

                                <li>
                                    <a class="dropdown-item text-danger"
                                       asp-controller="Auth"
                                       asp-action="Logout">
                                        <i class="bi bi-box-arrow-right me-2"></i> Logout
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>
        </header>

        <main class="flex-grow-1 pb-3">
            @RenderBody()
        </main>

        <footer class="footer text-muted mt-auto">
            <div class="container text-center">
                &copy; 2026 - E-PAS PERTAMINA
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('sidebarOverlay');
            const toggleIcon = document.getElementById('toggleIcon');

            sidebar.classList.toggle('active');
            overlay.classList.toggle('active');

            if (sidebar.classList.contains('active')) {
                toggleIcon.classList.replace('bi-list', 'bi-x');
            } else {
                toggleIcon.classList.replace('bi-x', 'bi-list');
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.submenu-panel').forEach(panel => {
                panel.addEventListener('show.bs.collapse', () => {
                    panel.closest('.menu-group')?.classList.add('open');

                    const trigger = panel.closest('.menu-group')?.querySelector('.menu-trigger');
                    if (trigger) {
                        trigger.setAttribute('aria-expanded', 'true');
                    }
                });

                panel.addEventListener('hide.bs.collapse', () => {
                    panel.closest('.menu-group')?.classList.remove('open');

                    const trigger = panel.closest('.menu-group')?.querySelector('.menu-trigger');
                    if (trigger) {
                        trigger.setAttribute('aria-expanded', 'false');
                    }
                });
            });

            document.querySelectorAll('.submenu-panel').forEach(panel => {
                if (panel.querySelector('.nav-link.active')) {
                    const inst = bootstrap.Collapse.getOrCreateInstance(panel, { toggle: false });
                    inst.show();
                }
            });

            document.querySelectorAll('.menu-trigger').forEach(trigger => {
                trigger.addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    const selector = trigger.getAttribute('data-target');
                    if (!selector) return;

                    const panel = document.querySelector(selector);
                    if (!panel) return;

                    const inst = bootstrap.Collapse.getOrCreateInstance(panel, { toggle: false });

                            if (panel.classList.contains('show')) {
            inst.hide();
        } else {
            document.querySelectorAll('.submenu-panel.show').forEach(openPanel => {
                if (openPanel !== panel) {
                    const openInst = bootstrap.Collapse.getOrCreateInstance(openPanel, { toggle: false });
                    openInst.hide();
                }
            });

            inst.show();
        }
                });
            });

            const dropdownTrigger = document.querySelector('[data-bs-toggle="dropdown"]');

            if (dropdownTrigger) {
                const dropdown = bootstrap.Dropdown.getOrCreateInstance(dropdownTrigger);

                dropdownTrigger.addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    dropdown.toggle();
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
