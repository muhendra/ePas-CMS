@model e_Pas_CMS.ViewModels.PaginationModel<e_Pas_CMS.ViewModels.CityBoundaryListVm>

@{
    ViewData["Title"] = "Approval Batas Kota";
    var selectedStatus = ViewBag.Status as string ?? "";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        .approval-page {
            background: #f4f5f8;
            min-height: calc(100vh - 120px);
            padding: 28px 22px;
        }

        .page-title {
            font-size: 28px;
            font-weight: 800;
            color: #111827;
            margin-bottom: 28px;
        }

        .filter-card {
            display: flex;
            gap: 12px;
            margin-bottom: 28px;
            flex-wrap: wrap;
        }

        .search-input {
            width: 420px;
            max-width: 100%;
            height: 48px;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            padding: 0 16px;
            background: #fff;
        }

        .filter-select {
            width: 190px;
            height: 48px;
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            padding: 0 16px;
            background: #fff;
            font-weight: 500;
        }

        .btn-cyan {
            background: #21B6D7;
            border: 0;
            color: #fff;
            border-radius: 10px;
            padding: 0 22px;
            height: 48px;
            font-weight: 700;
        }

        .table-card {
            background: #fff;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #e5e7eb;
        }

        .table {
            margin: 0;
            color: #111827;
        }

            .table thead th {
                background: #eaeaea;
                border: none;
                padding: 18px 24px;
                font-weight: 800;
                color: #111827;
                white-space: nowrap;
            }

            .table tbody td {
                border: none;
                padding: 18px 24px;
                vertical-align: middle;
                white-space: nowrap;
            }

            .table tbody tr {
                border-bottom: 1px solid #f1f5f9;
            }

        .badge-status {
            display: inline-flex;
            align-items: center;
            border-radius: 999px;
            padding: 6px 12px;
            font-weight: 800;
            font-size: 12px;
        }

        .badge-pending {
            background: #fff7ed;
            color: #c2410c;
        }

        .badge-approved {
            background: #dcfce7;
            color: #166534;
        }

        .badge-rejected {
            background: #fee2e2;
            color: #991b1b;
        }

        .btn-action {
            border: 0;
            border-radius: 9px;
            padding: 8px 12px;
            font-weight: 800;
            color: #fff;
            font-size: 13px;
        }

        .btn-approve {
            background: #16a34a;
        }

        .btn-reject {
            background: #dc2626;
        }

        .btn-action:disabled {
            opacity: .45;
            cursor: not-allowed;
        }

        .pagination .page-link {
            border: 0;
            color: #111827;
            background: transparent;
            border-radius: 8px;
            margin: 0 2px;
        }

        .pagination .active .page-link {
            background: #21B6D7;
            color: #fff;
        }
    </style>
}

<div class="approval-page">

    <h3 class="page-title">Approval Batas Kota</h3>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-3">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger rounded-3">@TempData["Error"]</div>
    }

    <form method="get" class="filter-card">
        <input type="text"
               name="searchTerm"
               value="@ViewBag.SearchTerm"
               class="search-input"
               placeholder="Cari nama auditor / username / status" />

        <select name="status" class="filter-select">
            <option value="" selected="@(selectedStatus == "")">Semua Status</option>
            <option value="WAITING_APPROVAL" selected="@(selectedStatus == "WAITING_APPROVAL")">Pending</option>
            <option value="APPROVED" selected="@(selectedStatus == "APPROVED")">Setuju</option>
            <option value="REJECTED" selected="@(selectedStatus == "REJECTED")">Ditolak</option>
        </select>

        <select name="pageSize" class="filter-select">
            @{
                var sizes = new[] { 10, 25, 50 };
                foreach (var s in sizes)
                {
                    <option value="@s" selected="@(Model.PageSize == s)">@s per halaman</option>
                }
            }
        </select>

        <button class="btn-cyan" type="submit">
            Cari
        </button>
    </form>

    <div class="table-card">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th class="text-center">Action</th>
                        <th>Auditor</th>
                        <th>Username</th>
                        <th>Tanggal Audit<br />Terakhir</th>
                        <th>Homebase 1</th>
                        <th>Homebase 2</th>
                        <th>Homebase 3</th>
                        <th>Homebase 4</th>
                        <th>Status Approval</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            var statusText = item.Status == "APPROVED"
                            ? "Setuju"
                            : item.Status == "REJECTED"
                            ? "Ditolak"
                            : "Pending";

                            var statusClass = item.Status == "APPROVED"
                            ? "badge-approved"
                            : item.Status == "REJECTED"
                            ? "badge-rejected"
                            : "badge-pending";

                            var isPending = item.Status == "WAITING_APPROVAL";

                            <tr>
                                <td class="text-center">
                                    <div class="d-flex gap-2 justify-content-center">
                                        <button type="button"
                                                class="btn-action btn-approve"
                                                data-bs-toggle="modal"
                                                data-bs-target="#approveModal"
                                                data-id="@item.Id"
                                                data-auditor="@item.AuditorName"
                                                disabled="@(!isPending)">
                                            Setuju
                                        </button>

                                        <button type="button"
                                                class="btn-action btn-reject"
                                                data-bs-toggle="modal"
                                                data-bs-target="#rejectModal"
                                                data-id="@item.Id"
                                                data-auditor="@item.AuditorName"
                                                disabled="@(!isPending)">
                                            Tolak
                                        </button>
                                    </div>
                                </td>

                                <td>@item.AuditorName</td>
                                <td>@item.AuditorUsername</td>
                                <td>@(item.LastAuditDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                <td>@(item.BoundaryCity1 ?? "-")</td>
                                <td>@(item.BoundaryCity2 ?? "-")</td>
                                <td>@(item.BoundaryCity3 ?? "-")</td>
                                <td>@(item.BoundaryCity4 ?? "-")</td>
                                <td>
                                    <span class="badge-status @statusClass">@statusText</span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5 text-muted">
                                Data approval batas kota tidak ditemukan
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @await Html.PartialAsync("_CityBoundaryPagination", Model)
</div>

<div class="modal fade" id="approveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form method="post" asp-controller="CityBoundary" asp-action="Approve" class="modal-content">
            @Html.AntiForgeryToken()

            <div class="modal-header">
                <h5 class="modal-title fw-bold">Setujui Batas Kota</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" name="Id" id="approveId" />

                <p class="mb-3">
                    Apakah Anda yakin ingin menyetujui batas kota auditor
                    <strong id="approveAuditorName">-</strong>?
                </p>

                <label class="form-label fw-bold">Catatan Approval</label>
                <textarea name="ApprovalNotes"
                          class="form-control"
                          rows="4"
                          placeholder="Catatan approval, opsional"></textarea>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Batal</button>
                <button type="submit" class="btn btn-success fw-bold">Setuju</button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form method="post" asp-controller="CityBoundary" asp-action="Reject" class="modal-content">
            @Html.AntiForgeryToken()

            <div class="modal-header">
                <h5 class="modal-title fw-bold">Tolak Batas Kota</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" name="Id" id="rejectId" />

                <p class="mb-3">
                    Apakah Anda yakin ingin menolak batas kota auditor
                    <strong id="rejectAuditorName">-</strong>?
                </p>

                <label class="form-label fw-bold">Alasan Penolakan</label>
                <textarea name="ApprovalNotes"
                          class="form-control"
                          rows="4"
                          placeholder="Wajib isi alasan agar auditor dapat submit ulang"
                          required></textarea>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Batal</button>
                <button type="submit" class="btn btn-danger fw-bold">Tolak</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const approveModal = document.getElementById('approveModal');
            const rejectModal = document.getElementById('rejectModal');

            approveModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;

                document.getElementById('approveId').value = button.getAttribute('data-id');
                document.getElementById('approveAuditorName').innerText = button.getAttribute('data-auditor') || '-';
            });

            rejectModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;

                document.getElementById('rejectId').value = button.getAttribute('data-id');
                document.getElementById('rejectAuditorName').innerText = button.getAttribute('data-auditor') || '-';
            });
        });
    </script>
}