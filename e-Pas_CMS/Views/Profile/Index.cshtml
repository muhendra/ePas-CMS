@using e_Pas_CMS.ViewModels
@model ProfileViewModel

@{
    ViewData["Title"] = "Profile";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        .account-page {
            min-height: calc(100vh - 150px);
            background: #f7f8fb;
            padding: 36px 16px;
        }

        .account-shell {
            max-width: 980px;
            margin: 0 auto;
        }

        .account-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 22px;
            box-shadow: 0 18px 45px rgba(15,23,42,.08);
            overflow: hidden;
        }

        .account-header {
            background: linear-gradient(135deg, #111827, #1f2937);
            color: #fff;
            padding: 30px;
            display: flex;
            align-items: center;
            gap: 18px;
        }

        .account-avatar {
            width: 74px;
            height: 74px;
            border-radius: 22px;
            background: rgba(255, 200, 10, .16);
            border: 1px solid rgba(255, 200, 10, .35);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #FFC80A;
            font-size: 34px;
            flex: 0 0 auto;
        }

        .account-title {
            font-size: 24px;
            font-weight: 800;
            margin: 0;
            letter-spacing: -.3px;
        }

        .account-subtitle {
            color: #cbd5e1;
            margin-top: 4px;
            font-size: 14px;
        }

        .account-body {
            padding: 30px;
        }

        .section-title {
            font-weight: 800;
            color: #111827;
            margin-bottom: 6px;
        }

        .section-desc {
            color: #64748b;
            font-size: 13px;
            margin-bottom: 24px;
        }

        .form-label {
            font-weight: 700;
            color: #334155;
            font-size: 13px;
            margin-bottom: 7px;
        }

        .input-wrap {
            position: relative;
        }

            .input-wrap i {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
                font-size: 16px;
            }

        .form-control {
            border-radius: 14px;
            border: 1px solid #dbe2ea;
            padding: 12px 14px 12px 42px;
            background: #fff;
            color: #0f172a;
            transition: .2s ease;
        }

            .form-control:focus {
                border-color: #FFC80A;
                box-shadow: 0 0 0 4px rgba(255,200,10,.16);
            }

            .form-control[readonly] {
                background: #f8fafc;
                color: #64748b;
                cursor: not-allowed;
            }

        .form-hint {
            font-size: 12px;
            color: #94a3b8;
            margin-top: 5px;
        }

        .btn-classy {
            background: #111827;
            color: #fff;
            border: 1px solid #111827;
            border-radius: 14px;
            padding: 13px 18px;
            font-weight: 800;
            transition: .2s ease;
        }

            .btn-classy:hover {
                background: #000;
                color: #FFC80A;
                transform: translateY(-1px);
                box-shadow: 0 12px 28px rgba(15,23,42,.18);
            }

        .info-panel {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 18px;
            padding: 18px;
            height: 100%;
        }

        .info-panel-title {
            font-weight: 800;
            color: #111827;
            margin-bottom: 10px;
        }

        .info-item {
            display: flex;
            gap: 10px;
            color: #64748b;
            font-size: 13px;
            margin-bottom: 12px;
        }

            .info-item i {
                color: #b45309;
            }

        @@media (max-width: 768px) {
            .account-header {
                align-items: flex-start;
                flex-direction: column;
            }

            .account-body {
                padding: 22px;
            }
        }
    </style>
}

<div class="account-page">
    <div class="account-shell">
        <div class="account-card">

            <div class="account-header">
                <div class="account-avatar">
                    <i class="bi bi-person-badge"></i>
                </div>
                <div>
                    <h3 class="account-title">@Model.Name</h3>
                    <div class="account-subtitle">@Model.Email</div>
                </div>
            </div>

            <div class="account-body">
                <div class="row g-4">
                    <div class="col-lg-8">
                        <h5 class="section-title">Informasi Profile</h5>
                        <div class="section-desc">Kelola informasi dasar akun yang digunakan di sistem E-PAS.</div>

                        <form method="post">
                            @Html.AntiForgeryToken()

                            <input type="hidden" asp-for="Id" />

                            <div class="mb-3">
                                <label class="form-label">Username</label>
                                <div class="input-wrap">
                                    <i class="bi bi-person"></i>
                                    <input asp-for="Username" class="form-control" readonly />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Nama</label>
                                <div class="input-wrap">
                                    <i class="bi bi-card-text"></i>
                                    <input asp-for="Name" class="form-control" placeholder="Masukkan nama lengkap" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <div class="input-wrap">
                                    <i class="bi bi-envelope"></i>
                                    <input asp-for="Email" class="form-control" placeholder="Masukkan email" />
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label">No HP</label>
                                <div class="input-wrap">
                                    <i class="bi bi-telephone"></i>
                                    <input asp-for="PhoneNumber" class="form-control" placeholder="Masukkan nomor HP" />
                                </div>
                                <div class="form-hint">Gunakan nomor aktif untuk kebutuhan komunikasi.</div>
                            </div>

                            <button class="btn btn-classy w-100" type="submit">
                                <i class="bi bi-save me-1"></i>
                                Update Profile
                            </button>
                        </form>
                    </div>

                    <div class="col-lg-4">
                        <div class="info-panel">
                            <div class="info-panel-title">Account Security</div>

                            <div class="info-item">
                                <i class="bi bi-shield-check"></i>
                                <span>Pastikan email dan nomor HP selalu aktif.</span>
                            </div>

                            <div class="info-item">
                                <i class="bi bi-lock"></i>
                                <span>Gunakan password yang kuat dan rutin diperbarui.</span>
                            </div>

                            <div class="info-item mb-0">
                                <i class="bi bi-info-circle"></i>
                                <span>Username bersifat permanen dan tidak dapat diubah.</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>