@using e_Pas_CMS.ViewModels
@model ProfileViewModel

@{
    ViewData["Title"] = "Ganti Password";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        .security-page {
            min-height: calc(100vh - 150px);
            background: #f7f8fb;
            padding: 36px 16px;
        }

        .security-shell {
            max-width: 900px;
            margin: 0 auto;
        }

        .security-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 22px;
            box-shadow: 0 18px 45px rgba(15,23,42,.08);
            overflow: hidden;
        }

        .security-header {
            background: linear-gradient(135deg, #111827, #1f2937);
            color: #fff;
            padding: 30px;
            display: flex;
            align-items: center;
            gap: 18px;
        }

        .security-icon {
            width: 70px;
            height: 70px;
            border-radius: 22px;
            background: rgba(255,200,10,.16);
            border: 1px solid rgba(255,200,10,.35);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #FFC80A;
            font-size: 32px;
        }

        .security-title {
            font-size: 24px;
            font-weight: 800;
            margin: 0;
        }

        .security-subtitle {
            color: #cbd5e1;
            margin-top: 4px;
            font-size: 14px;
        }

        .security-body {
            padding: 30px;
        }

        .form-label {
            font-weight: 700;
            color: #334155;
            font-size: 13px;
            margin-bottom: 7px;
        }

        .password-wrap {
            position: relative;
        }

            .password-wrap .lock-icon {
                position: absolute;
                left: 14px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
            }

            .password-wrap .form-control {
                border-radius: 14px;
                border: 1px solid #dbe2ea;
                padding: 12px 44px 12px 42px;
                background: #fff;
                transition: .2s ease;
            }

                .password-wrap .form-control:focus {
                    border-color: #FFC80A;
                    box-shadow: 0 0 0 4px rgba(255,200,10,.16);
                }

        .toggle-password {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            border: 0;
            background: transparent;
            color: #64748b;
            padding: 0;
            z-index: 3;
        }

        .helper-box {
            background: #fffbeb;
            border: 1px solid #fde68a;
            border-radius: 16px;
            padding: 14px;
            color: #92400e;
            font-size: 13px;
            display: flex;
            gap: 10px;
        }

        .btn-classy {
            background: #111827;
            color: #fff;
            border: 1px solid #111827;
            border-radius: 14px;
            padding: 13px 18px;
            font-weight: 800;
            transition: .2s ease;
        }

            .btn-classy:hover {
                background: #000;
                color: #FFC80A;
                transform: translateY(-1px);
                box-shadow: 0 12px 28px rgba(15,23,42,.18);
            }
    </style>
}

<div class="security-page">
    <div class="security-shell">
        <div class="security-card">

            <div class="security-header">
                <div class="security-icon">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <div>
                    <h3 class="security-title">Ganti Password</h3>
                    <div class="security-subtitle">Perbarui password akun dengan aman dan terkontrol.</div>
                </div>
            </div>

            <div class="security-body">
                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Password Lama</label>
                        <div class="password-wrap">
                            <i class="bi bi-lock lock-icon"></i>
                            <input type="password" name="CurrentPassword" class="form-control password-input" placeholder="Masukkan password lama" />
                            <button type="button" class="toggle-password">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password Baru</label>
                        <div class="password-wrap">
                            <i class="bi bi-key lock-icon"></i>
                            <input type="password" name="NewPassword" class="form-control password-input" placeholder="Masukkan password baru" />
                            <button type="button" class="toggle-password">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Konfirmasi Password</label>
                        <div class="password-wrap">
                            <i class="bi bi-check2-square lock-icon"></i>
                            <input type="password" name="ConfirmPassword" class="form-control password-input" placeholder="Ulangi password baru" />
                            <button type="button" class="toggle-password">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="helper-box mb-4">
                        <i class="bi bi-info-circle"></i>
                        <div>
                            Gunakan kombinasi huruf besar, huruf kecil, angka, dan simbol. Jangan gunakan password yang sama dengan akun lain.
                        </div>
                    </div>

                    <button class="btn btn-classy w-100" type="submit">
                        <i class="bi bi-check-circle me-1"></i>
                        Update Password
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.toggle-password').forEach(btn => {
            btn.addEventListener('click', function () {
                const input = this.closest('.password-wrap').querySelector('.password-input');
                const icon = this.querySelector('i');

                const show = input.type === 'password';
                input.type = show ? 'text' : 'password';

                icon.classList.toggle('bi-eye', !show);
                icon.classList.toggle('bi-eye-slash', show);
            });
        });
    </script>
}