        }

        @@media (max-width: 768px) {
            .children {
                margin-left: 12px;
                padding-left: 12px;
            }

            .question-box {
                grid-template-columns: 1fr;
            }

            .search-box {
                width: 100%;
            }
        }
    </style>
}

@section Scripts {
    <script>
        const nodeModal = new bootstrap.Modal(document.getElementById('nodeModal'));

        function getToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]').value;
        }

        function emptyToNull(v) {
            return v === undefined || v === null || String(v).trim() === '' ? null : v;
        }

        function getNextChildType(parentType) {
            if (!parentType) return 'ELEMENT';

            parentType = parentType.toUpperCase();

            if (parentType === 'ELEMENT') return 'SUB_ELEMENT';
            if (parentType === 'SUB_ELEMENT') return 'QUESTION';
            if (parentType === 'GROUP') return 'QUESTION';

            return 'QUESTION';
        }

        function openNodeModal(id, parentId, parentTitle, parentType) {
            clearForm();

            const nextType = getNextChildType(parentType);

            document.getElementById('nodeModalTitle').innerText = id ? 'Edit Node' : 'Tambah Node';
            document.getElementById('nodeId').value = id || '';
            document.getElementById('parentId').value = parentId || '';
            document.getElementById('nodeType').value = nextType;

            if (parentId) {
                document.getElementById('parentInfo').innerText = `${parentType || '-'} > ${parentTitle || '-'}`;
            } else {
                document.getElementById('parentInfo').innerText = 'Root / Element utama';
                document.getElementById('nodeType').value = 'ELEMENT';
            }

            toggleQuestionFields();
            nodeModal.show();
        }

        function clearForm() {
            document.getElementById('nodeId').value = '';
            document.getElementById('parentId').value = '';
            document.getElementById('nodeType').value = 'ELEMENT';
            document.getElementById('number').value = '';
            document.getElementById('orderNo').value = '0';
            document.getElementById('status').value = 'ACTIVE';
            document.getElementById('title').value = '';
            document.getElementById('description').value = '';
            document.getElementById('scoreOption').value = '';
            document.getElementById('weight').value = '';
            document.getElementById('formType').value = '';
            document.getElementById('isPenalty').checked = false;
            document.getElementById('isRelaksasi').checked = false;
            document.getElementById('penaltyAlert').value = '';
            document.getElementById('penaltyExcellentCriteria').value = '';
            document.getElementById('scoreExcellentCriteria').value = '';
            document.getElementById('parentInfo').innerText = 'Root / Element utama';
        }

        function editNode(btn) {
            const node = btn.closest('.tree-node');

            openNodeModal(node.dataset.nodeId, node.dataset.parentId);

            document.getElementById('nodeModalTitle').innerText = 'Edit Node';
            document.getElementById('nodeId').value = node.dataset.nodeId || '';
            document.getElementById('parentId').value = node.dataset.parentId || '';
            document.getElementById('nodeType').value = node.dataset.type || 'QUESTION';
            document.getElementById('number').value = node.dataset.number || '';
            document.getElementById('orderNo').value = node.dataset.orderNo || 0;
            document.getElementById('status').value = node.dataset.status || 'ACTIVE';
            document.getElementById('title').value = node.dataset.title || '';
            document.getElementById('description').value = node.dataset.description || '';
            document.getElementById('scoreOption').value = node.dataset.scoreOption || '';
            document.getElementById('weight').value = node.dataset.weight || '';
            document.getElementById('formType').value = node.dataset.formType || '';
            document.getElementById('isPenalty').checked = node.dataset.isPenalty === 'true';
            document.getElementById('isRelaksasi').checked = node.dataset.isRelaksasi === 'true';
            document.getElementById('penaltyAlert').value = node.dataset.penaltyAlert || '';
            document.getElementById('penaltyExcellentCriteria').value = node.dataset.penaltyExcellentCriteria || '';
            document.getElementById('scoreExcellentCriteria').value = node.dataset.scoreExcellentCriteria || '';

            const parentId = node.dataset.parentId || '';
            if (parentId) {
                const parentNode = document.querySelector(`.tree-node[data-node-id="${parentId}"]`);
                if (parentNode) {
                    document.getElementById('parentInfo').innerText =
                        `${parentNode.dataset.type || '-'} > ${parentNode.dataset.title || '-'}`;
                }
            } else {
                document.getElementById('parentInfo').innerText = 'Root / Element utama';
            }

            toggleQuestionFields();
        }

        function toggleQuestionFields() {
            const type = document.getElementById('nodeType').value;
            const isQuestion = type === 'QUESTION';

            document.querySelectorAll('.question-field').forEach(el => {
                el.style.display = isQuestion ? '' : 'none';
            });
        }

        document.getElementById('nodeType').addEventListener('change', toggleQuestionFields);

        function saveNode() {
            const title = document.getElementById('title').value.trim();

            if (!title) {
                alert('Title wajib diisi.');
                return;
            }

            const payload = {
                Id: emptyToNull(document.getElementById('nodeId').value),
                MasterQuestionerId: document.getElementById('masterQuestionerId').value,
                ParentId: emptyToNull(document.getElementById('parentId').value),
                Type: document.getElementById('nodeType').value,
                Number: emptyToNull(document.getElementById('number').value),
                Title: title,
                Description: emptyToNull(document.getElementById('description').value),
                ScoreOption: emptyToNull(document.getElementById('scoreOption').value),
                Weight: emptyToNull(document.getElementById('weight').value),
                OrderNo: parseInt(document.getElementById('orderNo').value || '0'),
                Status: document.getElementById('status').value,
                IsPenalty: document.getElementById('isPenalty').checked,
                PenaltyAlert: emptyToNull(document.getElementById('penaltyAlert').value),
                IsRelaksasi: document.getElementById('isRelaksasi').checked,
                PenaltyExcellentCriteria: emptyToNull(document.getElementById('penaltyExcellentCriteria').value),
                ScoreExcellentCriteria: emptyToNull(document.getElementById('scoreExcellentCriteria').value),
                FormType: emptyToNull(document.getElementById('formType').value)
            };

            fetch('/MasterChecklist/SaveNode', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getToken()
                },
                body: JSON.stringify(payload)
            })
            .then(async res => {
                if (!res.ok) throw await res.text();
                return res.json();
            })
            .then(res => {
                showToast(res.message || 'Data berhasil disimpan.', 'success');
                setTimeout(() => location.reload(), 700);
            })
            .catch(err => {
                console.error(err);
                showToast(err || 'Gagal menyimpan data.', 'danger');
            });
        }

        function deleteNode(id) {
            if (!confirm('Yakin hapus node ini? Node yang punya child tidak bisa dihapus.')) return;

            fetch('/MasterChecklist/DeleteNode', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getToken()
                },
                body: JSON.stringify({ Id: id })
            })
            .then(async res => {
                if (!res.ok) throw await res.text();
                return res.json();
            })
            .then(res => {
                showToast(res.message || 'Node berhasil dihapus.', 'success');
                setTimeout(() => location.reload(), 700);
            })
            .catch(err => {
                console.error(err);
                showToast(err || 'Gagal hapus node.', 'danger');
            });
        }

        function toggleChildren(btn) {
            const node = btn.closest('.tree-node');
            const children = node.querySelector(':scope > .children');
            const icon = btn.querySelector('i');

            if (!children) return;

            children.classList.toggle('collapsed');

            if (children.classList.contains('collapsed')) {
                icon.classList.remove('bi-chevron-down');
                icon.classList.add('bi-chevron-right');
            } else {
                icon.classList.remove('bi-chevron-right');
                icon.classList.add('bi-chevron-down');
            }
        }

        function expandAll() {
            document.querySelectorAll('.children').forEach(x => x.classList.remove('collapsed'));
            document.querySelectorAll('.btn-toggle i').forEach(icon => {
                if (icon.classList.contains('bi-chevron-right')) {
                    icon.classList.remove('bi-chevron-right');
                    icon.classList.add('bi-chevron-down');
                }
            });
        }

        function collapseAll() {
            document.querySelectorAll('.children').forEach(x => x.classList.add('collapsed'));
            document.querySelectorAll('.btn-toggle i').forEach(icon => {
                if (icon.classList.contains('bi-chevron-down')) {
                    icon.classList.remove('bi-chevron-down');
                    icon.classList.add('bi-chevron-right');
                }
            });
        }

        document.getElementById('searchNode').addEventListener('input', function () {
            const keyword = this.value.toLowerCase().trim();

            if (!keyword) {
                document.querySelectorAll('.tree-node').forEach(node => {
                    node.classList.remove('hidden-by-search');
                });
                return;
            }

            expandAll();

            document.querySelectorAll('.tree-node').forEach(node => {
                const title = (node.dataset.title || '').toLowerCase();
                const number = (node.dataset.number || '').toLowerCase();
                const type = (node.dataset.type || '').toLowerCase();
                const desc = (node.dataset.description || '').toLowerCase();

                const selfMatch =
                    title.includes(keyword) ||
                    number.includes(keyword) ||
                    type.includes(keyword) ||
                    desc.includes(keyword);

                const childMatch = Array.from(node.querySelectorAll(':scope .tree-node')).some(child => {
                    const cTitle = (child.dataset.title || '').toLowerCase();
                    const cNumber = (child.dataset.number || '').toLowerCase();
                    const cType = (child.dataset.type || '').toLowerCase();
                    const cDesc = (child.dataset.description || '').toLowerCase();

                    return cTitle.includes(keyword)
                        || cNumber.includes(keyword)
                        || cType.includes(keyword)
                        || cDesc.includes(keyword);
                });

                node.classList.toggle('hidden-by-search', !(selfMatch || childMatch));
            });
        });

        function showToast(message, type) {
            const el = document.createElement('div');
            el.className = `alert alert-${type} alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3 shadow`;
            el.style.zIndex = '9999';
            el.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.body.appendChild(el);
            setTimeout(() => el.remove(), 2500);
        }

        toggleQuestionFields();
    </script>
}