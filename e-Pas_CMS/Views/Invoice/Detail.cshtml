@using e_Pas_CMS.ViewModels
@using System.Globalization
@model InvoiceDetailViewModel

@{
    var claimStatus = ViewBag.ClaimStatus as string ?? "";
    var claimStatusLabel = ViewBag.ClaimStatusLabel as string ?? "";

    var invoiceStatus = ViewBag.InvoiceStatus as string ?? "";
    var invoiceStatusLabel = ViewBag.InvoiceStatusLabel as string ?? "";

    var isWait = claimStatus == "UNDER_REVIEW";
    var isPendingApproval = claimStatus == "PENDING_APPROVAL";
    var isDone = claimStatus == "APPROVED";
    var isRejected = claimStatus == "REJECTED";

    var isEditableView = isWait || isPendingApproval;

    var statusText = claimStatus switch
    {
        "UNDER_REVIEW" => "UNDER_REVIEW",
        "PENDING_APPROVAL" => "PENDING_APPROVAL",
        "APPROVED" => "APPROVED",
        "REJECTED" => "REJECTED",
        _ => string.IsNullOrWhiteSpace(claimStatus) ? "-" : claimStatus
    };

    var statusClass = claimStatus switch
    {
        "APPROVED" => "done",
        "REJECTED" => "rejected",
        _ => "warning"
    };

    var amountDue = Model.TotalExpense - Model.LessDirectCharges - Model.LessAdvances;

    string DistanceDisplay(decimal? value)
    {
        if (!value.HasValue)
            return "-";

        return $"{value.Value:N0} KM";
    }

    string MoneyInputValue(decimal value)
    {
        return value.ToString("0.##", CultureInfo.InvariantCulture);
    }

    const string AssetBaseUrl = "https://epas-assets.zarata.co.id/";

    string BuildAssetUrl(string path)
    {
        if (string.IsNullOrWhiteSpace(path))
            return "";

        // Kalau sudah full URL, jangan ditambah prefix lagi
        if (path.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            path.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
            return path;

        // Contoh:
        // uploads/signature/xxx/file.png
        // /uploads/signature/xxx/file.png
        return AssetBaseUrl.TrimEnd('/') + "/" + path.TrimStart('/');
    }

    string GetMediaPath(string key)
    {
        if (Model.AttachmentGroups != null && Model.AttachmentGroups.ContainsKey(key))
        {
            var path = Model.AttachmentGroups[key]?.media_path ?? "";
            return BuildAssetUrl(path);
        }

        return "";
    }
    string GetFileName(string path)
    {
        if (string.IsNullOrWhiteSpace(path))
            return "Dokumen Pendukung 1.pdf";

        try
        {
            return System.IO.Path.GetFileName(path);
        }
        catch
        {
            return "Dokumen Pendukung 1.pdf";
        }
    }

    var bpjsKesehatan = GetMediaPath("BPJS_KESEHATAN");
    var bpjsKetenagakerjaan = GetMediaPath("BPJS_KETENAGAKERJAAN");
    var vehicle = GetMediaPath("VEHICLE_MAINTENANCE");
    var internet = GetMediaPath("INTERNET");
    var other = GetMediaPath("OTHER");
    var requestorSignatureUrl = BuildAssetUrl(Model.RequestorSignaturePath);

    var attachmentItems = new[]
    {
        new { Title = "BPJS Kesehatan", Path = bpjsKesehatan, Description = "" },
        new { Title = "BPJS Ketenagakerjaan", Path = bpjsKetenagakerjaan, Description = "" },
        new { Title = "Vehicle maintenance", Path = vehicle, Description = "" },
        new { Title = "Internet data", Path = internet, Description = "" },
        new { Title = "Others", Path = other, Description = "Biaya makan" }
    }
    .Where(x => !string.IsNullOrWhiteSpace(x.Path))
    .ToList();
}

