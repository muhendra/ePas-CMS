@using e_Pas_CMS.ViewModels
@model InvoiceDetailViewModel

@{
    var status = Model.Status ?? "";
    var claimStatus = ViewBag.ClaimStatus as string ?? "";
    var claimStatusLabel = ViewBag.ClaimStatusLabel as string ?? "";

    var isWait = claimStatus == "UNDER_REVIEW";
    var isPendingApproval = claimStatus == "PENDING_APPROVAL";
    var isDone = claimStatus == "APPROVED";
    var isRejected = claimStatus == "REJECTED";

    var isProcess = isWait || isPendingApproval;

    var statusText = isWait
        ? "UNDER_REVIEW"
        : isPendingApproval
            ? "PENDING_APPROVAL"
            : isDone
                ? "APPROVED"
                : isRejected
                    ? "REJECTED"
                    : claimStatus;

    var statusClass = isDone
        ? "done"
        : isRejected
            ? "rejected"
            : "warning";

    var amountDue = Model.TotalExpense;

    string GetMediaPath(string key)
    {
        if (Model.AttachmentGroups != null && Model.AttachmentGroups.ContainsKey(key))
            return Model.AttachmentGroups[key]?.media_path ?? "";

        return "";
    }

    string GetFileName(string path)
    {
        if (string.IsNullOrWhiteSpace(path))
            return "Dokumen Pendukung 1.pdf";

        try
        {
            return System.IO.Path.GetFileName(path);
        }
        catch
        {
            return "Dokumen Pendukung 1.pdf";
        }
    }

    var bpjsKesehatan = GetMediaPath("BPJS_KESEHATAN");
    var bpjsKetenagakerjaan = GetMediaPath("BPJS_KETENAGAKERJAAN");
    var vehicle = GetMediaPath("VEHICLE_MAINTENANCE");
    var internet = GetMediaPath("INTERNET");
    var other = GetMediaPath("OTHER");
}
@section Styles {
    <style>
        :root {
            --invoice-bg: #f4f5f7;
            --invoice-card: #ffffff;
            --invoice-text: #101820;
            --invoice-muted: #8f98a3;
            --invoice-soft-muted: #aab2bd;
            --invoice-line: #edf0f2;
            --invoice-head: #eeeeef;
            --invoice-cyan: #22b8d4;
            --invoice-yellow: #ffd43b;
            --invoice-yellow-text: #ffb800;
            --invoice-green: #13ad68;
            --invoice-input: #eef0f2;
        }

        .status-banner.rejected {
            background: #ef4444;
        }

        .approval-action-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-top: 16px;
            flex-wrap: wrap;
        }

        .btn-approve,
        .btn-reject {
            border: 0;
            border-radius: 999px;
            min-width: 120px;
            height: 42px;
            padding: 0 24px;
            font-size: 14px;
            font-weight: 800;
            cursor: pointer;
            color: #fff;
        }

        .btn-approve {
            background: var(--invoice-green);
        }

            .btn-approve:hover {
                background: #0f985b;
            }

        .btn-reject {
            background: #ef4444;
        }

            .btn-reject:hover {
                background: #dc2626;
            }

        .approval-rejected {
            color: #ef4444;
            font-size: 14px;
            margin-top: 8px;
            font-weight: 700;
        }

        html,
        body {
            width: 100%;
            min-height: 100%;
            overflow-x: hidden;
        }

        body {
            background: var(--invoice-bg);
            font-family: 'Inter', Arial, Helvetica, sans-serif;
            color: var(--invoice-text);
        }

        .invoice-detail-page {
            width: 100%;
            max-width: none !important;
            margin: 0;
            padding: 34px 24px 120px;
            box-sizing: border-box;
        }

            .invoice-detail-page * {
                box-sizing: border-box;
            }

        .invoice-top-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            margin-bottom: 10px;
            width: 100%;
            max-width: none;
        }

        .invoice-title {
            font-size: 28px;
            font-weight: 800;
            letter-spacing: -0.4px;
            margin: 0;
        }

        .invoice-breadcrumb {
            font-size: 12px;
            color: #a2abb4;
            margin: 24px 0 26px;
            font-weight: 500;
        }

            .invoice-breadcrumb span {
                color: var(--invoice-cyan);
                font-weight: 800;
            }

        .download-pdf-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            border: 0;
            background: var(--invoice-cyan);
            color: #fff;
            border-radius: 999px;
            padding: 12px 30px;
            text-decoration: none;
            font-weight: 800;
            font-size: 14px;
            min-width: 172px;
            justify-content: center;
        }

            .download-pdf-btn:hover {
                color: #fff;
                background: #18a8c3;
            }

        .status-banner {
            width: 100%;
            max-width: none;
            min-height: 58px;
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 26px;
            font-weight: 800;
            margin-bottom: 22px;
            box-shadow: 0 3px 10px rgba(0,0,0,.06);
        }

            .status-banner.warning {
                background: var(--invoice-yellow);
            }

            .status-banner.done {
                background: var(--invoice-green);
            }

        .invoice-card {
            width: 100%;
            max-width: none;
            background: var(--invoice-card);
            border-radius: 8px;
            padding: 24px 22px;
            margin-bottom: 20px;
            border: 1px solid #edf0f2;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(5, minmax(130px, 1fr));
            gap: 28px 42px;
            width: 100%;
        }

        .field-label {
            font-size: 14px;
            font-weight: 800;
            color: #111827;
            margin-bottom: 8px;
            display: block;
        }

        .field-value {
            color: #555d66;
            font-size: 15px;
            line-height: 1.4;
        }

        .form-control.invoice-input,
        .form-select.invoice-input {
            height: 43px;
            border: 1px solid #e4e8ec;
            border-radius: 7px;
            color: #555d66;
            font-size: 14px;
            box-shadow: none;
            background-color: #fff;
        }

            .form-control.invoice-input:read-only {
                background-color: #fff;
            }

        .section-title {
            font-size: 22px;
            font-weight: 800;
            margin: 0 0 28px;
            letter-spacing: -0.2px;
        }

        .invoice-table-wrap {
            width: 100%;
            overflow-x: auto;
            overflow-y: hidden;
            padding-bottom: 0;
            scrollbar-width: thin;
        }

            .invoice-table-wrap::-webkit-scrollbar {
                height: 10px;
            }

            .invoice-table-wrap::-webkit-scrollbar-track {
                background: #eeeeef;
                border-radius: 999px;
            }

            .invoice-table-wrap::-webkit-scrollbar-thumb {
                background: #b9b9ba;
                border-radius: 999px;
            }

        .detail-table {
            width: 100%;
            min-width: 1120px;
            border-collapse: separate;
            border-spacing: 0;
            margin: 0;
            table-layout: fixed;
        }

            .detail-table thead th {
                background: var(--invoice-head);
                border: 0;
                color: #111827;
                font-size: 15px;
                font-weight: 800;
                padding: 16px 14px;
                vertical-align: middle;
                text-align: center;
            }

            .detail-table tbody td {
                border-top: 1px dashed #e5e8ec;
                background: #fff;
                padding: 20px 14px;
                vertical-align: middle;
                font-size: 14px;
                color: #111827;
                word-break: break-word;
            }

            .detail-table tbody tr:first-child td {
                border-top: 0;
            }

            .detail-table .no-col {
                width: 5%;
                text-align: center;
            }

            .detail-table .date-col {
                width: 12%;
            }

            .detail-table .expense-col {
                width: 25%;
            }

            .detail-table th:nth-child(4),
            .detail-table td:nth-child(4) {
                width: 15%;
            }

            .detail-table th:nth-child(5),
            .detail-table td:nth-child(5),
            .detail-table th:nth-child(6),
            .detail-table td:nth-child(6),
            .detail-table th:nth-child(7),
            .detail-table td:nth-child(7) {
                width: 14.3%;
            }

            .detail-table .amount-col {
                text-align: right;
                white-space: nowrap;
                word-break: normal;
            }

            .detail-table .center-col {
                text-align: center;
            }

        .date-sub {
            color: #a2aab3;
            font-size: 12px;
            margin-top: 2px;
        }

        .cell-input {
            height: 43px;
            border: 1px solid #e4e8ec;
            border-radius: 7px;
            padding: 0 12px;
            width: 100%;
            font-size: 14px;
            color: #4b5563;
            background: #fff;
            outline: none;
        }

            .cell-input.amount {
                text-align: right;
            }

        .summary-row td {
            font-weight: 800;
            border-top: 1px dashed #e5e8ec !important;
            padding-top: 26px !important;
            padding-bottom: 26px !important;
        }

        .summary-label {
            font-weight: 500 !important;
            color: #1f2937;
            text-align: left;
        }

        .summary-box-row td {
            background: #f1f1f2 !important;
            border-top: 0 !important;
            padding-top: 14px !important;
            padding-bottom: 14px !important;
        }

        .invoice-scrollbar {
            display: none;
        }

        .attachment-grid {
            display: grid;
            grid-template-columns: repeat(5, minmax(140px, 1fr));
            gap: 26px 34px;
            margin-bottom: 28px;
        }

        .attachment-title {
            font-size: 14px;
            font-weight: 800;
            margin-bottom: 6px;
            color: #111827;
        }

        .attachment-link {
            display: inline-block;
            color: #08b5d3;
            text-decoration: none;
            font-size: 14px;
            font-weight: 800;
            margin-top: 4px;
            word-break: break-word;
        }

            .attachment-link:hover {
                color: #059ab4;
                text-decoration: underline;
            }

        .attachment-desc {
            font-size: 14px;
            color: #555d66;
            margin: 6px 0 0;
        }

        .upload-box {
            height: 43px;
            border: 1px solid #e4e8ec;
            border-radius: 7px;
            background: #fff;
            padding: 0 12px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            color: #777f88;
            font-size: 14px;
            width: 100%;
            max-width: 220px;
            margin-bottom: 6px;
        }

        .bank-grid,
        .bank-readonly-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(180px, 1fr));
            gap: 28px;
            width: 100%;
        }

        .approval-grid {
            display: grid;
            grid-template-columns: 260px 1fr;
            gap: 80px;
            align-items: start;
        }

        .signature-box {
            width: 92px;
            height: 92px;
            background: #f0fbfd;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 8px 0 10px;
            overflow: hidden;
        }

            .signature-box img {
                max-width: 90px;
                max-height: 90px;
                object-fit: contain;
            }

        .claimant-name {
            font-size: 14px;
            color: #111827;
            margin-bottom: 3px;
        }

        .claimant-role {
            font-size: 13px;
            color: #6b7280;
        }

        .approval-wait {
            color: var(--invoice-yellow-text);
            font-size: 14px;
            font-style: italic;
            margin-top: 8px;
        }

        .approval-done {
            color: var(--invoice-green);
            font-size: 14px;
            margin-top: 8px;
        }

        .approval-file {
            color: #08b5d3;
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 7px;
            margin-top: 8px;
        }

        .bottom-action-bar {
            position: fixed;
            left: 202px;
            right: 0;
            bottom: 0;
            min-height: 78px;
            background: #fff;
            box-shadow: 0 -4px 16px rgba(16,24,40,.08);
            z-index: 50;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            padding: 18px 44px;
        }

        .btn-process {
            border: 0;
            background: var(--invoice-cyan);
            color: #fff;
            border-radius: 999px;
            min-width: 110px;
            height: 42px;
            padding: 0 24px;
            font-size: 14px;
            font-weight: 800;
            cursor: pointer;
        }

            .btn-process:hover {
                background: #18a8c3;
            }

        .invoice-alert {
            border-radius: 10px;
            padding: 12px 16px;
            margin-bottom: 18px;
            font-weight: 600;
        }

            .invoice-alert.success {
                background: #ecfdf5;
                color: #047857;
                border: 1px solid #bbf7d0;
            }

            .invoice-alert.error {
                background: #fef2f2;
                color: #b91c1c;
                border: 1px solid #fecaca;
            }

        @@media (max-width: 1400px) {
            .invoice-detail-page {
                width: 100%;
                max-width: none !important;
                margin: 0;
                padding-left: 24px;
                padding-right: 24px;
            }

            .info-grid {
                grid-template-columns: repeat(4, minmax(150px, 1fr));
            }

            .attachment-grid {
                grid-template-columns: repeat(4, minmax(140px, 1fr));
            }

            .detail-table {
                min-width: 1120px;
            }
        }

        @@media (max-width: 1199px) {
            .invoice-detail-page {
                width: 100%;
                max-width: none !important;
                margin: 0;
                padding-left: 18px;
                padding-right: 18px;
            }

            .detail-table {
                min-width: 1120px;
                table-layout: fixed;
            }

            .invoice-table-wrap {
                overflow-x: auto;
            }

            .invoice-scrollbar {
                display: block;
                height: 14px;
                background: #eeeeef;
                border-radius: 999px;
                margin: 14px 0 26px;
                overflow: hidden;
            }

                .invoice-scrollbar span {
                    display: block;
                    width: 39%;
                    height: 100%;
                    background: #b9b9ba;
                    border-radius: 999px;
                }
        }

        @@media (max-width: 991px) {
            .invoice-detail-page {
                width: 100%;
                max-width: none !important;
                margin-left: 0;
                margin-right: 0;
                padding: 24px 18px 110px;
            }

            .invoice-top-row {
                align-items: flex-start;
                flex-direction: column;
            }

            .info-grid,
            .attachment-grid,
            .bank-grid,
            .bank-readonly-grid {
                grid-template-columns: 1fr;
                gap: 18px;
            }

            .approval-grid {
                grid-template-columns: 1fr;
                gap: 28px;
            }

            .bottom-action-bar {
                left: 0;
                padding: 16px 18px;
            }

            .download-pdf-btn {
                width: 100%;
            }

            .detail-table {
                min-width: 1120px;
                table-layout: fixed;
            }

            .invoice-table-wrap {
                overflow-x: auto;
            }

            .invoice-scrollbar {
                display: block;
                height: 14px;
                background: #eeeeef;
                border-radius: 999px;
                margin: 14px 0 26px;
                overflow: hidden;
            }

                .invoice-scrollbar span {
                    display: block;
                    width: 39%;
                    height: 100%;
                    background: #b9b9ba;
                    border-radius: 999px;
                }
        }
    </style>
}

<div class="invoice-detail-page">

    <div class="invoice-top-row">
        <h1 class="invoice-title">Detail Invoice</h1>

        @if (isDone)
        {
            <a asp-action="DownloadPdf"
               asp-route-id="@Model.Id"
               class="download-pdf-btn">
                <i class="bi bi-file-earmark-arrow-down-fill"></i>
                Download PDF
            </a>
        }
    </div>

    <div class="invoice-breadcrumb">
        Invoice Management / <span>Detail Invoice</span>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="invoice-alert success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="invoice-alert error">@TempData["Error"]</div>
    }

    <div class="status-banner @statusClass">
        @statusText
    </div>

    <div class="invoice-card">
        @if (isProcess)
        {
            <div class="info-grid">
                <div>
                    <label class="field-label">Invoice Number</label>
                    <input class="form-control invoice-input" value="@Model.InvoiceNo" readonly />
                </div>

                <div>
                    <label class="field-label">Name</label>
                    <input class="form-control invoice-input" value="@Model.EmployeeName" readonly />
                </div>

                <div>
                    <label class="field-label">Period</label>
                    <div class="position-relative">
                        <input class="form-control invoice-input" value="@Model.Period" readonly />
                        <i class="bi bi-calendar3 position-absolute"
                           style="right:14px;top:50%;transform:translateY(-50%);color:#6b7280;"></i>
                    </div>
                </div>

                <div>
                    <label class="field-label">Kind of Job</label>
                    <select class="form-select invoice-input" disabled>
                        <option selected>@Model.Job</option>
                    </select>
                </div>

                <div>
                    <label class="field-label">Homebase</label>
                    <input class="form-control invoice-input" value="@Model.Homebase" readonly />
                </div>
            </div>
        }
        else
        {
            <div class="info-grid">
                <div>
                    <label class="field-label">Invoice Number</label>
                    <div class="field-value">@Model.InvoiceNo</div>
                </div>

                <div>
                    <label class="field-label">Name</label>
                    <div class="field-value">@Model.EmployeeName</div>
                </div>

                <div>
                    <label class="field-label">Period</label>
                    <div class="field-value">@Model.Period</div>
                </div>

                <div>
                    <label class="field-label">Kind of Job</label>
                    <div class="field-value">@Model.Job</div>
                </div>

                <div>
                    <label class="field-label">Homebase</label>
                    <div class="field-value">@Model.Homebase</div>
                </div>
            </div>
        }
    </div>

    <div class="invoice-card">
        <h2 class="section-title">Rincian Item</h2>

        <div class="invoice-table-wrap">
            <table class="detail-table">
                <thead>
                    <tr>
                        <th class="no-col">No</th>
                        <th class="date-col">Date</th>
                        <th class="expense-col">Details of Expense</th>
                        <th>Contract or Cost<br />Centre</th>
                        <th>TOTAL<br />EXPENSE</th>
                        <th>Audit Fee</th>
                        <th>Lumpsum</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        for (int i = 0; i < Model.Items.Count; i++)
                        {
                            var item = Model.Items[i];

                            <tr>
                                <td class="no-col">@(i + 1)</td>

                                <td class="date-col">
                                    @if (isProcess)
                                    {
                                        <div class="position-relative">
                                            <input class="cell-input" value="@item.Date.ToString("dd/MM/yyyy")" readonly />
                                            <i class="bi bi-calendar3 position-absolute"
                                               style="right:10px;top:50%;transform:translateY(-50%);color:#6b7280;font-size:13px;"></i>
                                        </div>
                                    }
                                    else
                                    {
                                        <div>@item.Date.ToString("dd/MM/yyyy")</div>
                                        <div class="date-sub">@item.Date.ToString("HH:mm") WIB</div>
                                    }
                                </td>

                                <td class="expense-col">
                                    @if (isProcess)
                                    {
                                        <input class="cell-input" value="@item.Description" readonly />
                                    }
                                    else
                                    {
                                        @item.Description
                                    }
                                </td>

                                <td class="center-col">
                                    @if (isProcess)
                                    {
                                        <input class="cell-input" value="102" readonly />
                                    }
                                    else
                                    {
                                        <span>102</span>
                                    }
                                </td>

                                <td class="amount-col">
                                    @if (isProcess)
                                    {
                                        <input class="cell-input amount" value="Rp @item.Amount.ToString("N0")" readonly />
                                    }
                                    else
                                    {
                                        <span>Rp @item.Amount.ToString("N0")</span>
                                    }
                                </td>

                                <td class="amount-col">
                                    @if (isProcess)
                                    {
                                        <input class="cell-input amount" value="Rp @item.AuditFee.ToString("N0")" readonly />
                                    }
                                    else
                                    {
                                        <span>Rp @item.AuditFee.ToString("N0")</span>
                                    }
                                </td>

                                <td class="amount-col">
                                    @if (isProcess)
                                    {
                                        <input class="cell-input amount" value="Rp @item.Lumpsum.ToString("N0")" readonly />
                                    }
                                    else
                                    {
                                        <span>Rp @item.Lumpsum.ToString("N0")</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                Tidak ada rincian item
                            </td>
                        </tr>
                    }

                    <tr class="summary-row">
                        <td></td>
                        <td></td>
                        <td class="summary-label" colspan="2">TOTALS/CARRIED FORWARD</td>
                        <td class="amount-col">Rp @Model.TotalExpense.ToString("N0")</td>
                        <td class="amount-col">Rp @Model.TotalAuditFee.ToString("N0")</td>
                        <td class="amount-col">Rp @Model.TotalLumpsum.ToString("N0")</td>
                    </tr>

                    <tr class="summary-box-row">
                        <td></td>
                        <td></td>
                        <td class="summary-label" colspan="2">LESS DIRECT CHARGES</td>
                        <td class="amount-col">Rp @Model.LessDirectCharges.ToString("N0")</td>
                        <td></td>
                        <td></td>
                    </tr>

                    <tr class="summary-box-row">
                        <td></td>
                        <td></td>
                        <td class="summary-label" colspan="2">LESS ADVANCES</td>
                        <td class="amount-col">Rp @Model.LessAdvances.ToString("N0")</td>
                        <td></td>
                        <td></td>
                    </tr>

                    <tr class="summary-box-row">
                        <td></td>
                        <td></td>
                        <td class="summary-label" colspan="2">AMOUNT DUE TO/(FROM) EMPLOYEE</td>
                        <td class="amount-col">Rp @amountDue.ToString("N0")</td>
                        <td></td>
                        <td></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="invoice-scrollbar">
            <span></span>
        </div>

        <h2 class="section-title" style="margin-top:6px;margin-bottom:22px;">Lampiran-lampiran</h2>

        <div class="attachment-grid">
            <div>
                <div class="attachment-title">BPJS Kesehatan</div>

                @if (isProcess)
                {
                    <div class="upload-box">
                        <span>Pilih file</span>
                        <i class="bi bi-upload"></i>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(bpjsKesehatan))
                {
                    <a href="@bpjsKesehatan" target="_blank" class="attachment-link">
                        @GetFileName(bpjsKesehatan)
                    </a>
                }
                else
                {
                    <a href="#" class="attachment-link">Dokumen Pendukung 1.pdf</a>
                }
            </div>

            <div>
                <div class="attachment-title">BPJS Ketenagakerjaan</div>

                @if (isProcess)
                {
                    <div class="upload-box">
                        <span>Pilih file</span>
                        <i class="bi bi-upload"></i>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(bpjsKetenagakerjaan))
                {
                    <a href="@bpjsKetenagakerjaan" target="_blank" class="attachment-link">
                        @GetFileName(bpjsKetenagakerjaan)
                    </a>
                }
                else
                {
                    <a href="#" class="attachment-link">Dokumen Pendukung 1.pdf</a>
                }
            </div>

            <div>
                <div class="attachment-title">Vehicle maintenance</div>

                @if (isProcess)
                {
                    <div class="upload-box">
                        <span>Pilih file</span>
                        <i class="bi bi-upload"></i>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(vehicle))
                {
                    <a href="@vehicle" target="_blank" class="attachment-link">
                        @GetFileName(vehicle)
                    </a>
                }
                else
                {
                    <a href="#" class="attachment-link">Dokumen Pendukung 1.pdf</a>
                }
            </div>

            <div>
                <div class="attachment-title">Internet data</div>

                @if (isProcess)
                {
                    <div class="upload-box">
                        <span>Pilih file</span>
                        <i class="bi bi-upload"></i>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(internet))
                {
                    <a href="@internet" target="_blank" class="attachment-link">
                        @GetFileName(internet)
                    </a>
                }
                else
                {
                    <a href="#" class="attachment-link">Dokumen Pendukung 1.pdf</a>
                }
            </div>

            <div>
                <div class="attachment-title">Others</div>

                @if (isProcess)
                {
                    <div class="upload-box">
                        <span>Pilih file</span>
                        <i class="bi bi-upload"></i>
                    </div>

                    <input class="cell-input" value="Biaya makan" readonly style="max-width:180px;margin-bottom:6px;" />
                }
                else
                {
                    <p class="attachment-desc">Biaya makan</p>
                }

                @if (!string.IsNullOrWhiteSpace(other))
                {
                    <a href="@other" target="_blank" class="attachment-link">
                        @GetFileName(other)
                    </a>
                }
                else
                {
                    <a href="#" class="attachment-link">Dokumen Pendukung 1.pdf</a>
                }
            </div>
        </div>

        <h2 class="section-title" style="margin-bottom:22px;">Informasi Bank</h2>

        @if (isDone)
        {
            <div class="bank-readonly-grid">
                <div>
                    <label class="field-label">Nama Bank</label>
                    <div class="field-value">@Model.BankName</div>
                </div>

                <div>
                    <label class="field-label">Nomor Rekening</label>
                    <div class="field-value">@Model.BankAccount</div>
                </div>

                <div>
                    <label class="field-label">Nama Pemilik Rekening</label>
                    <div class="field-value">@Model.BankOwner</div>
                </div>
            </div>
        }
        else
        {
            <div class="bank-grid">
                <div>
                    <label class="field-label">Nama Bank</label>
                    <input class="form-control invoice-input"
                           value="@Model.BankName"
                           placeholder="Nama Bank"
                           readonly />
                </div>

                <div>
                    <label class="field-label">Nomor Rekening</label>
                    <input class="form-control invoice-input"
                           value="@Model.BankAccount"
                           placeholder="Nomor Rekening"
                           readonly />
                </div>

                <div>
                    <label class="field-label">Nama Pemilik Rekening</label>
                    <input class="form-control invoice-input"
                           value="@Model.BankOwner"
                           placeholder="Nama Pemilik Rekening"
                           readonly />
                </div>
            </div>
        }
    </div>

    <div class="invoice-card">
        <h2 class="section-title">Persetujuan</h2>

        <div class="approval-grid">
            <div>
                <label class="field-label">Required by</label>

                <div class="signature-box">
                    <img src="~/images/images_ttd.jpg"
                         onerror="this.onerror=null;this.src='/images/imagesttd.jpg';"
                         alt="Signature" />
                </div>

                <div class="claimant-name">@Model.EmployeeName</div>
                <div class="claimant-role">Claimant</div>
            </div>

            <div>
                <label class="field-label">Finance / Accounting</label>

                @if (isPendingApproval)
                {
                    <a href="#" class="approval-file">
                        <i class="bi bi-file-earmark-text-fill"></i>
                        ttd_digital.png
                    </a>

                    <div class="approval-wait">
                        @claimStatusLabel
                    </div>

                    <div class="approval-action-row">
                        <form method="post"
                              asp-action="Approve"
                              asp-route-id="@Model.Id">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-approve">
                                Setuju
                            </button>
                        </form>

                        <form method="post"
                              asp-action="Reject"
                              asp-route-id="@Model.Id"
                              onsubmit="return confirm('Yakin invoice ini tidak disetujui?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-reject">
                                Tidak Setuju
                            </button>
                        </form>
                    </div>
                }
                else if (isDone)
                {
                    <a href="#" class="approval-file">
                        <i class="bi bi-file-earmark-text-fill"></i>
                        ttd_digital.png
                    </a>

                    <div class="approval-done">
                        Setuju
                    </div>
                }
                else if (isRejected)
                {
                    <div class="approval-rejected">
                        Tidak Setuju
                    </div>
                }
                else
                {
                    <div class="approval-wait">
                        Menunggu Persetujuan
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (isWait)
{
    <form method="post"
          asp-action="StartProcess"
          asp-route-id="@Model.Id"
          class="bottom-action-bar">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn-process">Proses</button>
    </form>
}
else if (isPendingApproval)
{
    <div class="bottom-action-bar">
        <form method="post"
              asp-action="Reject"
              asp-route-id="@Model.Id"
              onsubmit="return confirm('Yakin invoice ini tidak disetujui?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-reject">Tidak Setuju</button>
        </form>

        <form method="post"
              asp-action="Approve"
              asp-route-id="@Model.Id"
              style="margin-left:12px;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-approve">Setuju</button>
        </form>
    </div>
}