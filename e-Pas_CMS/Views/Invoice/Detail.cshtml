@if (isPendingApproval)
{
    <form id="approvalForm" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
    </form>
}

<div class="invoice-detail-page">
    <div class="invoice-top-row">
        <h1 class="invoice-title">Detail Invoice</h1>

        @if (isDone)
        {
            // <a asp-action="DownloadPdf"
            //    asp-route-id="@Model.Id"
            //    class="download-pdf-btn">
            //     <i class="bi bi-file-earmark-arrow-down-fill"></i>
            //     Download PDF
            // </a>
        }
    </div>

    <div class="invoice-breadcrumb">
        Invoice Management / <span>Detail Invoice</span>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="invoice-alert success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="invoice-alert error">@TempData["Error"]</div>
    }

    <div class="status-banner @statusClass">
        @statusText
    </div>

    <div class="invoice-card">
        <div class="info-grid">
            <div>
                <label class="field-label">Invoice Number</label>
                @if (isEditableView)
                {
                    <input class="form-control invoice-input" value="@Model.InvoiceNo" readonly />
                }
                else
                {
                    <div class="field-value">@Model.InvoiceNo</div>
                }
            </div>

            <div>
                <label class="field-label">Name</label>
                @if (isEditableView)
                {
                    <input class="form-control invoice-input" value="@Model.EmployeeName" readonly />
                }
                else
                {
                    <div class="field-value">@Model.EmployeeName</div>
                }
            </div>

            <div>
                <label class="field-label">Period</label>
                @if (isEditableView)
                {
                    <div class="position-relative">
                        <input class="form-control invoice-input" value="@Model.Period" readonly />
                        <i class="bi bi-calendar3 position-absolute"
                           style="right:14px;top:50%;transform:translateY(-50%);color:#6b7280;"></i>
                    </div>
                }
                else
                {
                    <div class="field-value">@Model.Period</div>
                }
            </div>

            <div>
                <label class="field-label">Kind of Job</label>
                @if (isEditableView)
                {
                    <select class="form-select invoice-input" disabled>
                        <option selected>@Model.Job</option>
                    </select>
                }
                else
                {
                    <div class="field-value">@Model.Job</div>
                }
            </div>

            <div>
                <label class="field-label">Homebase</label>
                @if (isEditableView)
                {
                    <input class="form-control invoice-input" value="@Model.Homebase" readonly />
                }
                else
                {
                    <div class="field-value">@Model.Homebase</div>
                }
            </div>

            <div>
                <label class="field-label">Jumlah Jarak</label>
                @if (isEditableView)
                {
                    <input class="form-control invoice-input" value="@DistanceDisplay(Model.TotalKmRange)" readonly />
                }
                else
                {
                    <div class="field-value">@DistanceDisplay(Model.TotalKmRange)</div>
                }
            </div>
        </div>
    </div>

    <div class="invoice-card">
        <h2 class="section-title">Rincian Item</h2>

        <div class="invoice-table-wrap">
            <table class="detail-table">
                <thead>
                    <tr>
                        <th class="no-col">No</th>
                        <th class="date-col">Date</th>
                        <th class="expense-col">Details of Expense</th>
                        <th>Contract or Cost<br />Centre</th>
                        <th>TOTAL<br />EXPENSE</th>
                        <th>Audit Fee</th>
                        <th>Lumpsum</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        for (int i = 0; i < Model.Items.Count; i++)
                        {
                            var item = Model.Items[i];

                            <tr>
                                <td class="no-col">@(i + 1)</td>

                                <td class="date-col">
                                    @if (isEditableView)
                                    {
                                        <div class="position-relative">
                                            <input class="cell-input" value="@item.Date.ToString("dd/MM/yyyy")" readonly />
                                            <i class="bi bi-calendar3 position-absolute"
                                               style="right:10px;top:50%;transform:translateY(-50%);color:#6b7280;font-size:13px;"></i>
                                        </div>
                                    }
                                    else
                                    {
                                        <div>@item.Date.ToString("dd/MM/yyyy")</div>
                                        <div class="date-sub">@item.Date.ToString("HH:mm") WIB</div>
                                    }
                                </td>

                                <td class="expense-col">
                                    @if (isEditableView)
                                    {
                                        <input class="cell-input" value="@item.Description" readonly />
                                    }
                                    else
                                    {
                                        @item.Description
                                    }
                                </td>

                                <td class="center-col">
                                    @if (isEditableView)
                                    {
                                        <input class="cell-input" value="102" readonly />
                                    }
                                    else
                                    {
                                        <span>102</span>
                                    }
                                </td>

                                <td class="amount-col">
                                    <span class="line-total-text">
                                        Rp @item.Amount.ToString("N0")
                                    </span>
                                </td>

                                <td class="amount-col">
                                    @if (isPendingApproval)
                                    {
                                        <input type="hidden"
                                               form="approvalForm"
                                               name="Items[@i].TrxInvoiceDetailId"
                                               value="@item.TrxInvoiceDetailId" />

                                        <input type="number"
                                               form="approvalForm"
                                               name="Items[@i].AuditFee"
                                               value="@MoneyInputValue(item.AuditFee)"
                                               min="0"
                                               step="1000"
                                               class="cell-input amount editable js-money js-audit-fee"
                                               data-claim-amount="@MoneyInputValue(item.ClaimAmount)"
                                               data-row-index="@i" />
                                    }
                                    else
                                    {
                                        <span>Rp @item.AuditFee.ToString("N0")</span>
                                    }
                                </td>

                                <td class="amount-col">
                                    @if (isPendingApproval)
                                    {
                                        <input type="number"
                                               form="approvalForm"
                                               name="Items[@i].LumpsumFee"
                                               value="@MoneyInputValue(item.Lumpsum)"
                                               min="0"
                                               step="1000"
                                               class="cell-input amount editable js-money js-lumpsum-fee"
                                               data-row-index="@i" />
                                    }
                                    else
                                    {
                                        <span>Rp @item.Lumpsum.ToString("N0")</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                Tidak ada rincian item
                            </td>
                        </tr>
                    }

                    <tr class="summary-row">
                        <td></td>
                        <td></td>
                        <td class="summary-label" colspan="2">CLAIM EXPENSE</td>
                        <td class="amount-col" id="claimExpenseText" data-claim-expense="@MoneyInputValue(Model.ClaimExpenseAmount)">
                            Rp @Model.ClaimExpenseAmount.ToString("N0")
                        </td>
                        <td></td>
                        <td></td>
                    </tr>

                    <tr class="summary-row">
                        <td></td>
                        <td></td>
                        <td class="summary-label" colspan="2">TOTAL AUDIT FEE</td>
                        <td></td>
                        <td class="amount-col" id="totalAuditFeeText">Rp @Model.TotalAuditFee.ToString("N0")</td>
                        <td></td>
                    </tr>

                    <tr class="summary-row">
                        <td></td>
                        <td></td>
                        <td class="summary-label" colspan="2">TOTAL LUMPSUM</td>
                        <td></td>
                        <td></td>
                        <td class="amount-col" id="totalLumpsumText">Rp @Model.TotalLumpsum.ToString("N0")</td>
                    </tr>

                    <tr class="summary-row">
                        <td></td>
                        <td></td>
                        <td class="summary-label" colspan="2">TOTALS/CARRIED FORWARD</td>
                        <td class="amount-col" id="totalExpenseText" data-claim-expense="@MoneyInputValue(Model.ClaimExpenseAmount)">
                            Rp @Model.TotalExpense.ToString("N0")
                        </td>
                        <td class="amount-col" id="totalAuditFeeTextBottom">Rp @Model.TotalAuditFee.ToString("N0")</td>
                        <td class="amount-col" id="totalLumpsumTextBottom">Rp @Model.TotalLumpsum.ToString("N0")</td>
                    </tr>

                    <tr class="summary-box-row">
                        <td></td>
                        <td></td>
                        <td class="summary-label" colspan="2">LESS DIRECT CHARGES</td>
                        <td class="amount-col">Rp @Model.LessDirectCharges.ToString("N0")</td>
                        <td></td>
                        <td></td>
                    </tr>

                    <tr class="summary-box-row">
                        <td></td>
                        <td></td>
                        <td class="summary-label" colspan="2">LESS ADVANCES</td>
                        <td class="amount-col">Rp @Model.LessAdvances.ToString("N0")</td>
                        <td></td>
                        <td></td>
                    </tr>

                    <tr class="summary-box-row">
                        <td></td>
                        <td></td>
                        <td class="summary-label" colspan="2">AMOUNT DUE TO/(FROM) EMPLOYEE</td>
                        <td class="amount-col" id="amountDueText">Rp @amountDue.ToString("N0")</td>
                        <td></td>
                        <td></td>
                    </tr>
                </tbody>
            </table>
        </div>

        @if (attachmentItems.Any())
        {
            <h2 class="section-title" style="margin-top:28px;margin-bottom:22px;">Lampiran-lampiran</h2>

            <div class="attachment-grid">
                @foreach (var attachment in attachmentItems)
                {
                    <div>
                        <div class="attachment-title">@attachment.Title</div>

                        @if (!string.IsNullOrWhiteSpace(attachment.Description))
                        {
                            <p class="attachment-desc">@attachment.Description</p>
                        }

                        <a href="@attachment.Path" target="_blank" class="attachment-link">
                            @GetFileName(attachment.Path)
                        </a>
                    </div>
                }
            </div>
        }

        <h2 class="section-title" style="margin-bottom:22px;">Informasi Bank</h2>

        @if (isDone)
        {
            <div class="bank-readonly-grid">
                <div>
                    <label class="field-label">Nama Bank</label>
                    <div class="field-value">@Model.BankName</div>
                </div>

                <div>
                    <label class="field-label">Nomor Rekening</label>
                    <div class="field-value">@Model.BankAccount</div>
                </div>

                <div>
                    <label class="field-label">Nama Pemilik Rekening</label>
                    <div class="field-value">@Model.BankOwner</div>
                </div>
            </div>
        }
        else
        {
            <div class="bank-grid">
                <div>
                    <label class="field-label">Nama Bank</label>
                    <input class="form-control invoice-input" value="@Model.BankName" placeholder="Nama Bank" readonly />
                </div>

                <div>
                    <label class="field-label">Nomor Rekening</label>
                    <input class="form-control invoice-input" value="@Model.BankAccount" placeholder="Nomor Rekening" readonly />
                </div>

                <div>
                    <label class="field-label">Nama Pemilik Rekening</label>
                    <input class="form-control invoice-input" value="@Model.BankOwner" placeholder="Nama Pemilik Rekening" readonly />
                </div>
            </div>
        }
    </div>

    <div class="invoice-card">
        <h2 class="section-title">Persetujuan</h2>

        <div class="approval-grid">
            <div>
                <label class="field-label">Requestor</label>

                <div class="approval-signature-box">
                    @if (!string.IsNullOrWhiteSpace(requestorSignatureUrl))
                    {
                        <img src="@requestorSignatureUrl"
                             alt="Requestor Signature"
                             class="requestor-signature-img" />
                    }
                    else
                    {
                        <div class="requestor-stamp">
                            <div class="requestor-stamp-main">REQUESTOR</div>
                            <div class="requestor-stamp-sub">SUBMITTED</div>
                            <div class="requestor-stamp-date">
                                @Model.ClaimDate.ToString("dd/MM/yyyy")
                            </div>
                        </div>
                    }
                </div>

                <div class="claimant-name">@Model.EmployeeName</div>
                <div class="claimant-role">Requestor</div>
            </div>
            <div>
                <label class="field-label">Finance / Accounting</label>

                @if (isPendingApproval)
                {
                    <div class="approval-signature-box">
                        <div class="approval-signature-placeholder">
                            <i class="bi bi-pen" style="font-size:22px;"></i>
                            <div style="margin-top:8px;">Signature will be filled after approval</div>
                        </div>
                    </div>

                    <div class="approval-wait">@claimStatusLabel</div>

                    <div class="finance-decision-card">
                        <div class="decision-header">
                            <div>
                                <div class="decision-title">Keputusan Finance</div>
                                <div class="decision-subtitle">
                                    Finance dapat menyesuaikan Audit Fee dan Lumpsum sebelum menyetujui atau menolak invoice.
                                </div>
                            </div>

                            <div class="decision-total">
                                <span>Total Expense</span>
                                <strong id="decisionTotalExpense">Rp @Model.TotalExpense.ToString("N0")</strong>
                            </div>
                        </div>

                        <label class="field-label mt-3">Alasan Ditolak</label>
                        <textarea form="approvalForm"
                              name="RejectionReason"
                              required
                              class="finance-reject-textarea"
                              rows="4"
                              placeholder="Isi alasan jika invoice ditolak. Contoh: nominal tidak sesuai, dokumen kurang lengkap, atau perlu revisi audit fee.">@Model.RejectionReason</textarea>

                    </div>
                }
                else if (isDone)
                {
                    <div class="approval-signature-box">
                        <div class="signed-stamp">
                            <div class="signed-stamp-main">SIGNED</div>
                            <div class="signed-stamp-sub">DIGITALLY APPROVED</div>
                            @if (Model.ApprovedDate.HasValue)
                            {
                                <div class="signed-stamp-date">
                                    @Model.ApprovedDate.Value.ToString("dd/MM/yyyy")
                                </div>
                            }
                        </div>
                    </div>

                    <div class="approval-meta">
                        <div>
                            <strong>Approved By:</strong>
                            @(string.IsNullOrWhiteSpace(Model.ApprovedBy) ? "Finance / Accounting" : Model.ApprovedBy)
                        </div>

                        @if (Model.ApprovedDate.HasValue)
                        {
                            <div>
                                <strong>Approved Date:</strong>
                                @Model.ApprovedDate.Value.ToString("dd/MM/yyyy HH:mm") WIB
                            </div>
                        }
                    </div>

                    <div class="approval-done">
                        Setuju
                    </div>
                }
                else if (isRejected)
                {
                    <div class="approval-signature-box">
                        <div class="approval-signature-placeholder">
                            <i class="bi bi-x-circle" style="font-size:22px;color:#ef4444;"></i>
                            <div style="margin-top:8px;color:#ef4444;">Approval rejected</div>
                        </div>
                    </div>

                    <div class="approval-rejected">Tidak Setuju</div>

                    @if (!string.IsNullOrWhiteSpace(Model.RejectionReason))
                    {
                        <div class="finance-decision-card rejected-card">
                            <div class="decision-title text-danger">Alasan Ditolak</div>
                            <div class="decision-subtitle mt-2">@Model.RejectionReason</div>
                        </div>
                    }
                }
                else
                {
                    <div class="approval-signature-box">
                        <div class="approval-signature-placeholder">
                            <i class="bi bi-clock-history" style="font-size:22px;"></i>
                            <div style="margin-top:8px;">Menunggu proses finance</div>
                        </div>
                    </div>

                    <div class="approval-wait">Menunggu proses finance</div>
                }
            </div>
        </div>
    </div>
</div>

@if (isWait)
{
    <form method="post"
          asp-action="StartProcess"
          asp-route-id="@Model.Id"
          class="bottom-action-bar">
        @Html.AntiForgeryToken()
        <button type="submit"
                class="btn-process"
                onclick="return confirmStartProcess();">
            Proses
        </button>
    </form>
}
else if (isPendingApproval)
{
    <div class="bottom-action-bar">
        <button type="submit"
                form="approvalForm"
                formmethod="post"
                formaction="@Url.Action("Reject", "Invoice", new { id = Model.Id })"
                class="btn-reject"
                onclick="return validateRejectReason();">
            Tidak Setuju
        </button>

        <button type="submit"
                form="approvalForm"
                formmethod="post"
                formaction="@Url.Action("Approve", "Invoice", new { id = Model.Id })"
                class="btn-approve"
                onclick="return confirmApprove();">
            Setuju
        </button>
    </div>
}

@section Scripts {
    <script>
        function toNumber(value) {
            if (value === null || value === undefined) return 0;

            let raw = String(value).trim();

            if (raw.length === 0) return 0;

            raw = raw.replace(/\s/g, '');

            const hasComma = raw.includes(',');
            const hasDot = raw.includes('.');

            // Format Indonesia: 9.600.000,50
            if (hasComma && hasDot) {
                raw = raw.replace(/\./g, '').replace(',', '.');
            }
            // Format decimal comma: 9600000,50
            else if (hasComma && !hasDot) {
                raw = raw.replace(',', '.');
            }
            // Format display: Rp 9.600.000
            else if (!hasComma && hasDot) {
                const parts = raw.split('.');
                const lastPart = parts[parts.length - 1];

                if (parts.length > 1 && lastPart.length === 3) {
                    raw = raw.replace(/\./g, '');
                }
            }

            raw = raw.replace(/[^\d.-]/g, '');

            return Number(raw) || 0;
        }

        function rupiah(value) {
            return 'Rp ' + Number(value || 0).toLocaleString('id-ID');
        }

        function recalcFinanceTotal() {
            let totalAudit = 0;
            let totalLumpsum = 0;

            document.querySelectorAll('.js-audit-fee').forEach(function (input) {
                totalAudit += toNumber(input.value);
            });

            document.querySelectorAll('.js-lumpsum-fee').forEach(function (input) {
                totalLumpsum += toNumber(input.value);
            });

            const totalExpenseEl = document.getElementById('totalExpenseText');
            const claimExpense = totalExpenseEl ? toNumber(totalExpenseEl.dataset.claimExpense) : 0;
            const grandTotal = claimExpense + totalAudit + totalLumpsum;

            const totalAuditFeeText = document.getElementById('totalAuditFeeText');
            const totalAuditFeeTextBottom = document.getElementById('totalAuditFeeTextBottom');
            const totalLumpsumText = document.getElementById('totalLumpsumText');
            const totalLumpsumTextBottom = document.getElementById('totalLumpsumTextBottom');
            const amountDueText = document.getElementById('amountDueText');
            const decisionTotalExpense = document.getElementById('decisionTotalExpense');

            if (totalAuditFeeText) totalAuditFeeText.innerText = rupiah(totalAudit);
            if (totalAuditFeeTextBottom) totalAuditFeeTextBottom.innerText = rupiah(totalAudit);
            if (totalLumpsumText) totalLumpsumText.innerText = rupiah(totalLumpsum);
            if (totalLumpsumTextBottom) totalLumpsumTextBottom.innerText = rupiah(totalLumpsum);
            if (totalExpenseEl) totalExpenseEl.innerText = rupiah(grandTotal);
            if (amountDueText) amountDueText.innerText = rupiah(grandTotal);
            if (decisionTotalExpense) decisionTotalExpense.innerText = rupiah(grandTotal);

            recalcLineTotals();
        }

        function recalcLineTotals() {
            document.querySelectorAll('.js-audit-fee').forEach(function (auditInput) {
                const row = auditInput.closest('tr');
                if (!row) return;

                const lumpsumInput = row.querySelector('.js-lumpsum-fee');
                const lineTotalText = row.querySelector('.line-total-text');

                const auditFee = toNumber(auditInput.value);
                const lumpsumFee = lumpsumInput ? toNumber(lumpsumInput.value) : 0;
                const claimAmount = toNumber(auditInput.dataset.claimAmount);

                const lineTotal = claimAmount + auditFee + lumpsumFee;

                if (lineTotalText) {
                    lineTotalText.innerText = rupiah(lineTotal);
                }
            });
        }

        function validateRejectReason() {
            const textarea = document.querySelector('textarea[name="RejectionReason"]');

            if (!textarea) {
                return confirm('Yakin ingin menolak invoice ini?');
            }

            if (textarea.value.trim().length === 0) {
                alert('Alasan Ditolak wajib diisi.');
                textarea.focus();
                return false;
            }

            return confirm('Yakin ingin menolak invoice ini?');
        }

        function confirmApprove() {
            return confirm('Yakin ingin menyetujui invoice ini?');
        }

        function confirmStartProcess() {
            return confirm('Yakin ingin memproses invoice ini ke pending approval finance?');
        }

        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.js-money').forEach(function (input) {
                input.addEventListener('input', recalcFinanceTotal);
            });

            recalcFinanceTotal();
        });
    </script>
}