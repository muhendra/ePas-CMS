@using e_Pas_CMS.ViewModels
@using System.Globalization
@using System.Collections.Generic
@model InvoiceDetailViewModel

@{
    Layout = null;

    var claimExpenseAmounts = ViewBag.ClaimExpenseAmounts as Dictionary<string, decimal>
        ?? new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);

    decimal ExpenseAmount(string key)
    {
        return claimExpenseAmounts.TryGetValue(key, out var amount) ? amount : 0m;
    }

    var bpjsKesehatan = ExpenseAmount("BPJS_KESEHATAN");
    var bpjsKetenagakerjaan = ExpenseAmount("BPJS_KETENAGAKERJAAN");
    var vehicleMaintenance = ExpenseAmount("VEHICLE_MAINTENANCE");
    var internetData = ExpenseAmount("INTERNET");
    var others = ExpenseAmount("OTHER");

    var amountDue = Model.TotalExpense - Model.LessDirectCharges - Model.LessAdvances;
    var rowCount = Math.Max(Model.Items?.Count ?? 0, 20);
    var autoPrint = ViewBag.AutoPrint is bool ap && ap;

    string Money(decimal value)
    {
        return value == 0 ? "" : value.ToString("N0", new CultureInfo("id-ID"));
    }

    string DateText(DateTime value)
    {
        return value.ToString("dd/MM/yyyy");
    }
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Preview Invoice - @Model.InvoiceNo</title>
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: #f3f4f6;
            font-family: Arial, Helvetica, sans-serif;
            color: #000;
        }

        .preview-toolbar {
            max-width: 1320px;
            margin: 18px auto 0;
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            padding: 0 16px;
        }

        .toolbar-btn {
            border: 0;
            border-radius: 999px;
            padding: 10px 22px;
            background: #22b8d4;
            color: #fff;
            font-weight: 800;
            cursor: pointer;
            text-decoration: none;
            font-size: 13px;
        }

            .toolbar-btn.dark {
                background: #111827;
            }

        .invoice-sheet {
            width: 1320px;
            min-height: 780px;
            margin: 18px auto 36px;
            background: #fff;
            padding: 22px 26px 34px;
            box-shadow: 0 18px 44px rgba(15, 23, 42, .12);
        }

        .top-header {
            display: grid;
            grid-template-columns: 360px 1fr 250px;
            align-items: start;
            gap: 22px;
            margin-bottom: 22px;
        }

        .company-title {
            font-size: 22px;
            font-weight: 900;
            line-height: 1;
        }

        .company-subtitle {
            font-size: 10px;
            margin-top: 4px;
        }

            .company-subtitle strong {
                font-size: 17px;
                letter-spacing: -1px;
            }

        .invoice-heading {
            text-align: center;
            font-size: 28px;
            font-weight: 900;
            letter-spacing: .3px;
            padding-top: 18px;
        }

        .invoice-no-box {
            margin-top: 18px;
            background: #fff200;
            padding: 12px 16px;
            display: grid;
            grid-template-columns: 95px 1fr;
            gap: 10px;
            font-size: 10px;
            font-weight: 900;
        }

        .info-block {
            width: 440px;
            margin-bottom: 18px;
        }

        .info-row {
            display: grid;
            grid-template-columns: 110px 1fr;
            align-items: center;
            margin-bottom: 2px;
            font-size: 10px;
            font-weight: 700;
        }

        .info-line {
            border-bottom: 2px solid #000;
            min-height: 16px;
            padding-left: 8px;
            font-weight: 500;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        .invoice-table th,
        .invoice-table td {
            border: 2px solid #000;
            font-size: 8px;
            padding: 4px 5px;
            line-height: 1.1;
            vertical-align: middle;
        }

        .invoice-table th {
            text-align: center;
            font-weight: 900;
        }

        .invoice-table td {
            height: 18px;
        }

        .invoice-table .center {
            text-align: center;
        }

        .invoice-table .right {
            text-align: right;
        }

        .invoice-table .bold {
            font-weight: 900;
        }

        .invoice-table .currency {
            width: 18px;
            text-align: center;
        }

        .invoice-table .summary-label {
            font-weight: 900;
            text-align: left;
        }

        .invoice-table .yellow {
            background: #fff200;
        }

        .statement-row {
            display: grid;
            grid-template-columns: 56% 44%;
            gap: 20px;
            margin-top: 8px;
            font-size: 9px;
            line-height: 1.25;
        }

        .statement-title {
            font-weight: 900;
            margin-bottom: 3px;
        }

        .notes {
            margin-top: 34px;
            font-size: 9px;
            line-height: 1.45;
        }

            .notes strong {
                display: block;
                margin-bottom: 2px;
            }

        .bottom-section {
            display: grid;
            grid-template-columns: 440px 1fr;
            gap: 180px;
            margin-top: 26px;
            align-items: start;
        }

        .bank-title {
            font-size: 9px;
            font-weight: 900;
            text-decoration: underline;
            margin: 0 0 10px 52px;
        }

        .bank-table td {
            border: 2px solid #000;
            font-size: 10px;
            height: 18px;
            padding: 2px 6px;
        }

        .bank-table .label {
            width: 80px;
            background: #fff200;
            font-weight: 900;
        }

        .bank-table .value {
            background: #fff200;
        }

        .sign-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 34px 70px;
            font-size: 9px;
        }

        .sign-row {
            display: grid;
            grid-template-columns: 52px 115px 42px 95px;
            align-items: end;
            column-gap: 8px;
        }

        .sign-line {
            border-bottom: 2px solid #000;
            min-height: 14px;
            text-align: center;
            font-weight: 900;
        }

        .sign-name {
            font-weight: 900;
            text-decoration: underline;
        }

        .sign-role {
            font-size: 8px;
            margin-top: 2px;
        }

        @@media print {
            body {
                background: #fff;
            }

            .preview-toolbar {
                display: none;
            }

            .invoice-sheet {
                width: 100%;
                margin: 0;
                padding: 10mm;
                box-shadow: none;
            }

            @@page {
                size: A4 landscape;
                margin: 7mm;
            }
        }
    </style>
</head>
<body>
    <div class="preview-toolbar">
        <a asp-action="Detail" asp-route-id="@Model.Id" class="toolbar-btn dark">Back to Detail</a>
        <a asp-action="Export" asp-route-id="@Model.Id" class="toolbar-btn dark">Export</a>
        <button type="button" class="toolbar-btn" onclick="window.print()">Print</button>
    </div>

    <div class="invoice-sheet">
        <div class="top-header">
            <div>
                <div class="company-title">PT Citrabuana Indoloka</div>
                <div class="company-subtitle">In association with&nbsp; <strong>intertek</strong></div>
            </div>

            <div class="invoice-heading">INVOICE</div>

            <div class="invoice-no-box">
                <div>INVOICE NO.</div>
                <div>: @Model.InvoiceNo</div>
            </div>
        </div>

        <div class="info-block">
            <div class="info-row">
                <div>Name</div>
                <div class="info-line">@Model.EmployeeName</div>
            </div>
            <div class="info-row">
                <div>Period</div>
                <div class="info-line">@Model.Period</div>
            </div>
            <div class="info-row">
                <div>Kind of Job</div>
                <div class="info-line">@Model.Job</div>
            </div>
            <div class="info-row">
                <div>Homebase</div>
                <div class="info-line">@Model.Homebase</div>
            </div>
        </div>

        <table class="invoice-table">
            <thead>
                <tr>
                    <th rowspan="2" style="width:55px;">Nomor</th>
                    <th rowspan="2" style="width:75px;">Date</th>
                    <th rowspan="2" style="width:310px;">Details of Expense (Purpose, staff or others present)</th>
                    <th rowspan="2" style="width:55px;">Contract<br />or Cost<br />Centre</th>
                    <th colspan="2" rowspan="2" style="width:90px;">TOTAL EXPENSE</th>
                    <th colspan="11">Descriptions</th>
                </tr>
                <tr>
                    <th colspan="2">Audit Fee</th>
                    <th colspan="2">Lumpsum</th>
                    <th colspan="2">BPJS Kesehatan</th>
                    <th colspan="2">BPJS Ketenagakerjaan</th>
                    <th>Vehicle<br />Maintenance</th>
                    <th>Internet Data</th>
                    <th>Others</th>
                </tr>
            </thead>
            <tbody>
                @for (var i = 0; i < rowCount; i++)
                {
                    var item = Model.Items != null && i < Model.Items.Count ? Model.Items[i] : null;
                    <tr>
                        <td class="center">@(item == null ? "" : (i + 1).ToString())</td>
                        <td class="center">@(item == null ? "" : DateText(item.Date))</td>
                        <td>@(item == null ? "" : item.Description)</td>
                        <td class="center">@(item == null ? "" : "102")</td>
                        <td class="currency">@(item == null ? "" : "Rp")</td>
                        <td class="right">@(item == null ? "" : Money(item.AuditFee + item.Lumpsum))</td>
                        <td class="currency">@(item == null ? "" : "Rp")</td>
                        <td class="right">@(item == null ? "" : Money(item.AuditFee))</td>
                        <td class="currency">@(item == null || item.Lumpsum == 0 ? "" : "Rp")</td>
                        <td class="right">@(item == null ? "" : Money(item.Lumpsum))</td>
                        <td class="currency"></td>
                        <td class="right"></td>
                        <td class="currency"></td>
                        <td class="right"></td>
                        <td class="right"></td>
                        <td class="right"></td>
                        <td class="right"></td>
                    </tr>
                }

                <tr>
                    <td></td>
                    <td></td>
                    <td class="summary-label">Brought forward from continuation sheet</td>
                    <td></td>
                    <td class="currency"></td>
                    <td class="right"></td>
                    <td class="currency"></td>
                    <td class="right"></td>
                    <td class="currency"></td>
                    <td class="right"></td>
                    <td class="currency"></td>
                    <td class="right"></td>
                    <td class="currency"></td>
                    <td class="right"></td>
                    <td class="right"></td>
                    <td class="right"></td>
                    <td class="right"></td>
                </tr>
                <tr>
                    <td></td>
                    <td></td>
                    <td class="summary-label">TOTAL/CARRIED FORWARD</td>
                    <td></td>
                    <td class="currency">Rp</td>
                    <td class="right bold">@Money(Model.TotalExpense)</td>
                    <td class="currency">Rp</td>
                    <td class="right bold">@Money(Model.TotalAuditFee)</td>
                    <td class="currency">Rp</td>
                    <td class="right bold">@Money(Model.TotalLumpsum)</td>
                    <td class="currency">@(bpjsKesehatan == 0 ? "" : "Rp")</td>
                    <td class="right bold">@Money(bpjsKesehatan)</td>
                    <td class="currency">@(bpjsKetenagakerjaan == 0 ? "" : "Rp")</td>
                    <td class="right bold">@Money(bpjsKetenagakerjaan)</td>
                    <td class="right bold">@Money(vehicleMaintenance)</td>
                    <td class="right bold">@Money(internetData)</td>
                    <td class="right bold">@Money(others)</td>
                </tr>
                <tr>
                    <td></td>
                    <td></td>
                    <td class="summary-label">LESS DIRECT CHARGES</td>
                    <td></td>
                    <td class="currency">@(Model.LessDirectCharges == 0 ? "" : "Rp")</td>
                    <td class="right bold">@Money(Model.LessDirectCharges)</td>
                    <td colspan="11"></td>
                </tr>
                <tr>
                    <td></td>
                    <td></td>
                    <td class="summary-label">LESS ADVANCES</td>
                    <td></td>
                    <td class="currency">@(Model.LessAdvances == 0 ? "" : "Rp")</td>
                    <td class="right bold">@Money(Model.LessAdvances)</td>
                    <td colspan="11"></td>
                </tr>
                <tr>
                    <td></td>
                    <td></td>
                    <td class="summary-label">AMOUNT DUE TO/FROM EMPLOYEE</td>
                    <td></td>
                    <td class="currency">Rp</td>
                    <td class="right bold">@Money(amountDue)</td>
                    <td colspan="11"></td>
                </tr>
            </tbody>
        </table>

        <div class="statement-row">
            <div></div>
            <div>
                <div class="statement-title">Report Statement</div>
                The expenses submitted herein are a true and accurate record of prudent costs necessarily incurred on behalf of Intertek.
                These costs are supported by original receipts of the charging establishments wherever possible.
                These costs have not been reimbursed to myself previously nor to any other party.
            </div>
        </div>

        <div class="notes">
            <strong>Claimant:</strong>
            Receipts/invoices for the above are properly documented, attached and cross-referenced. Where VAT is claimed, proper VAT invoice is attached.
            <br /><br />
            <strong>Accountant:</strong>
            Checked calculations; exchange rates; reasonableness; receipts amounts, dates and details agree. Please highlight missing vouchers, any other discrepancies.
            <br /><br />
            <strong>Authoriser:</strong>
            Expenses claimed are reasonable. Accountant has reviewed and signed and all discrepancies highlighted approved. If not, reject claim.
        </div>

        <div class="bottom-section">
            <div>
                <div class="bank-title">Please transfer to :</div>
                <table class="bank-table">
                    <tr>
                        <td class="label">NAME</td>
                        <td class="value">@Model.BankOwner</td>
                    </tr>
                    <tr>
                        <td class="label">Bank</td>
                        <td class="value">@Model.BankName</td>
                    </tr>
                    <tr>
                        <td class="label">A/C No.</td>
                        <td class="value">@Model.BankAccount</td>
                    </tr>
                </table>
            </div>

            <div class="sign-grid">
                <div class="sign-row">
                    <div>Signed :</div>
                    <div>
                        <div class="sign-line">@Model.EmployeeName</div>
                        <div class="sign-role">Claimant</div>
                    </div>
                    <div>Date:</div>
                    <div class="sign-line">@Model.ClaimDate.ToString("dd/MM/yyyy")</div>
                </div>

                <div class="sign-row">
                    <div>Signed :</div>
                    <div>
                        <div class="sign-line">Rommy Irwan</div>
                        <div class="sign-role">Branch Rept.</div>
                    </div>
                    <div>Date:</div>
                    <div class="sign-line"></div>
                </div>

                <div class="sign-row">
                    <div>Signed :</div>
                    <div>
                        <div class="sign-line">Tri Poni</div>
                        <div class="sign-role">Checked by</div>
                    </div>
                    <div>Date:</div>
                    <div class="sign-line"></div>
                </div>

                <div class="sign-row">
                    <div>Signed :</div>
                    <div>
                        <div class="sign-line">Sabar L Kembaren</div>
                        <div class="sign-role">Manager</div>
                    </div>
                    <div>Date:</div>
                    <div class="sign-line"></div>
                </div>

                <div class="sign-row">
                    <div>Signed :</div>
                    <div>
                        <div class="sign-line">Elvy Chandra</div>
                        <div class="sign-role">General Manager</div>
                    </div>
                    <div>Date:</div>
                    <div class="sign-line"></div>
                </div>

                <div class="sign-row">
                    <div>Signed :</div>
                    <div>
                        <div class="sign-line">Taufik Hidayat</div>
                        <div class="sign-role">Director</div>
                    </div>
                    <div>Date:</div>
                    <div class="sign-line"></div>
                </div>
            </div>
        </div>
    </div>

    @if (autoPrint)
    {
        <script>
            window.addEventListener('load', function () {
                window.print();
            });
        </script>
    }
</body>
</html>
