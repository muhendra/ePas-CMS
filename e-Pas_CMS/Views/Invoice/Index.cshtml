@using e_Pas_CMS.ViewModels
@model e_Pas_CMS.ViewModels.PaginationModel<InvoiceVM>

@section Styles {
    <style>
        :root {
            --invoice-bg: #f4f5f7;
            --invoice-card: #ffffff;
            --invoice-text: #101820;
            --invoice-muted: #9aa3ad;
            --invoice-line: #edf0f2;
            --invoice-head: #eeeeef;
            --invoice-cyan: #22b8d4;
            --invoice-yellow: #ffb800;
            --invoice-green: #12ad66;
            --invoice-red: #ef4444;
            --invoice-blue: #2563eb;
            --invoice-orange: #f97316;
        }

        body {
            background: var(--invoice-bg);
            font-family: 'Inter', Arial, Helvetica, sans-serif;
            color: var(--invoice-text);
        }

        .invoice-page {
            padding: 38px 44px 70px;
        }

        .invoice-title {
            font-size: 30px;
            font-weight: 800;
            letter-spacing: -0.5px;
            margin-bottom: 8px;
        }

        .invoice-subtitle {
            color: #7b8490;
            font-size: 14px;
            margin-bottom: 28px;
        }

        .invoice-toolbar {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 26px;
            flex-wrap: wrap;
        }

        .invoice-search-wrap {
            position: relative;
            width: 100%;
            max-width: 520px;
        }

        .invoice-search-icon {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: #4b5563;
            font-size: 18px;
            z-index: 2;
        }

        .invoice-search {
            height: 50px;
            width: 100%;
            border-radius: 12px;
            border: 1px solid #e1e5ea;
            background: #fff;
            padding: 0 18px 0 48px;
            font-size: 15px;
            color: #111827;
            outline: none;
            box-shadow: none;
        }

        .invoice-search::placeholder {
            color: #9aa3ad;
        }

        .invoice-search:focus {
            border-color: var(--invoice-cyan);
            box-shadow: 0 0 0 3px rgba(34,184,212,.12);
        }

        .invoice-search-btn {
            height: 50px;
            border: 0;
            border-radius: 999px;
            background: var(--invoice-cyan);
            color: #fff;
            padding: 0 24px;
            font-size: 14px;
            font-weight: 800;
            cursor: pointer;
            transition: all .15s ease;
        }

        .invoice-search-btn:hover {
            background: #19a8c3;
            transform: translateY(-1px);
        }

        .invoice-reset-btn {
            height: 50px;
            border-radius: 999px;
            border: 1px solid #d7dde5;
            background: #fff;
            color: #4b5563;
            padding: 0 22px;
            font-size: 14px;
            font-weight: 800;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

        .invoice-reset-btn:hover {
            color: #111827;
            background: #f8fafc;
        }

        .invoice-card-table {
            background: var(--invoice-card);
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid #e9ecef;
            box-shadow: 0 14px 34px rgba(15, 23, 42, .06);
        }

        .invoice-table {
            width: 100%;
            margin: 0;
            border-collapse: separate;
            border-spacing: 0;
            min-width: 1080px;
        }

        .invoice-table thead th {
            background: var(--invoice-head);
            border: 0;
            padding: 15px 22px;
            font-size: 15px;
            font-weight: 800;
            color: #111827;
            vertical-align: middle;
            white-space: nowrap;
        }

        .invoice-table tbody td {
            background: #fff;
            border-top: 1px dashed #e8ebef;
            padding: 18px 22px;
            font-size: 15px;
            vertical-align: middle;
            color: #111827;
        }

        .invoice-table tbody tr:first-child td {
            border-top: 0;
        }

        .invoice-table tbody tr:hover td {
            background: #fcfdff;
        }

        .invoice-number-link {
            color: #13b5d1;
            text-decoration: none;
            font-weight: 800;
            white-space: nowrap;
        }

        .invoice-number-link:hover {
            color: #0ea5bd;
            text-decoration: underline;
        }

        .invoice-date-main {
            font-weight: 600;
            line-height: 1.25;
        }

        .invoice-date-sub {
            color: #a0a7b0;
            font-size: 13px;
            margin-top: 2px;
        }

        .invoice-amount {
            font-weight: 800;
            white-space: nowrap;
        }

        .invoice-status {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-size: 13px;
            font-weight: 800;
            line-height: 1.35;
            border-radius: 999px;
            padding: 7px 12px;
            white-space: nowrap;
        }

        .invoice-status-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: currentColor;
        }

        .invoice-status.under-review {
            color: var(--invoice-orange);
            background: #fff7ed;
        }

        .invoice-status.pending {
            color: var(--invoice-blue);
            background: #eff6ff;
        }

        .invoice-status.approved {
            color: var(--invoice-green);
            background: #ecfdf5;
        }

        .invoice-status.rejected {
            color: var(--invoice-red);
            background: #fef2f2;
        }

        .invoice-status.default {
            color: #64748b;
            background: #f1f5f9;
        }

        .invoice-action {
            text-align: center;
        }

        .invoice-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 96px;
            height: 36px;
            padding: 0 20px;
            border: 0;
            border-radius: 999px;
            background: var(--invoice-cyan);
            color: #fff;
            font-size: 14px;
            font-weight: 800;
            text-decoration: none;
            cursor: pointer;
            transition: all .15s ease;
        }

        .invoice-btn:hover {
            background: #19a8c3;
            color: #fff;
            transform: translateY(-1px);
        }

        .invoice-btn.process {
            background: #111827;
        }

        .invoice-btn.process:hover {
            background: #1f2937;
        }

        .invoice-empty {
            text-align: center;
            color: #8b95a1;
            padding: 44px 16px !important;
            font-weight: 600;
        }

        .invoice-scrollbar {
            height: 16px;
            background: #ffffff;
            border-radius: 999px;
            margin: 26px 12px 22px;
            overflow: hidden;
        }

        .invoice-scrollbar span {
            display: block;
            width: 35%;
            height: 100%;
            background: #e9e9ea;
            border-radius: 999px;
        }

        .invoice-pagination-wrap {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 14px;
            margin-top: 12px;
            flex-wrap: wrap;
        }

        .invoice-pagination {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 0;
            padding: 0;
            list-style: none;
            flex-wrap: wrap;
        }

        .invoice-page-link {
            width: 30px;
            height: 30px;
            border-radius: 9px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #111827;
            text-decoration: none;
            font-size: 14px;
            font-weight: 700;
        }

        .invoice-page-link.active {
            background: var(--invoice-cyan);
            color: #fff;
            font-weight: 800;
        }

        .invoice-page-arrow {
            color: #a6adb5;
            text-decoration: none;
            font-size: 26px;
            line-height: 1;
        }

        .invoice-page-arrow:hover {
            color: #111827;
        }

        .invoice-alert {
            border-radius: 12px;
            padding: 12px 16px;
            margin-bottom: 18px;
            font-weight: 700;
        }

        .invoice-alert.success {
            background: #ecfdf5;
            color: #047857;
            border: 1px solid #bbf7d0;
        }

        .invoice-alert.error {
            background: #fef2f2;
            color: #b91c1c;
            border: 1px solid #fecaca;
        }

        @@media (max-width: 991px) {
            .invoice-page {
                padding: 24px 18px 60px;
            }

            .invoice-title {
                font-size: 26px;
            }

            .invoice-table thead th,
            .invoice-table tbody td {
                padding: 15px 16px;
                font-size: 14px;
            }

            .invoice-search-wrap {
                max-width: none;
            }

            .invoice-search-btn,
            .invoice-reset-btn {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
}

@{
    var totalPages = Model.TotalPages;
    var prevPage = Model.PageNumber > 1 ? Model.PageNumber - 1 : 1;
    var nextPage = Model.PageNumber < totalPages ? Model.PageNumber + 1 : totalPages;

    string GetStatusText(string status)
    {
        return status switch
        {
            "UNDER_REVIEW" => "Sedang Direview",
            "PENDING_APPROVAL" => "Menunggu Approval",
            "APPROVED" => "Disetujui",
            "REJECTED" => "Ditolak",

            "NOT_CLAIMED" => "Belum Diklaim",
            "IN_PROGRESS" => "Diproses",
            "COMPLETED" => "Selesai",

            _ => string.IsNullOrWhiteSpace(status) ? "-" : status
        };
    }

    string GetStatusClass(string status)
    {
        return status switch
        {
            "UNDER_REVIEW" => "under-review",
            "PENDING_APPROVAL" => "pending",
            "APPROVED" => "approved",
            "REJECTED" => "rejected",

            "NOT_CLAIMED" => "under-review",
            "IN_PROGRESS" => "pending",
            "COMPLETED" => "approved",

            _ => "default"
        };
    }
}

<div class="invoice-page">
    <h1 class="invoice-title">Invoice Management</h1>
    <div class="invoice-subtitle">
        Kelola invoice finance, proses review, approval, reject, dan total expense auditor.
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="invoice-alert success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="invoice-alert error">@TempData["Error"]</div>
    }

    <form method="get" asp-action="Index" class="invoice-toolbar">
        <div class="invoice-search-wrap">
            <span class="invoice-search-icon">
                <i class="bi bi-search"></i>
            </span>

            <input type="text"
                   name="searchTerm"
                   value="@ViewBag.SearchTerm"
                   class="invoice-search"
                   placeholder="Cari invoice, SPBU, employee, atau surveyor..." />

            <input type="hidden" name="pageNumber" value="1" />
            <input type="hidden" name="pageSize" value="@Model.PageSize" />
            <input type="hidden" name="sortColumn" value="@ViewBag.SortColumn" />
            <input type="hidden" name="sortDirection" value="@ViewBag.SortDirection" />
        </div>

        <button type="submit" class="invoice-search-btn">
            Cari
        </button>

        <a asp-action="Index" class="invoice-reset-btn">
            Reset
        </a>
    </form>

    <div class="invoice-card-table">
        <div class="table-responsive">
            <table class="invoice-table">
                <thead>
                    <tr>
                        <th>Invoice Number</th>
                        <th>Invoice Date</th>
                        <th>Employee ID</th>
                        <th>Name of<br />Surveyor</th>
                        <th>Expected<br />Settlement Date</th>
                        <th>Total Expense</th>
                        <th>Status</th>
                        <th class="invoice-action">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            var status = item.Status ?? "";
                            var statusText = GetStatusText(status);
                            var statusClass = GetStatusClass(status);

                            // item.Status dari controller adalah trx_claim.status.
                            // Tombol Proses hanya muncul saat claim UNDER_REVIEW.
                            var canProcess = status == "UNDER_REVIEW";

                            <tr>
                                <td>
                                    <a asp-action="Detail"
                                       asp-route-id="@item.Id"
                                       class="invoice-number-link">
                                        @item.InvoiceNo
                                    </a>
                                </td>

                                <td>
                                    <div class="invoice-date-main">
                                        @(item.InvoiceDate?.ToString("dd/MM/yyyy") ?? "-")
                                    </div>
                                    <div class="invoice-date-sub">
                                        @(item.InvoiceDate?.ToString("HH:mm") ?? "--:--") WIB
                                    </div>
                                </td>

                                <td>@(item.EmployeeId ?? "-")</td>

                                <td>@(item.SurveyorName ?? "-")</td>

                                <td>
                                    <div class="invoice-date-main">
                                        @(item.ExpectedDate?.ToString("dd/MM/yyyy") ?? "-")
                                    </div>
                                    <div class="invoice-date-sub">
                                        @(item.ExpectedDate?.ToString("HH:mm") ?? "--:--") WIB
                                    </div>
                                </td>

                                <td>
                                    <span class="invoice-amount">
                                        Rp @item.TotalAmount.ToString("N0")
                                    </span>
                                </td>

                                <td>
                                    <span class="invoice-status @statusClass">
                                        <span class="invoice-status-dot"></span>
                                        @statusText
                                    </span>
                                </td>

                                <td class="invoice-action">
                                    @if (canProcess)
                                    {
                                        <form asp-action="StartProcess" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="invoice-btn process">
                                                Proses
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <a asp-action="Detail"
                                           asp-route-id="@item.Id"
                                           class="invoice-btn">
                                            Detail
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="invoice-empty">
                                Tidak ada data invoice
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="invoice-scrollbar">
        <span></span>
    </div>

    @if (totalPages > 1)
    {
        <div class="invoice-pagination-wrap">
            <a class="invoice-page-arrow"
               href="@Url.Action("Index", new {
                   pageNumber = prevPage,
                   pageSize = Model.PageSize,
                   searchTerm = ViewBag.SearchTerm,
                   sortColumn = ViewBag.SortColumn,
                   sortDirection = ViewBag.SortDirection
               })">
                ‹
            </a>

            <ul class="invoice-pagination">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li>
                        <a class="invoice-page-link @(i == Model.PageNumber ? "active" : "")"
                           href="@Url.Action("Index", new {
                               pageNumber = i,
                               pageSize = Model.PageSize,
                               searchTerm = ViewBag.SearchTerm,
                               sortColumn = ViewBag.SortColumn,
                               sortDirection = ViewBag.SortDirection
                           })">
                            @i
                        </a>
                    </li>
                }
            </ul>

            <a class="invoice-page-arrow"
               href="@Url.Action("Index", new {
                   pageNumber = nextPage,
                   pageSize = Model.PageSize,
                   searchTerm = ViewBag.SearchTerm,
                   sortColumn = ViewBag.SortColumn,
                   sortDirection = ViewBag.SortDirection
               })">
                ›
            </a>
        </div>
    }
</div>