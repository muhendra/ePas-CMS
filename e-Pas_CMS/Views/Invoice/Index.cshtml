@using e_Pas_CMS.ViewModels
@using System.Collections.Generic
@model e_Pas_CMS.ViewModels.PaginationModel<InvoiceVM>

@section Styles {
    <style>
        :root {
            --invoice-bg: #f4f5f7;
            --invoice-card: #ffffff;
            --invoice-text: #101820;
            --invoice-muted: #9aa3ad;
            --invoice-line: #edf0f2;
            --invoice-head: #eeeeef;
            --invoice-cyan: #22b8d4;
            --invoice-yellow: #ffb800;
            --invoice-green: #12ad66;
            --invoice-red: #ef4444;
            --invoice-blue: #2563eb;
            --invoice-orange: #f97316;
            --invoice-dark: #111827;
        }

        body {
            background: var(--invoice-bg);
            font-family: 'Inter', Arial, Helvetica, sans-serif;
            color: var(--invoice-text);
        }

        .invoice-page {
            padding: 38px 44px 70px;
        }

        .invoice-title {
            font-size: 30px;
            font-weight: 800;
            letter-spacing: -0.5px;
            margin-bottom: 8px;
        }

        .invoice-subtitle {
            color: #7b8490;
            font-size: 14px;
            margin-bottom: 28px;
        }

        .summary-filter-card {
            background: #ffffff;
            border: 1px solid #e9ecef;
            border-radius: 16px;
            box-shadow: 0 14px 34px rgba(15, 23, 42, .06);
            padding: 22px;
            margin-bottom: 24px;
        }

        .summary-filter-head {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 18px;
            margin-bottom: 18px;
            flex-wrap: wrap;
        }

        .summary-filter-title {
            font-size: 22px;
            font-weight: 900;
            letter-spacing: -0.3px;
            margin: 0 0 4px;
            color: #111827;
        }

        .summary-filter-subtitle {
            color: #7b8490;
            font-size: 13px;
            margin: 0;
        }

        .summary-filter-form {
            display: grid;
            grid-template-columns: minmax(220px, 1.1fr) minmax(170px, .8fr) minmax(260px, 1.2fr) auto auto;
            gap: 12px;
            align-items: end;
        }

        .summary-field label {
            display: block;
            font-size: 12px;
            font-weight: 800;
            margin-bottom: 7px;
            color: #111827;
        }

        .summary-control {
            height: 46px;
            width: 100%;
            border-radius: 12px;
            border: 1px solid #e1e5ea;
            background: #fff;
            padding: 0 14px;
            font-size: 14px;
            color: #111827;
            outline: none;
            box-shadow: none;
        }

            .summary-control:focus {
                border-color: var(--invoice-cyan);
                box-shadow: 0 0 0 3px rgba(34,184,212,.12);
            }

        .summary-search-wrap {
            position: relative;
        }

        .summary-search-wrap i {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #6b7280;
        }

        .summary-search-wrap .summary-control {
            padding-left: 40px;
        }

        .invoice-search-btn {
            height: 46px;
            border: 0;
            border-radius: 999px;
            background: var(--invoice-cyan);
            color: #fff;
            padding: 0 24px;
            font-size: 14px;
            font-weight: 800;
            cursor: pointer;
            transition: all .15s ease;
            white-space: nowrap;
        }

            .invoice-search-btn:hover {
                background: #19a8c3;
                transform: translateY(-1px);
            }

        .invoice-reset-btn {
            height: 46px;
            border-radius: 999px;
            border: 1px solid #d7dde5;
            background: #fff;
            color: #4b5563;
            padding: 0 22px;
            font-size: 14px;
            font-weight: 800;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            white-space: nowrap;
        }

            .invoice-reset-btn:hover {
                color: #111827;
                background: #f8fafc;
            }

        .summary-grid {
            display: grid;
            grid-template-columns: repeat(5, minmax(150px, 1fr));
            gap: 12px;
            margin-top: 20px;
        }

        .summary-card {
            background: #f8fafc;
            border: 1px solid #edf0f2;
            border-radius: 14px;
            padding: 16px;
            min-height: 94px;
        }

        .summary-card-label {
            color: #6b7280;
            font-size: 12px;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .summary-card-value {
            color: #111827;
            font-size: 24px;
            font-weight: 900;
            letter-spacing: -0.3px;
        }

        .summary-card-value.money {
            font-size: 18px;
            line-height: 1.3;
        }

        .summary-card-note {
            color: #9aa3ad;
            font-size: 11px;
            margin-top: 6px;
        }

        .invoice-card-table {
            background: var(--invoice-card);
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid #e9ecef;
            box-shadow: 0 14px 34px rgba(15, 23, 42, .06);
        }

        .invoice-table {
            width: 100%;
            margin: 0;
            border-collapse: separate;
            border-spacing: 0;
            min-width: 1080px;
        }

            .invoice-table thead th {
                background: var(--invoice-head);
                border: 0;
                padding: 12px 16px;
                font-size: 12px;
                font-weight: 800;
                color: #111827;
                vertical-align: middle;
                white-space: nowrap;
            }

            .invoice-table tbody td {
                background: #fff;
                border-top: 1px dashed #e8ebef;
                padding: 13px 16px;
                font-size: 12px;
                vertical-align: middle;
                color: #111827;
            }

            .invoice-table tbody tr:first-child td {
                border-top: 0;
            }

            .invoice-table tbody tr:hover td {
                background: #fcfdff;
            }

        .invoice-number-link {
            color: #13b5d1;
            text-decoration: none;
            font-weight: 800;
            white-space: nowrap;
            font-size: 12px;
        }

            .invoice-number-link:hover {
                color: #0ea5bd;
                text-decoration: underline;
            }

        .invoice-date-main {
            font-weight: 600;
            line-height: 1.25;
            font-size: 12px;
        }

        .invoice-date-sub {
            color: #a0a7b0;
            font-size: 11px;
            margin-top: 2px;
        }

        .invoice-amount {
            font-weight: 800;
            white-space: nowrap;
            font-size: 12px;
        }

        .invoice-status {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            font-weight: 800;
            line-height: 1.35;
            border-radius: 999px;
            padding: 6px 10px;
            white-space: nowrap;
        }

        .invoice-status-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
        }

        .invoice-status.under-review {
            color: var(--invoice-orange);
            background: #fff7ed;
        }

        .invoice-status.pending {
            color: var(--invoice-blue);
            background: #eff6ff;
        }

        .invoice-status.approved {
            color: var(--invoice-green);
            background: #ecfdf5;
        }

        .invoice-status.rejected {
            color: var(--invoice-red);
            background: #fef2f2;
        }

        .invoice-status.default {
            color: #64748b;
            background: #f1f5f9;
        }

        .invoice-action {
            text-align: center;
        }

        .invoice-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 86px;
            height: 32px;
            padding: 0 16px;
            border: 0;
            border-radius: 999px;
            background: var(--invoice-cyan);
            color: #fff;
            font-size: 12px;
            font-weight: 800;
            text-decoration: none;
            cursor: pointer;
            transition: all .15s ease;
        }

            .invoice-btn:hover {
                background: #19a8c3;
                color: #fff;
                transform: translateY(-1px);
            }

            .invoice-btn.process {
                background: #111827;
            }

                .invoice-btn.process:hover {
                    background: #1f2937;
                }

        .invoice-empty {
            text-align: center;
            color: #8b95a1;
            padding: 44px 16px !important;
            font-weight: 600;
            font-size: 12px;
        }

        .invoice-scrollbar {
            height: 16px;
            background: #ffffff;
            border-radius: 999px;
            margin: 26px 12px 22px;
            overflow: hidden;
        }

            .invoice-scrollbar span {
                display: block;
                width: 35%;
                height: 100%;
                background: #e9e9ea;
                border-radius: 999px;
            }

        .invoice-pagination-wrap {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 14px;
            margin-top: 12px;
            flex-wrap: wrap;
        }

        .invoice-pagination {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 0;
            padding: 0;
            list-style: none;
            flex-wrap: wrap;
        }

        .invoice-page-link {
            width: 30px;
            height: 30px;
            border-radius: 9px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #111827;
            text-decoration: none;
            font-size: 14px;
            font-weight: 700;
        }

            .invoice-page-link.active {
                background: var(--invoice-cyan);
                color: #fff;
                font-weight: 800;
            }

        .invoice-page-arrow {
            color: #a6adb5;
            text-decoration: none;
            font-size: 26px;
            line-height: 1;
        }

            .invoice-page-arrow:hover {
                color: #111827;
            }

        .invoice-alert {
            border-radius: 12px;
            padding: 12px 16px;
            margin-bottom: 18px;
            font-weight: 700;
        }

            .invoice-alert.success {
                background: #ecfdf5;
                color: #047857;
                border: 1px solid #bbf7d0;
            }

            .invoice-alert.error {
                background: #fef2f2;
                color: #b91c1c;
                border: 1px solid #fecaca;
            }

        @@media (max-width: 1200px) {
            .summary-filter-form {
                grid-template-columns: repeat(2, minmax(220px, 1fr));
            }

            .summary-grid {
                grid-template-columns: repeat(2, minmax(150px, 1fr));
            }
        }

        @@media (max-width: 991px) {
            .invoice-page {
                padding: 24px 18px 60px;
            }

            .invoice-title {
                font-size: 26px;
            }

            .summary-filter-form,
            .summary-grid {
                grid-template-columns: 1fr;
            }

            .invoice-table thead th,
            .invoice-table tbody td {
                padding: 12px 14px;
                font-size: 12px;
            }

            .invoice-date-main {
                font-size: 12px;
            }

            .invoice-date-sub {
                font-size: 11px;
            }

            .invoice-status {
                font-size: 12px;
            }

            .invoice-search-btn,
            .invoice-reset-btn {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
}

@{
    var totalPages = Model.TotalPages;
    var prevPage = Model.PageNumber > 1 ? Model.PageNumber - 1 : 1;
    var nextPage = Model.PageNumber < totalPages ? Model.PageNumber + 1 : totalPages;

    var auditorOptions = ViewBag.AuditorOptions as IEnumerable<InvoiceAuditorOptionVM>
        ?? new List<InvoiceAuditorOptionVM>();

    var selectedAuditorId = ViewBag.AuditorId as string ?? "";
    var selectedPeriodClaim = ViewBag.PeriodClaim as string ?? "";
    var searchTerm = ViewBag.SearchTerm as string ?? "";

    var summaryTotalInvoice = ViewBag.SummaryTotalInvoice is int sti ? sti : 0;
    var summaryTotalExpense = ViewBag.SummaryTotalExpense is decimal ste ? ste : 0m;
    var summaryApproved = ViewBag.SummaryApproved is int sa ? sa : 0;
    var summaryPending = ViewBag.SummaryPending is int sp ? sp : 0;
    var summaryRejected = ViewBag.SummaryRejected is int sr ? sr : 0;

    string GetStatusText(string status)
    {
        return status switch
        {
            "UNDER_REVIEW" => "Sedang Direview",
            "PENDING_APPROVAL" => "Menunggu Approval",
            "APPROVED" => "Disetujui",
            "REJECTED" => "Ditolak",

            "NOT_CLAIMED" => "Belum Diklaim",
            "IN_PROGRESS" => "Diproses",
            "COMPLETED" => "Selesai",

            _ => string.IsNullOrWhiteSpace(status) ? "-" : status
        };
    }

    string GetStatusClass(string status)
    {
        return status switch
        {
            "UNDER_REVIEW" => "under-review",
            "PENDING_APPROVAL" => "pending",
            "APPROVED" => "approved",
            "REJECTED" => "rejected",

            "NOT_CLAIMED" => "under-review",
            "IN_PROGRESS" => "pending",
            "COMPLETED" => "approved",

            _ => "default"
        };
    }
}

<div class="invoice-page">
    <h1 class="invoice-title">Invoice Management</h1>
    <div class="invoice-subtitle">
        Summary Invoice dan pengelolaan proses review, approval, reject, serta total expense auditor.
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="invoice-alert success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="invoice-alert error">@TempData["Error"]</div>
    }

    <div class="summary-filter-card">
        <div class="summary-filter-head">
            <div>
                <h2 class="summary-filter-title">Summary Invoice</h2>
                <p class="summary-filter-subtitle">
                    Filter berdasarkan auditor dan periode claim untuk melihat ringkasan invoice.
                </p>
            </div>
        </div>

        <form method="get" asp-action="Index" class="summary-filter-form">
            <div class="summary-field">
                <label>Auditor</label>
                <select name="auditorId" class="summary-control">
                    <option value="">Semua Auditor</option>
                    @foreach (var auditor in auditorOptions)
                    {
                        var auditorId = Convert.ToString(auditor.Id) ?? "";
                        var auditorName = string.IsNullOrWhiteSpace(auditor.Name) ? "-" : auditor.Name;

                        if (selectedAuditorId == auditorId)
                        {
                            <option value="@auditorId" selected="selected">
                                @auditorName
                            </option>
                        }
                        else
                        {
                            <option value="@auditorId">
                                @auditorName
                            </option>
                        }
                    }
                </select>
            </div>

            <div class="summary-field">
                <label>Months / Periode Claim</label>
                <input type="month"
                       name="periodClaim"
                       value="@selectedPeriodClaim"
                       class="summary-control" />
            </div>

            <div class="summary-field">
                <label>Keyword</label>
                <div class="summary-search-wrap">
                    <i class="bi bi-search"></i>
                    <input type="text"
                           name="searchTerm"
                           value="@searchTerm"
                           class="summary-control"
                           placeholder="Cari invoice, SPBU, employee, atau surveyor..." />
                </div>
            </div>

            <input type="hidden" name="pageNumber" value="1" />
            <input type="hidden" name="pageSize" value="@Model.PageSize" />
            <input type="hidden" name="sortColumn" value="@ViewBag.SortColumn" />
            <input type="hidden" name="sortDirection" value="@ViewBag.SortDirection" />

            <button type="submit" class="invoice-search-btn">
                Filter
            </button>

            <a asp-action="Index" class="invoice-reset-btn">
                Reset
            </a>
        </form>

        <div class="summary-grid">
            <div class="summary-card">
                <div class="summary-card-label">Total Invoice</div>
                <div class="summary-card-value">@summaryTotalInvoice.ToString("N0")</div>
                <div class="summary-card-note">Sesuai filter aktif</div>
            </div>

            <div class="summary-card">
                <div class="summary-card-label">Total Expense</div>
                <div class="summary-card-value money">Rp @summaryTotalExpense.ToString("N0")</div>
                <div class="summary-card-note">Akumulasi invoice</div>
            </div>

            <div class="summary-card">
                <div class="summary-card-label">Disetujui</div>
                <div class="summary-card-value">@summaryApproved.ToString("N0")</div>
                <div class="summary-card-note">Status approved</div>
            </div>

            <div class="summary-card">
                <div class="summary-card-label">Menunggu / Review</div>
                <div class="summary-card-value">@summaryPending.ToString("N0")</div>
                <div class="summary-card-note">Under review & pending approval</div>
            </div>

            <div class="summary-card">
                <div class="summary-card-label">Ditolak</div>
                <div class="summary-card-value">@summaryRejected.ToString("N0")</div>
                <div class="summary-card-note">Status rejected</div>
            </div>
        </div>
    </div>

    <div class="invoice-card-table">
        <div class="table-responsive">
            <table class="invoice-table">
                <thead>
                    <tr>
                        <th>Invoice Number</th>
                        <th>Name of<br />Surveyor</th>
                        <th>Total Expense</th>
                        <th>Status</th>
                        <th>Tanggal<br />Pengajuan Claim</th>
                        <th class="invoice-action">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            var status = item.Status ?? "";
                            var statusText = GetStatusText(status);
                            var statusClass = GetStatusClass(status);
                            var canProcess = status == "UNDER_REVIEW";

                            <tr>
                                <td>
                                    <a asp-action="Detail"
                                       asp-route-id="@item.Id"
                                       class="invoice-number-link">
                                        @item.InvoiceNo
                                    </a>
                                </td>

                                <td>@(item.SurveyorName ?? "-")</td>

                                <td>
                                    <span class="invoice-amount">
                                        Rp @item.TotalAmount.ToString("N0")
                                    </span>
                                </td>

                                <td>
                                    <span class="invoice-status @statusClass">
                                        <span class="invoice-status-dot"></span>
                                        @statusText
                                    </span>
                                </td>

                                <td>
                                    <div class="invoice-date-main">
                                        @(item.ClaimSubmittedDate?.ToString("dd/MM/yyyy") ?? "-")
                                    </div>
                                    <div class="invoice-date-sub">
                                        @(item.ClaimSubmittedDate?.ToString("HH:mm") ?? "--:--") WIB
                                    </div>
                                </td>

                                <td class="invoice-action">
                                    @if (canProcess)
                                    {
                                        <form asp-action="StartProcess" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="invoice-btn process">
                                                Proses
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <a asp-action="Detail"
                                           asp-route-id="@item.Id"
                                           class="invoice-btn">
                                            Detail
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="invoice-empty">
                                Tidak ada data invoice
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="invoice-scrollbar">
        <span></span>
    </div>

    @if (totalPages > 1)
    {
        <div class="invoice-pagination-wrap">
            <a class="invoice-page-arrow"
               href="@Url.Action("Index", new {
                   pageNumber = prevPage,
                   pageSize = Model.PageSize,
                   searchTerm = searchTerm,
                   auditorId = selectedAuditorId,
                   periodClaim = selectedPeriodClaim,
                   sortColumn = ViewBag.SortColumn,
                   sortDirection = ViewBag.SortDirection
               })">
                ‹
            </a>

            <ul class="invoice-pagination">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li>
                        <a class="invoice-page-link @(i == Model.PageNumber ? "active" : "")"
                           href="@Url.Action("Index", new {
                               pageNumber = i,
                               pageSize = Model.PageSize,
                               searchTerm = searchTerm,
                               auditorId = selectedAuditorId,
                               periodClaim = selectedPeriodClaim,
                               sortColumn = ViewBag.SortColumn,
                               sortDirection = ViewBag.SortDirection
                           })">
                            @i
                        </a>
                    </li>
                }
            </ul>

            <a class="invoice-page-arrow"
               href="@Url.Action("Index", new {
                   pageNumber = nextPage,
                   pageSize = Model.PageSize,
                   searchTerm = searchTerm,
                   auditorId = selectedAuditorId,
                   periodClaim = selectedPeriodClaim,
                   sortColumn = ViewBag.SortColumn,
                   sortDirection = ViewBag.SortDirection
               })">
                ›
            </a>
        </div>
    }
</div>
