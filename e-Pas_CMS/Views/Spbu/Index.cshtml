@using e_Pas_CMS.ViewModels
@model PaginationModel<MasterSpbuViewModel>

@section Styles {
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body {
            font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: #f4f6f9;
            color: #1f2937;
        }

        .spbu-page {
            padding: 28px 32px;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            margin-bottom: 22px;
        }

        .page-title {
            margin: 0;
            font-size: 1.35rem;
            font-weight: 700;
            color: #111827;
            letter-spacing: -0.02em;
        }

        .page-subtitle {
            margin-top: 4px;
            color: #6b7280;
            font-size: 0.88rem;
        }

        .header-actions {
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
        }

        .card-panel {
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 18px;
            box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
            overflow: hidden;
        }

        .filter-panel {
            padding: 18px;
            margin-bottom: 20px;
        }

        .table-card {
            padding: 0;
        }

        .form-control,
        .form-select {
            border-radius: 12px;
            border: 1px solid #dbe1ea;
            padding: 10px 14px;
            font-size: 0.9rem;
            color: #111827;
            background: #ffffff;
        }

            .form-control::placeholder {
                color: #9ca3af;
            }

            .form-control:focus,
            .form-select:focus {
                border-color: #111827;
                box-shadow: 0 0 0 4px rgba(17, 24, 39, 0.08);
            }

        .btn {
            border-radius: 12px;
            font-weight: 700;
            font-size: 0.86rem;
            padding: 9px 14px;
        }

        .btn-dark-blue {
            background: #111827;
            border-color: #111827;
            color: #ffffff;
        }

            .btn-dark-blue:hover {
                background: #1e3a8a;
                border-color: #1e3a8a;
                color: #ffffff;
            }

        .btn-soft {
            background: #f9fafb;
            border: 1px solid #dbe1ea;
            color: #374151;
        }

            .btn-soft:hover {
                background: #eef2f7;
                border-color: #cbd5e1;
                color: #111827;
            }

        .btn-green {
            background: #027a48;
            border-color: #027a48;
            color: #ffffff;
        }

            .btn-green:hover {
                background: #05603a;
                border-color: #05603a;
                color: #ffffff;
            }

        .btn-gold {
            background: #fffaeb;
            border: 1px solid #fedf89;
            color: #b54708;
        }

            .btn-gold:hover {
                background: #fef0c7;
                border-color: #fdb022;
                color: #93370d;
            }

        .table {
            margin-bottom: 0;
            font-size: 0.9rem;
        }

            .table thead th {
                background: #f8fafc;
                color: #64748b;
                font-size: 0.73rem;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: 0.06em;
                border-bottom: 1px solid #e5e7eb;
                padding: 15px 16px;
                white-space: nowrap;
            }

            .table tbody td {
                padding: 16px;
                border-bottom: 1px solid #edf0f4;
                color: #374151;
                vertical-align: middle;
            }

            .table tbody tr:last-child td {
                border-bottom: none;
            }

            .table tbody tr:hover td {
                background: #fafafa;
            }

        .td-number {
            color: #94a3b8;
            font-weight: 700;
            width: 70px;
        }

        .spbu-number {
            font-weight: 800;
            color: #111827;
            white-space: nowrap;
        }

        .spbu-address {
            color: #6b7280;
            font-size: 0.84rem;
            max-width: 320px;
        }

        .pill {
            display: inline-flex;
            align-items: center;
            padding: 6px 11px;
            border-radius: 999px;
            background: #f1f5f9;
            color: #334155;
            font-weight: 700;
            font-size: 0.78rem;
            white-space: nowrap;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 800;
            white-space: nowrap;
        }

        .status-active {
            background: #ecfdf3;
            color: #027a48;
        }

        .status-warning {
            background: #fffaeb;
            color: #b54708;
        }

        .status-danger {
            background: #fef3f2;
            color: #b42318;
        }

        .status-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: currentColor;
        }

        .score-text {
            font-weight: 800;
            color: #111827;
        }

        .date-text {
            color: #667085;
            font-size: 0.84rem;
            font-weight: 600;
            white-space: nowrap;
        }

        .btn-action {
            background: #ffffff;
            border: 1px solid #dbe1ea;
            color: #344054;
            padding: 7px 11px;
            border-radius: 10px;
            font-weight: 700;
            font-size: 0.82rem;
            white-space: nowrap;
        }

            .btn-action:hover {
                background: #111827;
                border-color: #111827;
                color: #ffffff;
            }

        .alert {
            border-radius: 14px;
            font-weight: 600;
            border: 1px solid transparent;
        }

        .alert-success {
            background: #f0fdf4;
            color: #166534;
            border-color: #bbf7d0;
        }

        .alert-danger {
            background: #fef2f2;
            color: #991b1b;
            border-color: #fecaca;
        }

        .empty-state {
            padding: 44px 20px;
            text-align: center;
            color: #6b7280;
        }

        .empty-icon {
            width: 48px;
            height: 48px;
            margin: 0 auto 12px;
            border-radius: 14px;
            background: #f3f4f6;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #9ca3af;
            font-size: 1.4rem;
        }

        .pagination-wrapper {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 18px;
            gap: 12px;
            flex-wrap: wrap;
        }

        .pagination-info {
            color: #6b7280;
            font-size: 0.85rem;
        }

        .pagination {
            margin-bottom: 0;
            gap: 6px;
        }

            .pagination .page-link {
                border-radius: 10px;
                border: 1px solid #dbe1ea;
                color: #475467;
                font-weight: 700;
                font-size: 0.84rem;
                min-width: 38px;
                text-align: center;
            }

                .pagination .page-link:hover {
                    background: #f1f5f9;
                    color: #111827;
                }

            .pagination .page-item.active .page-link {
                background: #111827;
                border-color: #111827;
                color: #ffffff;
            }

        @@media (max-width: 768px) {
            .spbu-page {
                padding: 20px 16px;
            }

            .page-header {
                align-items: flex-start;
                flex-direction: column;
            }

            .header-actions {
                width: 100%;
                flex-direction: column;
            }

                .header-actions .btn,
                .header-actions label {
                    width: 100%;
                }

            .filter-panel {
                padding: 14px;
            }
        }
    </style>
}

<div class="spbu-page">

    <div class="page-header">
        <div>
            <h3 class="page-title">Data SPBU</h3>
            <div class="page-subtitle">Manajemen data SPBU, status audit, level, dan skor terkini.</div>
        </div>
        <div class="header-actions">

            <a asp-action="Create" class="btn btn-dark-blue">
                <i class="bi bi-plus-lg me-1"></i> Tambah
            </a>

            <a asp-action="Export" class="btn btn-green">
                <i class="bi bi-file-earmark-excel me-1"></i> Export
            </a>

            <a asp-action="DownloadTemplate" class="btn btn-soft">
                <i class="bi bi-download me-1"></i> Template
            </a>

            <form asp-action="Import" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <label class="btn btn-gold mb-0">
                    <i class="bi bi-upload me-1"></i> Import
                    <input type="file" name="file" hidden onchange="this.form.submit()" />
                </label>
            </form>

        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-3">
            <i class="bi bi-exclamation-triangle me-2"></i>
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-3">
            <i class="bi bi-check-circle me-2"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card-panel filter-panel">
        <form method="get" class="row g-2 align-items-center mb-0">
            <div class="col-md-7">
                <input type="text"
                       name="searchTerm"
                       value="@ViewBag.SearchTerm"
                       class="form-control"
                       placeholder="Cari SPBU, kota, atau alamat..." />
            </div>

            <div class="col-md-2">
                <select name="pageSize" class="form-select">
                    @{
                        var sizes = new[] { 10, 25, 50 };
                        foreach (var s in sizes)
                        {
                            <option value="@s" selected="@(Model.PageSize == s)">
                                @s / halaman
                            </option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-3">
                <button type="submit" class="btn btn-dark-blue w-100">
                    <i class="bi bi-search me-1"></i> Cari
                </button>
            </div>
        </form>
    </div>

    <div class="card-panel table-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th class="text-center">No</th>
                        <th>SPBU</th>
                        <th class="text-center">Rayon</th>
                        <th>Kota</th>
                        <th>Alamat</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Level</th>
                        <th class="text-center">Skor</th>
                        <th class="text-center">Audit</th>
                        <th class="text-center">Aksi</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        var no = (Model.PageNumber - 1) * Model.PageSize;

                        foreach (var item in Model.Items)
                        {
                            var statusClass = item.Status == "Active"
                            ? "status-active"
                            : item.Status == "Warning"
                            ? "status-warning"
                            : "status-danger";

                            <tr>
                                <td class="text-center td-number">@(++no)</td>

                                <td>
                                    <div class="spbu-number">@item.SpbuNo</div>
                                </td>

                                <td class="text-center">
                                    <span class="pill">@item.Region</span>
                                </td>

                                <td>@item.CityName</td>

                                <td>
                                    <div class="spbu-address">@item.Address</div>
                                </td>

                                <td class="text-center">
                                    <span class="status-badge @statusClass">
                                        <span class="status-dot"></span>
                                        @item.Status
                                    </span>
                                </td>

                                <td class="text-center">
                                    <span class="pill">@item.Level</span>
                                </td>

                                <td class="text-center">
                                    <span class="score-text">@item.AuditCurrentScore</span>
                                </td>

                                <td class="text-center">
                                    <span class="date-text">
                                        @(item.AuditCurrentTime?.ToString("dd MMM yyyy") ?? "-")
                                    </span>
                                </td>

                                <td class="text-center">
                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-action">
                                        <i class="bi bi-pencil-square me-1"></i> Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10">
                                <div class="empty-state">
                                    <div class="empty-icon">
                                        <i class="bi bi-fuel-pump"></i>
                                    </div>
                                    <div class="fw-bold text-dark mb-1">Data tidak ditemukan</div>
                                    <div>Silakan ubah kata kunci pencarian atau tambah data SPBU baru.</div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        var startPage = ((Model.PageNumber - 1) / 10) * 10 + 1;
        var endPage = Math.Min(startPage + 9, Model.TotalPages);

        <div class="pagination-wrapper">
            <div class="pagination-info">
                Page @Model.PageNumber of @Model.TotalPages
            </div>

            <nav>
                <ul class="pagination">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link"
                           href="@Url.Action("Index", new { pageNumber = Model.PageNumber - 1, pageSize = Model.PageSize, searchTerm = ViewBag.SearchTerm })">
                            Prev
                        </a>
                    </li>

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link"
                               href="@Url.Action("Index", new { pageNumber = i, pageSize = Model.PageSize, searchTerm = ViewBag.SearchTerm })">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link"
                           href="@Url.Action("Index", new { pageNumber = Model.PageNumber + 1, pageSize = Model.PageSize, searchTerm = ViewBag.SearchTerm })">
                            Next
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

@section Scripts {
    <script>
        setTimeout(() => {
            const alert = document.querySelector(".alert-success");
            if (alert) {
                bootstrap.Alert.getOrCreateInstance(alert).close();
            }
        }, 4000);
    </script>
}