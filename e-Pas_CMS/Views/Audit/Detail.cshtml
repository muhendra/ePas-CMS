              window.__fsCarouselOnSlide = function () {
                clearAllFullScreenTransforms();
              };
              carouselEl.addEventListener('slide.bs.carousel', window.__fsCarouselOnSlide);

              window.__fsCarouselOnSlid = function () {
                resetFullScreenTransform();
              };
              carouselEl.addEventListener('slid.bs.carousel', window.__fsCarouselOnSlid);

              document.removeEventListener('keydown', window.__fsCarouselKeydown);
              window.__fsCarouselKeydown = function (e) {
                if (!modalEl.classList.contains('show')) return;
                if (e.key === 'ArrowLeft') window.bsCarousel.prev();
                if (e.key === 'ArrowRight') window.bsCarousel.next();
              };
              document.addEventListener('keydown', window.__fsCarouselKeydown);

            }, 150);

          }
         else {
