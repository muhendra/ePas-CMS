                        directSum += subScore;
                        console.log("   ↪ Sub skor:", subScore);
                    });
                    skor = directSum;
                    sumAF = skor;
                    sumWeight = 1;
                    sumX = 0;
                } else {
                    skor = (sumWeight - sumX) > 0 ? (sumAF / (sumWeight - sumX)) * sumWeight : 0;
                }
            }

