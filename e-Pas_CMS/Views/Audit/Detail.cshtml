        function getActiveFullScreenMediaEl() {
          const activeItem = document.querySelector('#fullSizeMediaModalBody .carousel-item.active');
          return activeItem
            ? activeItem.querySelector('img, video')
            : document.querySelector('#fullSizeMediaModalBody img, #fullSizeMediaModalBody video');
        }

        function clearAllFullScreenTransforms() {
          document
            .querySelectorAll('#fullSizeMediaModalBody img, #fullSizeMediaModalBody video')
            .forEach(el => {
              el.style.transform = '';
              el.style.width = '';
              el.style.height = '';
            });
        }

        function getNaturalSize(el) {
          if (!el) return { w: 0, h: 0 };
          if (el.tagName === 'IMG') return { w: el.naturalWidth || 0, h: el.naturalHeight || 0 };
          if (el.tagName === 'VIDEO') return { w: el.videoWidth || 0, h: el.videoHeight || 0 };
          return { w: 0, h: 0 };
        }

        function applyFullScreenTransform() {
          const el = getActiveFullScreenMediaEl();
          const vp = document.getElementById('fullSizeMediaModalBody');
          if (!el || !vp) return;

          clearAllFullScreenTransforms();

          const { w, h } = getNaturalSize(el);
          if (!w || !h) {
            setTimeout(applyFullScreenTransform, 50);
            return;
          }

          const vw = vp.clientWidth;
          const vh = vp.clientHeight;

          const rot = ((fsRotate % 360) + 360) % 360;
          const sideways = rot === 90 || rot === 270;

          const rw = sideways ? h : w;
          const rh = sideways ? w : h;

          const fitScale = Math.min(vw / rw, vh / rh);
          const totalScale = fitScale * fsScale;

          el.style.width = w + 'px';
          el.style.height = h + 'px';
          el.style.transform = `rotate(${fsRotate}deg) scale(${totalScale})`;
        }

        function resetFullScreenTransform() {
          fsScale = 1;
          fsRotate = 0;
          applyFullScreenTransform();
        }

        function zoomIn() { fsScale += 0.2; applyFullScreenTransform(); }
        function zoomOut() { fsScale = Math.max(0.2, fsScale - 0.2); applyFullScreenTransform(); }
        function rotateLeft() { fsRotate -= 90; applyFullScreenTransform(); }
        function rotateRight() { fsRotate += 90; applyFullScreenTransform(); }

