@using e_Pas_CMS.ViewModels
@using Newtonsoft.Json
@model DetailAuditViewModel

@{
    ViewData["Title"] = "Detail Hasil Audit";
    bool isVerified = Model.Status == "VERIFIED";
    var currentUser = User.Identity?.Name;
    bool isReadonlyUser = currentUser == "usermanagement1";
    var batasTanggal = new DateTime(2025, 5, 11);
    bool hideUploadButton = Model.TanggalSubmit.HasValue && Model.TanggalSubmit.Value > batasTanggal;
    bool isSuperadmin = (ViewBag.IsSuperadmin as bool?) ?? false;
}

@Html.AntiForgeryToken()

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<!-- Header Detail -->
<h3 class="mb-4 fw-bold">Detail Hasil Audit</h3>

<!-- HEADER DETAIL -->
<div class="row g-4 mb-5 p-4 bg-light rounded shadow-sm">
    <div class="col-md-4">
        <strong class="d-block">No. Report</strong>
        <span>@Model.ReportNo</span>
    </div>
    <div class="col-md-4">
        <strong class="d-block">Nama Auditor</strong>
        <span>@Model.NamaAuditor</span>
    </div>
    <div class="col-md-4">
        <strong class="d-block">Nama Auditor 2</strong>
        <span>@Model.Auditor2</span>
    </div>
    <div class="col-md-4">
        <strong class="d-block">Tanggal Submit</strong>
        <span>@Model.TanggalSubmit?.ToString("dd/MM/yyyy, HH:mm")</span>
    </div>
    <div class="col-md-4">
        <strong class="d-block">Nomor SPBU</strong>
        <span>@Model.SpbuNo</span>
    </div>
    <div class="col-md-4">
        <strong class="d-block">Provinsi SPBU</strong>
        <span>@Model.Provinsi</span>
    </div>
    <div class="col-md-4">
        <strong class="d-block">Kabupaten/Kota SPBU</strong>
        <span>@Model.Kota</span>
    </div>
    <div class="col-md-12">
        <strong class="d-block">Alamat SPBU</strong>
        <span>@Model.Alamat</span>
    </div>
</div>

<!-- CHECKLIST AUDIT -->
@if (Model.AuditType == "Mystery Audit" || Model.AuditType == "Regular Audit" || Model.AuditType == "Basic Operational")
{
    <h4 class="mt-5 fw-bold">Checklist Audit</h4>
    <ul id="auditChecklist" class="list-unstyled">
        @foreach (var node in Model.Elements)
        {
            await RenderChecklistNode(node, 0, isVerified, isReadonlyUser, hideUploadButton);

        }
    </ul>
}

<!-- Q&Q CHECK -->
@if (Model.QqChecks != null && Model.QqChecks.Any())
{
    <h4 class="mt-5 fw-bold">Q&Q Check</h4>

    @* Toggle hanya untuk superadmin *@
    @if (isSuperadmin)
    {
        <div class="d-flex align-items-center gap-2 mt-2 mb-2">
            <div class="form-check form-switch m-0">
                <input class="form-check-input" type="checkbox" id="qqEditToggle">
                <label class="form-check-label fw-semibold" for="qqEditToggle">Edit Mode</label>
            </div>
            <span class="text-muted small" id="qqModeLabel">View Only</span>
        </div>
    }

    @* =========================
       VIEW ONLY (DEFAULT)
       ========================= *@
    <div id="qqViewOnly">
        <div class="table-responsive">
            <table class="table table-bordered table-striped mt-3">
                <thead class="table-light">
                    <tr>
                        <th>Nozzle Number</th>
                        <th>DU Make</th>
                        <th>DU Serial No</th>
                        <th>Product</th>
                        <th>Mode</th>
                        <th>Quantity Variation (Measure)</th>
                        <th>Quantity Variation (%)</th>
                        <th>Observed Density</th>
                        <th>Observed Temp</th>
                        <th>Observed Density (15°)</th>
                        <th>Reference Density (15°)</th>
                        <th>Tank Number</th>
                        <th>Density Variation</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.QqChecks)
                    {
                        var qtyVarPercent = (item.QuantityVariationWithMeasure / 20000m) * 100m; // -120 -> -0.60%

                        <tr>
                            <td>@item.NozzleNumber</td>
                            <td>@item.DuMake</td>
                            <td>@item.DuSerialNo</td>
                            <td>@item.Product</td>
                            <td>@item.Mode</td>

                            <td style="background-color:@(item.QuantityVariationWithMeasure < -60m ? "#ff0000" : "transparent");">
                                @item.QuantityVariationWithMeasure
                            </td>

                            <td style="background-color:@(qtyVarPercent < -0.3m ? "#ff0000" : qtyVarPercent > 0.3m ? "#ffff00" : "transparent");">
                                @($"{qtyVarPercent:0.00}%")
                            </td>

                            <td>@item.ObservedDensity?.ToString("0.000")</td>
                            <td>@item.ObservedTemp?.ToString("0.0")</td>
                            <td>@item.ObservedDensity15Degree?.ToString("0.000")</td>
                            <td>@item.ReferenceDensity15Degree?.ToString("0.000")</td>
                            <td>@item.TankNumber</td>
                            <td>@item.DensityVariation?.ToString("0.000")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* =========================
       EDIT MODE (superadmin only, hidden by default)
       ========================= *@
    @if (isSuperadmin)
    {
        <div id="qqEditMode" class="d-none">
            <div class="table-responsive">
                <table class="table table-bordered table-striped mt-3">
                    <thead class="table-light">
                        <tr>
                            <th>Nozzle Number</th>
                            <th>DU Make</th>
                            <th>DU Serial No</th>
                            <th>Product</th>
                            <th>Mode</th>
                            <th>Quantity Variation (Measure)</th>
                            <th>Quantity Variation (%)</th>
                            <th>Observed Density</th>
                            <th>Observed Temp</th>
                            <th>Observed Density (15°)</th>
                            <th>Reference Density (15°)</th>
                            <th>Tank Number</th>
                            <th>Density Variation</th>
                            <th style="min-width:120px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.QqChecks)
                        {
                            <tr data-qq-id="@item.Id" data-audit-id="@ViewBag.AuditId">


                                <td><input class="form-control form-control-sm qq-nozzle" value="@item.NozzleNumber" /></td>
                                <td><input class="form-control form-control-sm qq-dumake" value="@item.DuMake" /></td>
                                <td><input class="form-control form-control-sm qq-duserial" value="@item.DuSerialNo" /></td>
                                <td><input class="form-control form-control-sm qq-product" value="@item.Product" /></td>
                                <td><input class="form-control form-control-sm qq-mode" value="@item.Mode" /></td>

                                <td>
                                    <input type="number" step="0.01"
                                           class="form-control form-control-sm qq-qvmeasure"
                                           value="@item.QuantityVariationWithMeasure" />
                                </td>

                                <td>
                                    <input type="number" step="0.01"
                                           class="form-control form-control-sm qq-qvpercent"
                                           value="@item.QuantityVariationInPercentage"
                                           readonly />
                                </td>

                                <td><input type="number" step="0.001" class="form-control form-control-sm qq-obdens" value="@item.ObservedDensity" /></td>
                                <td><input type="number" step="0.1" class="form-control form-control-sm qq-obtemp" value="@item.ObservedTemp" /></td>
                                <td><input type="number" step="0.001" class="form-control form-control-sm qq-obdens15" value="@item.ObservedDensity15Degree" /></td>
                                <td><input type="number" step="0.001" class="form-control form-control-sm qq-refdens15" value="@item.ReferenceDensity15Degree" /></td>
                                <td><input type="number" class="form-control form-control-sm qq-tank" value="@item.TankNumber" /></td>
                                <td><input type="number" step="0.001" class="form-control form-control-sm qq-densvar" value="@item.DensityVariation" readonly /></td>

                                <td>
                                    <button type="button" class="btn btn-sm btn-success btn-save-qq">Save</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="text-muted small mt-2">
                * Qty Variation (%) akan otomatis dihitung dari Qty Variation (Measure)
            </div>
        </div>
    }
}

<!-- CATATAN AUDIT -->
@if (Model.AuditType == "Mystery Audit" || Model.AuditType == "Mystery Guest")
{
    @if (!string.IsNullOrEmpty(Model.Notes) || (Model.MediaNotes != null && Model.MediaNotes.Any()))
    {
        <div class="accordion mt-4 mb-4" id="mysteryAuditAccordion">
            <div class="accordion-item shadow-sm">
                <h2 class="accordion-header" id="mysteryAuditHeading">
                    <button class="accordion-button collapsed d-flex justify-content-between align-items-center" type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#mysteryAuditCollapse"
                            aria-expanded="false"
                            aria-controls="mysteryAuditCollapse">
                        <div class="d-flex flex-column">
                            <span class="h5 fw-bold mb-0">
                                @(Model.AuditType == "Mystery Guest" ? "Mystery Guest" : "Mystery Audit")
                            </span>
                            <small class="text-muted fst-italic">Klik untuk detail</small>
                        </div>
                    </button>
                </h2>
                <div id="mysteryAuditCollapse" class="accordion-collapse collapse"
                     aria-labelledby="mysteryAuditHeading"
                     data-bs-parent="#mysteryAuditAccordion">
                    <div class="accordion-body">

                        @* Teks Catatan *@
                        @if (!string.IsNullOrEmpty(Model.Notes))
                        {
                            <div class="border rounded p-3 bg-light mb-4">
                                @Model.Notes
                            </div>
                        }

                        @* Gambar/Video Catatan *@
                        @if (Model.MediaNotes != null && Model.MediaNotes.Any())
                        {
                            <div class="row row-cols-1 row-cols-md-2 g-4">
                                @foreach (var media in Model.MediaNotes)
                                {
                                    <div class="col d-flex justify-content-center">
                                        <div class="card h-100 p-3 d-flex align-items-center justify-content-center">
                                            @if (media.MediaType?.ToUpper() == "VIDEO" || media.MediaPath.EndsWith(".mp4", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <video controls class="rounded shadow-sm" style="max-height:800px; width:auto; max-width:100%;">
                                                    <source src="@media.MediaPath" type="video/mp4" />
                                                    Your browser does not support the video tag.
                                                </video>
                                            }
                                            else
                                            {
                                                <img src="@media.MediaPath"
                                                     alt="Foto Catatan Audit"
                                                     class="rounded shadow-sm"
                                                     style="max-height:800px; width:auto; max-width:100%;" />
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>
    }
}


<!-- BERITA ACARA -->
@if (Model.Status != "VERIFIED" && currentUser != "usermanagement1")
{
    <div class="card p-4 mb-5 shadow-sm mt-5">
        <h4 class="fw-bold mb-4">Berita Acara</h4>

        @if (!isVerified && !isReadonlyUser)
        {
            <form method="post" asp-action="UpdateBeritaAcaraText" asp-route-id="@ViewBag.AuditId">
                <div class="mb-3">
                    <label for="BeritaAcaraText" class="form-label fw-semibold">Isi Berita Acara</label>
                    @* <textarea id="BeritaAcaraText" name="Notes" class="form-control" rows="5" required>@Model.Notes</textarea> *@
                    <textarea id="BeritaAcaraText"
                      name="Notes"
                      class="form-control textarea-modern"
                      rows="4"
                      placeholder="Tulis komentar / berita acara..."
                      required>@Model.Notes</textarea>
                </div>
                <button type="submit" class="btn btn-primary rounded-pill px-4">Ubah Berita Acara</button>
            </form>
        }
        else if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="mb-3">
                <label class="fw-semibold">Isi Catatan</label>
                <div class="border rounded p-3 bg-light" style="white-space: pre-line;">
                    @Model.Notes
                </div>
            </div>
        }

        <hr class="my-4" />

        @if (!isVerified && !isReadonlyUser)
        {
            <form method="post"
                  asp-action="UploadBeritaAcaraMedia"
                  asp-controller="Audit"
                  asp-route-auditId="@ViewBag.AuditId"
                  enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="beritaAcaraFile" class="form-label fw-semibold">Upload Dokumen Tambahan Berita Acara</label>
                    <input type="file" class="form-control" id="beritaAcaraFile" name="file" required />
                </div>
                <button type="submit" class="btn btn-secondary rounded-pill px-4">Upload Berita Acara</button>
            </form>

        }

        @if (Model.FinalDocuments?.Any() ?? false)
        {
            <div class="mb-2 fw-semibold mt-4">Dokumen Lampiran</div>
            <ul class="list-unstyled">
                <li class="mb-2">
                    <i class="bi bi-file-earmark-image text-primary"></i>
                    <button type="button"
                            class="btn btn-link text-decoration-none p-0"
                            onclick='showFinalMediaPopup(@Html.Raw(JsonConvert.SerializeObject(Model.FinalDocuments)))'>
                        Lihat Lampiran
                    </button>
                </li>
            </ul>
        }
    </div>
}
else if (!string.IsNullOrEmpty(Model.Notes) || (Model.FinalDocuments != null && Model.FinalDocuments.Any()))
{
    <div class="card p-4 mb-5 shadow-sm mt-5">
        <h4 class="fw-bold mb-4">Berita Acara</h4>

        <div class="mb-3">
            <label class="fw-semibold">Isi Catatan</label>
            <div class="border rounded p-3 bg-light">
                @Model.Notes
            </div>
        </div>

        @if (Model.FinalDocuments?.Any() ?? false)
        {
            <div class="mb-2 fw-semibold mt-4">Bukti Dokumen/Foto Berita Acara</div>
            <ul class="list-unstyled">
                <li class="mb-2">
                    <i class="bi bi-file-earmark-image text-primary"></i>
                    <button type="button"
                            class="btn btn-link text-decoration-none p-0"
                            onclick='showFinalMediaPopup(@Html.Raw(JsonConvert.SerializeObject(Model.FinalDocuments)))'>
                        Lihat Lampiran
                    </button>
                </li>
            </ul>
        }
    </div>
}

<div class="d-flex align-items-center justify-content-between mb-3 p-3 rounded"
     style="background: linear-gradient(90deg,#ffb300,#ff9800); color:white;">

    <div class="fw-semibold">
        ⏱️ Waktu Kecepatan Verifikasi
    </div>

    <div id="auditTimer"
         class="bg-white text-danger fw-bold px-3 py-1 rounded"
         style="font-size:18px;">
        00 : 00 : 00
    </div>
</div>

<div class="text-end mt-5 d-flex justify-content-end gap-2 flex-wrap">

    <a href="/Report/PreviewDetail/@ViewBag.AuditId"
       class="btn btn-outline-dark bg-light text-dark rounded-pill px-4 py-2 border border-dark-subtle">
        Preview report
    </a>

    @if ((Model.Status != null && Model.Status.ToUpper() != "VERIFIED") && currentUser != "usermanagement1")
    {
        <button class="btn btn-primary rounded-pill px-4 py-2" data-bs-toggle="modal" data-bs-target="#confirmModal">
            Setujui Laporan Audit
        </button>
    }
    else
    {
        <a asp-action="Index" class="btn btn-secondary rounded-pill px-4 py-2">
            Back
        </a>
    }

</div>

<!-- Modal Konfirmasi -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Konfirmasi Persetujuan</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
            </div>
            <div class="modal-body">
                Apakah Anda yakin ingin menyetujui laporan audit ini?
            </div>
            <div class="modal-footer">
                <form method="post" asp-action="Approve" asp-route-id="@Context.Request.RouteValues["id"]">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                    <button type="submit" class="btn btn-primary">Ya, Setujui</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Media -->
<div class="modal fade" id="mediaModal" tabindex="-1" aria-labelledby="mediaModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="mediaModalLabel">Dokumentasi Foto / Video</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
            </div>
            <div class="modal-body" id="mediaModalBody">
                <!-- Media will be inserted here -->
            </div>
        </div>
    </div>
</div>

<!-- Modal Full Size Media -->
<div class="modal fade" id="fullSizeMediaModal" tabindex="-1" aria-labelledby="fullSizeMediaModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content">
            <div class="modal-header">
                <!-- ✅ TOOLBAR (ADD) -->
                <div class="media-toolbar d-flex gap-2 align-items-center">
                    <button type="button" class="btn btn-sm btn-light" id="btnZoomOut" title="Zoom Out">
                        <i class="bi bi-zoom-out"></i>
                    </button>
                    <button type="button" class="btn btn-sm btn-light" id="btnZoomIn" title="Zoom In">
                        <i class="bi bi-zoom-in"></i>
                    </button>

                    <div class="vr bg-light opacity-75"></div>

                    <button type="button" class="btn btn-sm btn-light" id="btnRotateLeft" title="Rotate Left">
                        <i class="bi bi-arrow-counterclockwise"></i>
                    </button>
                    <button type="button" class="btn btn-sm btn-light" id="btnRotateRight" title="Rotate Right">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>

                    <div class="vr bg-light opacity-75"></div>

                    <button type="button" class="btn btn-sm btn-warning" id="btnResetTransform" title="Reset">
                        <i class="bi bi-arrow-repeat"></i>
                    </button>
                    <button type="button" class="btn btn-sm btn-success" id="btnSaveRotate" title="Save Rotate">
                        <i class="bi bi-save"></i>
                    </button>

                </div>

                <!-- ✅ EXISTING (KEEP) -->
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Tutup"></button>
            </div>
            <div class="modal-body p-0 position-relative" id="fullSizeMediaModalBody">
                <!-- Full size media will be inserted here -->
            </div>
            <div class="modal-footer justify-content-end">
                <button type="button" class="btn btn-primary" id="useMediaBtn" style="display: none;">
                    Gunakan media ini
                </button>
            </div>
        </div>
    </div>
</div>


@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <style>
        a.btn.btn-outline-dark:hover,
        a.btn.btn-outline-dark:focus,
        a.btn.btn-outline-dark:active {
            background-color: #f8f9fa !important;
            color: #000 !important;
            border-color: #212529 !important;
        }

        .card-header .btn-sm {
            min-width: 70px;
        }

        .card-header .option-group .btn {
            min-width: 60px;
            text-align: center;
        }

        .rotate-arrow {
            transition: transform .3s ease;
        }

            .rotate-arrow.rotate {
                transform: rotate(90deg);
            }

        .option-btn:hover {
            background-color: #e0f2f1 !important;
            border-color: #10b981;
            color: #0f766e;
        }

        .option-btn.active, .option-btn.active:hover {
            background-color: #059669 !important;
            color: #fff;
        }

        .modal {
            outline: none !important;
        }

        /* ==========================
                           MEDIA MODAL (Gallery)
                           ========================== */
        #mediaModal .modal-dialog {
            max-width: 95vw;
            margin: 1.75rem auto;
            width: 95vw;
        }

        #mediaModal .modal-content {
            background-color: #f8f9fa;
            width: 100%;
            max-width: 100%;
        }

        #mediaModal .modal-body {
            padding: 0.3rem;
            max-height: 90vh;
            overflow-y: auto;
            overflow-x: hidden;
            width: 100%;
            max-width: 100%;
        }

        #mediaModal .input-group {
            max-width: 100%;
            margin-bottom: 0.5rem;
        }

        #mediaModal .pagination {
            flex-wrap: wrap;
            justify-content: center;
            margin: 0.5rem 0;
        }

            #mediaModal .pagination .page-item {
                margin: 0.1rem;
            }

        /* Gallery grid styles */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            grid-auto-rows: min-content;
            gap: 0.3rem;
            padding: 0.3rem;
            width: 100%;
            max-width: 100%;
            margin: 0;
        }

            .gallery-grid .col {
                width: 100%;
                padding: 0;
                min-width: 0;
                height: fit-content;
            }

            .gallery-grid .card {
                margin: 0;
                border: 1px solid rgba(0,0,0,0.1);
                transform: scale(0.97);
                transform-origin: center;
                height: fit-content;
                width: 100%;
                min-width: 0;
            }

            .gallery-grid .card-body {
                padding: 0.12rem;
                display: flex;
                flex-direction: column;
                height: fit-content;
                min-width: 0;
            }

            .gallery-grid .media-container {
                flex: 0 0 120px;
                min-height: 0;
                position: relative;
                width: 100%;
                height: 120px;
                min-width: 0;
            }

                .gallery-grid .media-container img,
                .gallery-grid .media-container video {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                    border-radius: 0.25rem;
                }

            .gallery-grid .text-truncate.small {
                flex: 0 0 auto;
                font-size: 0.65rem;
                line-height: 1.1;
                margin-top: 0.12rem;
                padding: 0 0.15rem;
                color: #666;
                text-align: center;
                display: block;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

        /* ==========================
                           FULLSCREEN MODAL (Viewer)
                           ========================== */
        #fullSizeMediaModal .modal-dialog {
            margin: 0;
            max-width: 100%;
            height: 100vh;
        }

        #fullSizeMediaModal .modal-content {
            height: 100vh;
            background-color: rgba(0, 0, 0, 0.9);
            border: none;
            border-radius: 0;
        }

        #fullSizeMediaModal .modal-header {
            position: relative;
            z-index: 1060;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: .75rem 1rem;
            border: none;
        }

        #fullSizeMediaModal .modal-body {
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        #fullSizeMediaModal .modal-footer {
            position: absolute;
            bottom: 0;
            right: 0;
            z-index: 1050;
            border: none;
            padding: 1rem;
            background-color: transparent;
        }

        #fullSizeMediaModal .btn-close {
            position: absolute;
            right: 1rem;
            top: 1rem;
            z-index: 1050;
            background-color: white;
            opacity: 0.8;
        }

            #fullSizeMediaModal .btn-close:hover {
                opacity: 1;
            }

        #fullSizeMediaModal .btn-primary {
