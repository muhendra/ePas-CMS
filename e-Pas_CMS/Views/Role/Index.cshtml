@using e_Pas_CMS.ViewModels
@model RoleAuditorIndexViewModel
@Html.AntiForgeryToken()

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    int totalPages = Model.TotalPages;
    int currentPage = Model.CurrentPage;
    int windowSize = 10;

    int currentWindow = (int)Math.Ceiling((double)currentPage / windowSize);
    int startPage = (currentWindow - 1) * windowSize + 1;
    int endPage = Math.Min(startPage + windowSize - 1, totalPages);

    int rowNumber = (Model.CurrentPage - 1) * 10 + 1;
}

<style>
    body {
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f4f6f9;
        color: #1f2937;
    }

    .user-page {
        padding: 28px 32px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 22px;
        gap: 16px;
    }

    .page-title {
        margin: 0;
        font-size: 1.35rem;
        font-weight: 700;
        color: #111827;
        letter-spacing: -0.02em;
    }

    .page-subtitle {
        margin-top: 4px;
        color: #6b7280;
        font-size: 0.88rem;
    }

    .card-panel {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
        overflow: hidden;
    }

    .filter-panel {
        padding: 18px;
        margin-bottom: 20px;
    }

    .form-control {
        border-radius: 12px;
        border: 1px solid #dbe1ea;
        padding: 10px 14px;
        font-size: 0.9rem;
        color: #111827;
        background: #ffffff;
    }

        .form-control::placeholder {
            color: #9ca3af;
        }

        .form-control:focus {
            border-color: #111827;
            box-shadow: 0 0 0 4px rgba(17, 24, 39, 0.08);
        }

    .btn {
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.86rem;
        padding: 9px 14px;
    }

    .btn-dark-blue {
        background: #111827;
        border-color: #111827;
        color: #ffffff;
    }

        .btn-dark-blue:hover {
            background: #1e3a8a;
            border-color: #1e3a8a;
            color: #ffffff;
        }

    .btn-soft {
        background: #f9fafb;
        border: 1px solid #dbe1ea;
        color: #374151;
    }

        .btn-soft:hover {
            background: #eef2f7;
            border-color: #cbd5e1;
            color: #111827;
        }

    .table-card {
        padding: 0;
    }

    .table {
        margin-bottom: 0;
        font-size: 0.9rem;
    }

        .table thead th {
            background: #f8fafc;
            color: #64748b;
            font-size: 0.73rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            border-bottom: 1px solid #e5e7eb;
            padding: 15px 16px;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 16px;
            border-bottom: 1px solid #edf0f4;
            color: #374151;
            vertical-align: middle;
        }

        .table tbody tr:last-child td {
            border-bottom: none;
        }

        .table tbody tr:hover td {
            background: #fafafa;
        }

    .td-number {
        color: #94a3b8;
        font-weight: 600;
        width: 70px;
    }

    .role-name {
        font-weight: 700;
        color: #111827;
    }

    .user-name {
        font-weight: 700;
        color: #111827;
    }

    .user-meta {
        color: #6b7280;
        font-size: 0.82rem;
        margin-top: 2px;
    }

    .region-pill {
        display: inline-flex;
        align-items: center;
        padding: 6px 11px;
        border-radius: 999px;
        background: #f1f5f9;
        color: #334155;
        font-weight: 600;
        font-size: 0.8rem;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 700;
    }

    .status-active {
        background: #ecfdf3;
        color: #027a48;
    }

    .status-inactive {
        background: #f3f4f6;
        color: #667085;
    }

    .status-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: currentColor;
    }

    .action-group {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        flex-wrap: nowrap;
    }

    .btn-action {
        background: #ffffff;
        border: 1px solid #dbe1ea;
        color: #344054;
        padding: 7px 11px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.82rem;
        white-space: nowrap;
    }

        .btn-action:hover {
            background: #111827;
            border-color: #111827;
            color: #ffffff;
        }

    .btn-action-danger {
        background: #ffffff;
        border: 1px solid #fecaca;
        color: #dc2626;
        padding: 7px 11px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.82rem;
        white-space: nowrap;
    }

        .btn-action-danger:hover {
            background: #dc2626;
            border-color: #dc2626;
            color: #ffffff;
        }

    .empty-state {
        padding: 44px 20px;
        text-align: center;
        color: #6b7280;
    }

    .empty-icon {
        width: 48px;
        height: 48px;
        margin: 0 auto 12px;
        border-radius: 14px;
        background: #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #9ca3af;
        font-size: 1.4rem;
    }

    .pagination-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 18px;
        gap: 12px;
        flex-wrap: wrap;
    }

    .pagination-info {
        color: #6b7280;
        font-size: 0.85rem;
    }

    .pagination {
        margin-bottom: 0;
        gap: 6px;
    }

        .pagination .page-link {
            border-radius: 10px;
            border: 1px solid #dbe1ea;
            color: #475467;
            font-weight: 600;
            font-size: 0.84rem;
            min-width: 38px;
            text-align: center;
        }

            .pagination .page-link:hover {
                background: #f1f5f9;
                color: #111827;
            }

        .pagination .page-item.active .page-link {
            background: #111827;
            border-color: #111827;
            color: #ffffff;
        }

    .alert {
        border-radius: 14px;
        border: 1px solid #bbf7d0;
        background: #f0fdf4;
        color: #166534;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .user-page {
            padding: 20px 16px;
        }

        .page-header {
            align-items: flex-start;
            flex-direction: column;
        }

        .filter-panel {
            padding: 14px;
        }

        .action-group {
            flex-direction: column;
            align-items: stretch;
        }

        .btn-action,
        .btn-action-danger {
            width: 100%;
        }
    }
</style>

<div class="user-page">

    <div class="page-header">
        <div>
            <h3 class="page-title">User Management</h3>
            <div class="page-subtitle">
                Kelola user auditor, role, region, dan status akses secara terstruktur.
            </div>
        </div>

        <a href="@Url.Action("Add", "Role")" class="btn btn-dark-blue">
            <i class="bi bi-plus-lg me-1"></i> Tambah User
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-dismissible fade show mb-3" role="alert">
            <i class="bi bi-check-circle me-2"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card-panel filter-panel">
        <form method="get" class="row g-2 align-items-center mb-0">
            <div class="col-md-5">
                <input type="text"
                       name="searchTerm"
                       value="@Model.SearchTerm"
                       class="form-control"
                       placeholder="Cari role, nama user, username, atau region..." />
            </div>

            <div class="col-auto">
                <button type="submit" class="btn btn-dark-blue">
                    <i class="bi bi-search me-1"></i> Cari
                </button>
            </div>

            <div class="col-auto">
                <a href="@Url.Action("Index", "Role")" class="btn btn-soft">
                    Reset
                </a>
            </div>
        </form>
    </div>

    <div class="card-panel table-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr class="align-middle">
                        <th class="text-center">No</th>
                        <th>Nama Role</th>
                        <th>Nama</th>
                        <th>Username</th>
                        <th class="text-center">Region</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="text-center td-number">@rowNumber</td>

                                <td>
                                    <div class="role-name">@item.NamaRole</div>
                                    <div class="user-meta">User role access</div>
                                </td>

                                <td>
                                    <div class="user-name">@item.Auditor</div>
                                </td>

                                <td>
                                    <div>@item.Username</div>
                                </td>

                                <td class="text-center">
                                    <span class="region-pill">@item.Region</span>
                                </td>

                                <td class="text-center">
                                    <span class="status-badge @(item.IsActive ? "status-active" : "status-inactive")">
                                        <span class="status-dot"></span>
                                        @item.Status
                                    </span>
                                </td>

                                <td class="text-center">
                                    <div class="action-group">
                                        <a href="@Url.Action("Detail", "Role", new { id = item.Id })"
                                           class="btn btn-action">
                                            <i class="bi bi-eye me-1"></i> Detail
                                        </a>

                                        <a href="@Url.Action("Edit", "Role", new { id = item.Id })"
                                           class="btn btn-action">
                                            <i class="bi bi-pencil-square me-1"></i> Edit
                                        </a>

                                        <button type="button"
                                                class="btn btn-action-danger btnDelete"
                                                data-id="@item.Id">
                                            <i class="bi bi-trash me-1"></i> Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>

                            rowNumber++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7">
                                <div class="empty-state">
                                    <div class="empty-icon">
                                        <i class="bi bi-person-x"></i>
                                    </div>
                                    <div class="fw-bold text-dark mb-1">Data tidak ditemukan</div>
                                    <div>Silakan ubah kata kunci pencarian atau reset filter.</div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="pagination-wrapper">
            <div class="pagination-info">
                Page @currentPage of @totalPages
            </div>

            <nav>
                <ul class="pagination">
                    @if (startPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               href="@Url.Action("Index", new { pageNumber = startPage - 1, searchTerm = Model.SearchTerm })">
                                Prev
                            </a>
                        </li>
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link"
                               href="@Url.Action("Index", new { pageNumber = i, searchTerm = Model.SearchTerm })">
                                @i
                            </a>
                        </li>
                    }

                    @if (endPage < totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               href="@Url.Action("Index", new { pageNumber = endPage + 1, searchTerm = Model.SearchTerm })">
                                Next
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        setTimeout(function () {
            var alert = document.querySelector('.alert');
            if (alert) {
                var bsAlert = bootstrap.Alert.getOrCreateInstance(alert);
                bsAlert.close();
            }
        }, 5000);

        document.querySelectorAll('.btnDelete').forEach(btn => {
            btn.addEventListener('click', function () {
                var userId = this.getAttribute('data-id');
                var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                Swal.fire({
                    title: 'Nonaktifkan User?',
                    text: 'User ini akan dinonaktifkan dari sistem.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#111827',
                    cancelButtonColor: '#6b7280',
                    confirmButtonText: 'Ya, Nonaktifkan',
                    cancelButtonText: 'Batal',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        var formData = new FormData();
                        formData.append('id', userId);
                        formData.append('__RequestVerificationToken', token);

                        fetch('@Url.Action("Delete", "Role")', {
                            method: 'POST',
                            body: formData
                        })
                        .then(response => {
                            if (response.ok) {
                                Swal.fire({
                                    title: 'Berhasil',
                                    text: 'User telah dinonaktifkan.',
                                    icon: 'success',
                                    confirmButtonColor: '#111827'
                                }).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire({
                                    title: 'Gagal',
                                    text: 'Terjadi kesalahan saat menonaktifkan user.',
                                    icon: 'error',
                                    confirmButtonColor: '#111827'
                                });
                            }
                        })
                        .catch(() => {
                            Swal.fire({
                                title: 'Gagal',
                                text: 'Tidak dapat terhubung ke server.',
                                icon: 'error',
                                confirmButtonColor: '#111827'
                            });
                        });
                    }
                });
            });
        });
    </script>
}