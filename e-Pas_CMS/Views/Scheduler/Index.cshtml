@using e_Pas_CMS.ViewModels
@using System.Globalization
@model SchedulerIndexViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    int totalPages = Model.TotalPages;
    int currentPage = Model.CurrentPage;
    int windowSize = 10;

    int currentWindow = (int)Math.Ceiling((double)currentPage / windowSize);
    int startPage = (currentWindow - 1) * windowSize + 1;
    int endPage = Math.Min(startPage + windowSize - 1, totalPages);

    var selectedStatus = ViewBag.FilterStatus as string;
    var selectedSbm = ViewBag.FilterSbm as string;
    var selectedMonth = ViewBag.FilterMonth as int?;
    var selectedYear = ViewBag.FilterYear as int?;

    var selectedAuditor = ViewBag.FilterAuditor as string;
    var selectedDate = ViewBag.FilterDate as DateTime?;
    var selectedAuditType = ViewBag.FilterAuditType as string;
    var selectedAuditLevel = ViewBag.FilterAuditLevel as string;

    var currentYear = DateTime.Now.Year;

    var statusOptions = ViewBag.StatusOptions as Dictionary<string, string>
        ?? new Dictionary<string, string>
        {
            { "DRAFT", "Draft" },
            { "NOT_STARTED", "Belum Dimulai" },
            { "IN_PROGRESS_INPUT", "Sedang Berlangsung (Input)" },
            { "IN_PROGRESS_SUBMIT", "Sedang Berlangsung (Submit)" },
            { "UNDER_REVIEW", "Sedang Ditinjau" },
            { "VERIFIED", "Terverifikasi" }
        };

    var sbmOptions = ViewBag.SbmOptions as List<string> ?? new List<string>();
    var auditorOptions = ViewBag.AuditorOptions as List<string> ?? new List<string>();
    var auditTypeOptions = ViewBag.AuditTypeOptions as List<string> ?? new List<string>();
    var auditLevelOptions = ViewBag.AuditLevelOptions as List<string> ?? new List<string>();
}

<style>
    body {
        font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f4f6f9;
        color: #1f2937;
    }

    .scheduler-page {
        padding: 28px 32px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 22px;
    }

    .page-title {
        margin: 0;
        font-size: 1.35rem;
        font-weight: 700;
        color: #111827;
        letter-spacing: -0.02em;
    }

    .page-subtitle {
        margin-top: 4px;
        color: #6b7280;
        font-size: 0.88rem;
    }

    .header-actions {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .card-panel {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
        overflow: hidden;
    }

    .filter-panel {
        padding: 18px;
        margin-bottom: 20px;
    }

    .filter-form {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
    }

    .filter-search {
        min-width: 240px;
        flex: 1 1 240px;
    }

    .filter-item {
        min-width: 170px;
    }

    .filter-item-wide {
        min-width: 220px;
    }

    .filter-item-small {
        min-width: 140px;
    }

    .form-control,
    .form-select {
        border-radius: 12px;
        border: 1px solid #dbe1ea;
        padding: 10px 14px;
        font-size: 0.9rem;
        color: #111827;
        background: #ffffff;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: #111827;
            box-shadow: 0 0 0 4px rgba(17, 24, 39, 0.08);
        }

    .btn {
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.86rem;
        padding: 9px 14px;
    }

    .btn-dark-blue {
        background: #111827;
        border-color: #111827;
        color: #ffffff;
    }

        .btn-dark-blue:hover {
            background: #1e3a8a;
            border-color: #1e3a8a;
            color: #ffffff;
        }

    .btn-soft {
        background: #f9fafb;
        border: 1px solid #dbe1ea;
        color: #374151;
    }

        .btn-soft:hover {
            background: #eef2f7;
            border-color: #cbd5e1;
            color: #111827;
        }

    .btn-save {
        background: #027a48;
        border-color: #027a48;
        color: #ffffff;
    }

        .btn-save:hover {
            background: #05603a;
            border-color: #05603a;
            color: #ffffff;
        }

    .dirty-info {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #fffaeb;
        color: #b54708;
        border: 1px solid #fedf89;
        padding: 8px 12px;
        border-radius: 999px;
        font-size: 0.83rem;
        font-weight: 700;
        margin-bottom: 12px;
    }

    .table-card {
        padding: 0;
    }

    .table {
        margin-bottom: 0;
        font-size: 0.9rem;
    }

        .table thead th {
            background: #f8fafc;
            color: #64748b;
            font-size: 0.73rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            border-bottom: 1px solid #e5e7eb;
            padding: 15px 16px;
            white-space: nowrap;
        }

        .table tbody td {
            padding: 16px;
            border-bottom: 1px solid #edf0f4;
            color: #374151;
            vertical-align: middle;
        }

        .table tbody tr:last-child td {
            border-bottom: none;
        }

        .table tbody tr:hover td {
            background: #fafafa;
        }

        .table tbody tr.table-warning td {
            background: #fffbeb !important;
        }

    .td-number {
        color: #94a3b8;
        font-weight: 700;
        width: 70px;
    }

    .status-select {
        min-width: 190px;
        font-weight: 700;
        font-size: 0.82rem;
    }

    .auditor-name {
        font-weight: 700;
        color: #111827;
    }

    .date-text {
        font-weight: 700;
        color: #344054;
    }

    .audit-pill {
        display: inline-flex;
        align-items: center;
        padding: 6px 11px;
        border-radius: 999px;
        background: #f1f5f9;
        color: #334155;
        font-weight: 700;
        font-size: 0.8rem;
        white-space: nowrap;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        padding: 7px 12px;
        border-radius: 999px;
        background: #eef2ff;
        color: #3730a3;
        font-weight: 800;
        font-size: 0.78rem;
        white-space: nowrap;
    }

    .spbu-text {
        font-weight: 700;
        color: #111827;
        white-space: nowrap;
    }

    .note-input {
        min-width: 220px;
        font-size: 0.84rem;
    }

    .btn-action {
        background: #ffffff;
        border: 1px solid #dbe1ea;
        color: #344054;
        padding: 7px 11px;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.82rem;
        white-space: nowrap;
    }

        .btn-action:hover {
            background: #111827;
            border-color: #111827;
            color: #ffffff;
        }

    .empty-state {
        padding: 44px 20px;
        text-align: center;
        color: #6b7280;
    }

    .empty-icon {
        width: 48px;
        height: 48px;
        margin: 0 auto 12px;
        border-radius: 14px;
        background: #f3f4f6;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #9ca3af;
        font-size: 1.4rem;
    }

    .pagination-wrapper {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 18px;
        gap: 12px;
        flex-wrap: wrap;
    }

    .pagination-info {
        color: #6b7280;
        font-size: 0.85rem;
    }

    .pagination {
        margin-bottom: 0;
        gap: 6px;
    }

        .pagination .page-link {
            border-radius: 10px;
            border: 1px solid #dbe1ea;
            color: #475467;
            font-weight: 700;
            font-size: 0.84rem;
            min-width: 38px;
            text-align: center;
        }

            .pagination .page-link:hover {
                background: #f1f5f9;
                color: #111827;
            }

        .pagination .page-item.active .page-link {
            background: #111827;
            border-color: #111827;
            color: #ffffff;
        }

    @@media (max-width: 768px) {
        .scheduler-page {
            padding: 20px 16px;
        }

        .page-header {
            align-items: flex-start;
            flex-direction: column;
        }

        .header-actions {
            width: 100%;
            flex-direction: column;
        }

            .header-actions .btn {
                width: 100%;
            }

        .filter-panel {
            padding: 14px;
        }

        .filter-form {
            flex-direction: column;
            align-items: stretch;
        }

        .filter-search,
        .filter-item,
        .filter-item-wide,
        .filter-item-small,
        .filter-form .btn,
        .filter-form a.btn {
            width: 100%;
            min-width: 100%;
        }
    }
</style>

<div class="scheduler-page">

    <div class="page-header">
        <div>
            <h3 class="page-title">Penjadwalan Audit</h3>
            <div class="page-subtitle">
                Kelola jadwal audit, status, auditor, SPBU, SBM, dan catatan dalam satu halaman.
            </div>
        </div>

        <div class="header-actions">
            <button id="btnSaveChanges" class="btn btn-save d-none">
                <i class="bi bi-save me-1"></i> Save Changes
            </button>

            <a href="@Url.Action("Add", "Scheduler")" class="btn btn-dark-blue">
                <i class="bi bi-plus-lg me-1"></i> Add Scheduler
            </a>
        </div>
    </div>

    <div id="dirtyInfo" class="dirty-info d-none">
        <i class="bi bi-exclamation-circle"></i>
        <span></span>
    </div>

    <div class="card-panel filter-panel">
        <form method="get" class="filter-form mb-0" id="filterForm">
            <div class="filter-search">
                <input type="text"
                       name="searchTerm"
                       value="@Model.SearchTerm"
                       class="form-control"
                       placeholder="Cari SPBU atau Auditor..." />
            </div>

            <div class="filter-item-wide">
                <input type="text"
                       name="filterAuditor"
                       value="@selectedAuditor"
                       class="form-control"
                       placeholder="Nama Auditor..."
                       list="auditorSuggestions" />

                <datalist id="auditorSuggestions">
                    @foreach (var auditor in auditorOptions)
                    {
                        <option value="@auditor"></option>
                    }
                </datalist>
            </div>

            <div class="filter-item">
                <input type="date"
                       name="filterDate"
                       value="@(selectedDate.HasValue ? selectedDate.Value.ToString("yyyy-MM-dd") : "")"
                       class="form-control" />
            </div>

            <div class="filter-item-wide">
                <select name="filterStatus" class="form-select auto-submit-filter">
                    <option value="">Semua Status</option>
                    @foreach (var status in statusOptions)
                    {
                        <option value="@status.Key" selected="@(selectedStatus == status.Key)">
                            @status.Value
                        </option>
                    }
                </select>
            </div>

            <div class="filter-item">
                <select name="filterAuditType" class="form-select auto-submit-filter">
                    <option value="">Semua Tipe Audit</option>
                    @foreach (var type in auditTypeOptions)
                    {
                        <option value="@type" selected="@(selectedAuditType == type)">
                            @type
                        </option>
                    }
                </select>
            </div>

            <div class="filter-item">
                <select name="filterAuditLevel" class="form-select auto-submit-filter">
                    <option value="">Semua Level Audit</option>
                    @foreach (var level in auditLevelOptions)
                    {
                        <option value="@level" selected="@(selectedAuditLevel == level)">
                            @level
                        </option>
                    }
                </select>
            </div>

            <div class="filter-item">
                <select name="filterSbm" class="form-select auto-submit-filter">
                    <option value="">Semua SBM</option>
                    @foreach (var sbm in sbmOptions)
                    {
                        <option value="@sbm" selected="@(selectedSbm == sbm)">
                            @sbm
                        </option>
                    }
                </select>
            </div>

            <div class="filter-item">
                <select name="filterMonth" class="form-select auto-submit-filter">
                    <option value="">Semua Bulan</option>
                    @for (int m = 1; m <= 12; m++)
                    {
                        var monthName = CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m);
                        <option value="@m" selected="@(selectedMonth == m)">
                            @monthName
                        </option>
                    }
                </select>
            </div>

            <div class="filter-item-small">
                <select name="filterYear" class="form-select auto-submit-filter">
                    <option value="">Semua Tahun</option>
                    @for (int y = currentYear + 1; y >= currentYear - 5; y--)
                    {
                        <option value="@y" selected="@(selectedYear == y)">
                            @y
                        </option>
                    }
                </select>
            </div>

            <div>
                <button type="submit" class="btn btn-dark-blue">
                    <i class="bi bi-search me-1"></i> Cari
                </button>
            </div>

            <div>
                <a href="@Url.Action("Index", "Scheduler")" class="btn btn-soft">
                    Reset
                </a>
            </div>
        </form>
    </div>

    <div class="card-panel table-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th class="text-center">No</th>
                        <th class="text-center">Status</th>
                        <th>Auditor</th>
                        <th class="text-center">Tanggal</th>
                        <th class="text-center">Tipe</th>
                        <th class="text-center">Level</th>
                        <th class="text-center">SPBU</th>
                        <th class="text-center">SBM</th>
                        <th class="text-center">No Report</th>
                        <th>Note</th>
                        <th class="text-center">Aksi</th>
                    </tr>
                </thead>

                <tbody>
                    @{
                        int index = (Model.CurrentPage - 1) * Model.PageSize + 1;
                    }

                    @if (Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            bool canEdit = item.Status == "Draft" || item.Status == "Belum Dimulai";

                            <tr data-id="@item.Id">
                                <td class="text-center td-number">@index</td>

                                <td class="text-center">
                                    @if (canEdit)
                                    {
                                        <select class="form-select form-select-sm status-select status-dropdown">
                                            @foreach (var status in statusOptions.Where(x => x.Key == "DRAFT" || x.Key == "NOT_STARTED"))
                                            {
                                                <option value="@status.Key" selected="@(item.Status == status.Value)">
                                                    @status.Value
                                                </option>
                                            }
                                        </select>
                                    }
                                    else
                                    {
                                        <span class="status-badge">@item.Status</span>
                                    }
                                </td>

                                <td>
                                    <div class="auditor-name">@item.AppUserName</div>
                                </td>

                                <td class="text-center">
                                    <span class="date-text">@item.AuditDate.ToString("dd/MM/yyyy")</span>
                                </td>

                                <td class="text-center">
                                    <span class="audit-pill">@item.AuditType</span>
                                </td>

                                <td class="text-center">
                                    <span class="audit-pill">@item.AuditLevel</span>
                                </td>

                                <td class="text-center">
                                    <span class="spbu-text">@item.SpbuNo</span>
                                </td>

                                <td class="text-center">
                                    <span class="audit-pill">@item.SBM</span>
                                </td>

                                <td class="text-center">
                                    <span class="audit-pill">@item.ReportNo</span>
                                </td>

                                <td>
                                    <input type="text"
                                           class="form-control form-control-sm note-input"
                                           value="@item.Note"
                                           @(canEdit ? "" : "disabled") />
                                </td>

                                <td class="text-center">
                                    <a href="@Url.Action("Detail", "Scheduler", new { id = item.Id })"
                                       class="btn btn-action">
                                        <i class="bi bi-eye me-1"></i> Detail
                                    </a>
                                </td>
                            </tr>

                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="11">
                                <div class="empty-state">
                                    <div class="empty-icon">
                                        <i class="bi bi-calendar-x"></i>
                                    </div>
                                    <div class="fw-bold text-dark mb-1">Data tidak ditemukan</div>
                                    <div>Silakan ubah kata kunci pencarian atau reset filter.</div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="pagination-wrapper">
            <div class="pagination-info">
                Page @currentPage of @totalPages
            </div>

            <nav>
                <ul class="pagination">
                    @if (startPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               href="@Url.Action("Index", new {
                                   pageNumber = startPage - 1,
                                   searchTerm = Model.SearchTerm,
                                   pageSize = Model.PageSize,
                                   filterStatus = selectedStatus,
                                   filterSbm = selectedSbm,
                                   filterMonth = selectedMonth,
                                   filterYear = selectedYear,
                                   filterAuditor = selectedAuditor,
                                   filterDate = selectedDate?.ToString("yyyy-MM-dd"),
                                   filterAuditType = selectedAuditType,
                                   filterAuditLevel = selectedAuditLevel
                               })">
                                Prev
                            </a>
                        </li>
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link"
                               href="@Url.Action("Index", new {
                                   pageNumber = i,
                                   searchTerm = Model.SearchTerm,
                                   pageSize = Model.PageSize,
                                   filterStatus = selectedStatus,
                                   filterSbm = selectedSbm,
                                   filterMonth = selectedMonth,
                                   filterYear = selectedYear,
                                   filterAuditor = selectedAuditor,
                                   filterDate = selectedDate?.ToString("yyyy-MM-dd"),
                                   filterAuditType = selectedAuditType,
                                   filterAuditLevel = selectedAuditLevel
                               })">
                                @i
                            </a>
                        </li>
                    }

                    @if (endPage < totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link"
                               href="@Url.Action("Index", new {
                                   pageNumber = endPage + 1,
                                   searchTerm = Model.SearchTerm,
                                   pageSize = Model.PageSize,
                                   filterStatus = selectedStatus,
                                   filterSbm = selectedSbm,
                                   filterMonth = selectedMonth,
                                   filterYear = selectedYear,
                                   filterAuditor = selectedAuditor,
                                   filterDate = selectedDate?.ToString("yyyy-MM-dd"),
                                   filterAuditType = selectedAuditType,
                                   filterAuditLevel = selectedAuditLevel
                               })">
                                Next
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>

@section Scripts {
    <script>
        let changes = {};

        function markDirty(row, field, value) {
            const id = row.dataset.id;

            if (!changes[id]) {
                changes[id] = {};
            }

            changes[id][field] = value;
            row.classList.add('table-warning');

            updateUI();
        }

        function updateUI() {
            const count = Object.keys(changes).length;

            const btn = document.getElementById('btnSaveChanges');
            const info = document.getElementById('dirtyInfo');
            const infoText = info.querySelector('span');

            if (count > 0) {
                btn.classList.remove('d-none');
                info.classList.remove('d-none');
                infoText.innerText = count + ' data berubah';
            } else {
                btn.classList.add('d-none');
                info.classList.add('d-none');
                infoText.innerText = '';
            }
        }

        function hasUnsavedChanges() {
            return Object.keys(changes).length > 0;
        }

        function confirmLeaveWithUnsavedChanges() {
            if (hasUnsavedChanges()) {
                return confirm('Ada perubahan belum disimpan. Lanjutkan?');
            }

            return true;
        }

        document.querySelectorAll('.status-dropdown').forEach(el => {
            el.addEventListener('change', function () {
                const row = this.closest('tr');
                markDirty(row, 'status', this.value);
            });
        });

        document.querySelectorAll('.note-input').forEach(el => {
            el.addEventListener('input', function () {
                const row = this.closest('tr');
                markDirty(row, 'note', this.value);
            });
        });

        document.getElementById('btnSaveChanges').addEventListener('click', function () {
            const payload = Object.keys(changes).map(id => ({
                id: id,
                status: changes[id].status,
                note: changes[id].note
            }));

            fetch('/Scheduler/BulkInlineUpdate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            })
            .then(res => res.json())
            .then(res => {
                if (res.success) {
                    location.reload();
                } else {
                    alert('Gagal save');
                }
            })
            .catch(() => {
                alert('Gagal terhubung ke server');
            });
        });

        document.querySelectorAll('.auto-submit-filter').forEach(el => {
            el.addEventListener('change', function () {
                if (!confirmLeaveWithUnsavedChanges()) {
                    return;
                }

                document.getElementById('filterForm').submit();
            });
        });

        const filterDateInput = document.querySelector('input[name="filterDate"]');
        if (filterDateInput) {
            filterDateInput.addEventListener('change', function () {
                if (!confirmLeaveWithUnsavedChanges()) {
                    return;
                }

                document.getElementById('filterForm').submit();
            });
        }

        window.addEventListener('beforeunload', function (e) {
            if (hasUnsavedChanges()) {
                e.preventDefault();
                e.returnValue = '';
            }
        });

        document.getElementById('filterForm').addEventListener('submit', function (e) {
            if (!confirmLeaveWithUnsavedChanges()) {
                e.preventDefault();
            }
        });
    </script>
}